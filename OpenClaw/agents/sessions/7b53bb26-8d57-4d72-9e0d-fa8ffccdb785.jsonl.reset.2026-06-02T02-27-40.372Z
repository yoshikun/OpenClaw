{"type":"message","id":"116f3122","parentId":"b0aeddb0","timestamp":"2026-06-01T08:26:16.794Z","message":{"role":"toolResult","toolCallId":"call_00_ET_lDNNkBHUVNm3MMyaNMbx6497","toolName":"exec","content":[{"type":"text","text":"GET /ms/project/api/pipelines/p-f78c977835c84b71a6d58b4746cd1c4a/trigger => 404\nGET /ms/project/api/pipelines/trigger => 404\nGET /ms/project/api/pipelines/p-f78c977835c84b71a6d58b4746cd1c4a => 404\nGET /ms/project/api/pipelines/p-f78c977835c84b71a6d58b4746cd1c4a/run => 404\nGET /ms/project/api/pipeline/p-f78c977835c84b71a6d58b4746cd1c4a/trigger => 404\nGET /ms/project/api/pipeline/trigger => 404\nGET /ms/pipeline/api/pipelines/trigger => 404\nGET /ms/project/api/pipelines => 404\n\n--- POST 触发尝试 ---\nPOST /ms/project/api/pipelines/p-f78c977835c84b71a6d58b4746cd1c4a/trigger => 404\n  Data: {\"status\":404,\"data\":\"\",\"result\":true,\"message\":\"请求资源不存在。\"}\nPOST /ms/project/api/pipelines/trigger => 404\n  Data: {\"status\":404,\"data\":\"\",\"result\":true,\"message\":\"请求资源不存在。\"}"}],"details":{"status":"completed","exitCode":0,"durationMs":1954,"aggregated":"GET /ms/project/api/pipelines/p-f78c977835c84b71a6d58b4746cd1c4a/trigger => 404\nGET /ms/project/api/pipelines/trigger => 404\nGET /ms/project/api/pipelines/p-f78c977835c84b71a6d58b4746cd1c4a => 404\nGET /ms/project/api/pipelines/p-f78c977835c84b71a6d58b4746cd1c4a/run => 404\nGET /ms/project/api/pipeline/p-f78c977835c84b71a6d58b4746cd1c4a/trigger => 404\nGET /ms/project/api/pipeline/trigger => 404\nGET /ms/pipeline/api/pipelines/trigger => 404\nGET /ms/project/api/pipelines => 404\n\n--- POST 触发尝试 ---\nPOST /ms/project/api/pipelines/p-f78c977835c84b71a6d58b4746cd1c4a/trigger => 404\n  Data: {\"status\":404,\"data\":\"\",\"result\":true,\"message\":\"请求资源不存在。\"}\nPOST /ms/project/api/pipelines/trigger => 404\n  Data: {\"status\":404,\"data\":\"\",\"result\":true,\"message\":\"请求资源不存在。\"}","cwd":"C:\\Users\\yyzypublic\\.openclaw\\workspace"},"isError":false,"timestamp":1780302376794
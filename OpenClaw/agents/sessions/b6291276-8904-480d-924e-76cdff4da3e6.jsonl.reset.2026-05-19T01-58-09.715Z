{"type":"message","id":"0ad92f74","parentId":"fde527f8","timestamp":"2026-05-18T09:59:11.498Z","message":{"role":"toolResult","toolCallId":"toolu_vrtx_01SybshU7PUao89oLvC3npS6","toolName":"read","content":[{"type":"text","text":"﻿using System;\nusing Dida.GameLogic.Gordian;\nusing UnityEngine;\nusing UnityEngine.UI;\n\nnamespace Gordian\n{\n\n    public class GordianEquipCard : BaseItem\n    {\n        /* -------- AUTO GENERATED COMPONENT FIELDS START -------- */\n\t\tprotected RectTransform m_CardBgTransform;\n\t\tprotected RectTransform m_CardTransform;\n\t\tprotected Button m_BuyButton;\n\t\tprotected Image m_PriceImage;\n\t\tprotected Text m_PriceText;\n\n\t\tpublic Action OnBuyButtonCallback { get; set; }\n\n\t\tprotected override void BindComponents(GameObject go)\n\t\t{\n\t\t\tvar autoBindTool = go.GetComponent<AutoBindTool>();\n\n\t\t\tm_CardBgTransform = autoBindTool.BindComponent<RectTransform>(0);\n\t\t\tm_CardTransform = autoBindTool.BindComponent<RectTransform>(1);\n\t\t\tm_BuyButton = autoBindTool.BindComponent<Button>(2);\n\t\t\tm_PriceImage = autoBindTool.BindComponent<Image>(3);\n\t\t\tm_PriceText = autoBindTool.BindComponent<Text>(4);\n\t\t}\n        /* -------- AUTO GENERATED COMPONENT FIELDS END -------- */\n\n        private GordianCard m_Card;\n\n        private int m_HeroBaseId;\n\n        private int m_CardBaseId;\n\n        private int m_EquipId;\n\n        protected override void InitView()\n        {\n            base.InitView();\n        }\n\n        protected override void InitEvent()\n        {\n            m_BuyButton.onClick.AddListener(OnEquipButton);\n\n            m_Card = m_CardTransform.GetComponentInChildren<GordianCard>(true);\n            m_Card.OnClickCallback = OnClickCard;\n        }\n\n        public void OnEquipButton()\n        {\n            EventSystem.Instance.Fire(this, UIEquipCardClickEvent.Create(m_HeroBaseId, m_EquipId));\n        }\n\n        protected override void RemoveEvent()\n        {\n            m_BuyButton.onClick.RemoveAllListeners();\n        }\n\n        public override void Remove()\n        {\n            base.Remove();\n        }\n\n        public void InitData(int heroBaseId, int cardBaseId, int equipId)\n        {\n            m_HeroBaseId = heroBaseId;\n            m_CardBaseId = cardBaseId;\n            m_EquipId = equipId;\n\n            var baseData = ConfigSystem.Instance.GetCardData(m_CardBaseId);\n            if (baseData != null)\n            {\n                m_PriceImage.SetActive(false);\n\n                m_PriceText.text = LanguageEnum.Replace.GetLanguage();\n\n                m_Card.SetActive(true);\n\n                var cardVo = GordianCardVo.Create(baseData);\n                m_Card.InitData(cardVo);\n\n                m_CardBgTransform.SetActive(false);\n            }\n            else\n            {\n                m_PriceImage.SetActive(false);\n\n                m_PriceText.text = LanguageEnum.Wear.GetLanguage();\n\n                m_Card.SetActive(false);\n                m_CardBgTransform.SetActive(true);\n            }\n        }\n\n        private void OnClickCard(GordianCard card)\n        {\n            GordianUIManager.Instance.OpenCardDetailPanel(m_Card.Vo);\n        }\n\n        public Button BuyButton => m_BuyButton;\n\n        public int CardBaseId => m_CardBaseId;\n        public int HeroId => m_HeroBaseId;\n    }\n}\n"}],"isError":false,"timestamp":1779098351498}}

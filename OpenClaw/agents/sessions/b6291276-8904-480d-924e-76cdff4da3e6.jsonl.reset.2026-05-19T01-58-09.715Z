": \"bug_form\",\n    \"action\": \"https://www.tapd.cn/31253609/bugtrace/bugs/submit_from_add/0/security?return_url=https%3A%2F%2Fwww.tapd.cn%2F31253609%2Fbugtrace%2Fbugreports%2Fmy_view\",\n    \"method\": \"post\",\n    \"inputCount\": 33\n  },\n  {\n    \"id\": \"attachmentsForm\",\n    \"action\": \"https://file.tapd.cn/31253609/attachments/bug_add/security\",\n    \"method\": \"post\",\n    \"inputCount\": 4\n  },\n  {\n    \"id\": \"export_submit_form\",\n    \"action\": \"https://www.tapd.cn/31253609/bugtrace/bugs/edit?id=1131253609001016529\",\n    \"method\": \"post\",\n    \"inputCount\": 2\n  },\n  {\n    \"id\": \"\",\n    \"action\": \"https://www.tapd.cn/31253609/bugtrace/bugs/edit?id=1131253609001016529\",\n    \"method\": \"get\",\n    \"inputCount\": 1\n  }\n]\nCC fields: [\n  {\n    \"tag\": \"INPUT\",\n    \"id\": \"BugCc\",\n    \"name\": \"data[Bug][cc]\",\n    \"value\": \"\",\n    \"display\": \"none\"\n  },\n  {\n    \"tag\": \"INPUT\",\n    \"id\": \"BugCcValue\",\n    \"name\": \"\",\n    \"value\": \"\",\n    \"display\": \"inline-block\"\n  },\n  {\n    \"tag\": \"DIV\",\n    \"id\": \"BugCcValueValueTip\",\n    \"name\": \"\",\n    \"value\": \"\",\n    \"display\": \"block\"\n  }\n]","cwd":"C:\\Users\\yyzypublic\\.openclaw\\workspace"},"isError":false,"timestamp":1779076666576}}
{"type":"message","id":"118eab81","parentId":"897a8f58","timestamp":"2026-05-18T03:58:05.286Z","message":{"role":"assistant","content":[{"type":"text","text":"找到了！表单 `bug_form` 的 action 是 `submit_from_add`，CC 的隐藏字段是 `#BugCc`（`data[Bug][cc]`）。直接 JS 设置隐藏字段值然后提交表单："},{"type":"toolCall","id":"toolu_vrtx_017DFBhUa5WebFEi8r6vizYn","name":"write","arguments":{"path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\fix_bug_cc3.mjs","content":"/**\n * 修复 Bug 单抄送人 - 直接 JS 设置字段并提交表单\n */\nimport { chromium } from 'playwright';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\nconst WS_DIR = path.resolve(__dirname, '..');\nconst COOKIES_FILE = path.join(WS_DIR, 'tapd_cookies.json');\n\nconst BUG_ID = '1131253609001016529';\nconst WORKSPACE_ID = '31253609';\nconst EDIT_URL = `https://www.tapd.cn/${WORKSPACE_ID}/bugtrace/bugs/edit?id=${BUG_ID}`;\n\nconst cookies = JSON.parse(fs.readFileSync(COOKIES_FILE, 'utf8'));\nconst STEALTH = `Object.defineProperty(navigator,'webdriver',{get:()=>undefined});window.chrome={runtime:{}};`;\n\nconst browser = await chromium.launch({ headless: false, args: ['--no-sandbox'] });\nconst ctx = await browser.newContext({\n  userAgent: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',\n  viewport: { width: 1280, height: 900 },\n});\nawait ctx.addInitScript(STEALTH);\nawait ctx.addCookies(cookies);\nconst page = await ctx.newPage();\n\nconsole.log('Opening bug edit page...');\nawait page.goto(EDIT_URL, { waitUntil: 'networkidle', timeout: 30000 });\n\n// 先用自动补全输入 CC 以获取正确的 user ID 格式\nconsole.log('Setting CC via autocomplete...');\nconst ccInput = page.locator('#BugCcValue');\nawait ccInput.click();\nawait page.waitForTimeout(300);\nawait ccInput.fill('');\nawait ccInput.type('周以天', { delay: 150 });\nawait page.waitForTimeout(2500);\nawait page.keyboard.press('Enter');\nawait page.waitForTimeout(800);\n\n// 检查隐藏字段值\nconst ccVal = await page.locator('#BugCc').inputValue().catch(() => '');\nconsole.log('CC hidden value after autocomplete:', ccVal);\n\nif (!ccVal || ccVal.trim() === '') {\n  // 如果自动补全没有填上，直接用 JS 设置（使用 TAPD 用户 ID 格式）\n  console.log('Autocomplete failed, setting directly via JS...');\n  await page.evaluate(() => {\n    const el = document.querySelector('#BugCc');\n    if (el) {\n      el.value = '周以天;';\n      el.dispatchEvent(new Event('change'));\n    }\n    const elDisplay = document.querySelector('#BugCcValue');\n    if (elDisplay) elDisplay.value = '周以天';\n  });\n}\n\n// 直接提交 bug_form 表单\nconsole.log('Submitting bug_form via JS...');\nconst result = await page.evaluate(() => {\n  const form = document.getElementById('bug_form');\n  if (!form) return 'form not found';\n  // 设置提交类型（提交并查看）\n  const submitInput = document.getElementById('save_view');\n  if (submitInput) submitInput.disabled = false;\n  form.submit();\n  return 'submitted';\n});\nconsole.log('Submit result:', result);\n\n// 等待导航\ntry {\n  await page.waitForNavigation({ waitUntil: 'networkidle', timeout: 15000 });\n} catch {\n  await page.waitForTimeout(3000);\n}\n\nconst finalUrl = page.url();\nconsole.log('Final URL:', finalUrl);\n\nawait browser.close();\n"}}],"api":"openai-completions","provider":"openai-proxy","model":"giant-claude-sonnet-4-6","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779076666577,"responseId":"chatcmpl-0b6532a6-5d70-4086-b1ef-7f1e573c0b2a"}}

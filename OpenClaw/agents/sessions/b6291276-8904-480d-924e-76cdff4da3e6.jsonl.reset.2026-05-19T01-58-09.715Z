{"type":"message","id":"aa2187d6","parentId":"03a600cc","timestamp":"2026-05-18T09:59:04.403Z","message":{"role":"toolResult","toolCallId":"toolu_vrtx_01LVrsjQmXvk2NzGkAoJqXMi","toolName":"read","content":[{"type":"text","text":"﻿using UnityEngine;\nusing UnityEngine.UI;\n\nnamespace Gordian\n{\n\n    public class GordianEquipItem : BaseItem\n    {\n        /* -------- AUTO GENERATED COMPONENT FIELDS START -------- */\n\t\tprotected HorizontalLayoutGroup m_CardsHGroup;\n\n\t\tprotected override void BindComponents(GameObject go)\n\t\t{\n\t\t\tvar autoBindTool = go.GetComponent<AutoBindTool>();\n\n\t\t\tm_CardsHGroup = autoBindTool.BindComponent<HorizontalLayoutGroup>(0);\n\t\t}\n        /* -------- AUTO GENERATED COMPONENT FIELDS END -------- */\n\n        private GordianCardShopHeroItem m_HeroItem;\n\n        private GordianEquipItemVo m_Vo;\n        public GordianEquipItemVo Vo => m_Vo;\n\n        private float m_OriginSpacing;\n\n        protected override void InitView()\n        {\n            base.InitView();\n\n            m_HeroItem = transform.GetComponentInChildren<GordianCardShopHeroItem>(true);\n\n            m_OriginSpacing = m_CardsHGroup.spacing;\n        }\n\n        protected override void InitEvent()\n        {\n\n        }\n\n        protected override void RemoveEvent()\n        {\n        }\n\n        public override void Remove()\n        {\n            base.Remove();\n\n            m_CardsHGroup.spacing = m_OriginSpacing;\n        }\n\n        public void InitData(GordianEquipItemVo vo)\n        {\n            m_Vo = vo;\n\n            m_HeroItem.InitData(m_Vo.HeroVo);\n\n            var heroBaseId = m_Vo.HeroVo.BaseId;\n            for (int i = 0; i < m_CardsHGroup.transform.childCount; i++)\n            {\n                var posTransform = m_CardsHGroup.transform.GetChild(i);\n\n                var card = posTransform.GetComponentInChildren<GordianEquipCard>(true);\n                if (m_Vo.EquipList.Count > i)\n                {\n                    var cardVo = m_Vo.EquipList[i];\n                    card.InitData(heroBaseId, cardVo.BaseId, cardVo.Id);\n                }\n                else\n                {\n                    card.InitData(heroBaseId, 0, 0);\n                }\n\n                if (m_Vo.HeroVo.Slot == GordianConfig.EquipSlot)\n                {\n                    // 2个中间间距大一点\n                    m_CardsHGroup.spacing = GordianAdjustManager.Instance.IsPC ? 200 : 80;\n                }\n                else\n                {\n                    m_CardsHGroup.spacing = m_OriginSpacing;\n                }\n                card.transform.parent.SetActive(m_Vo.HeroVo.Slot > i);\n            }\n        }\n    }\n}\n"}],"isError":false,"timestamp":1779098344403}}

{"type":"message","id":"56e352d5","parentId":"9deecf81","timestamp":"2026-05-18T10:01:13.200Z","message":{"role":"toolResult","toolCallId":"toolu_vrtx_01HnkAwXDCTE9R8LeS96N8WU","toolName":"read","content":[{"type":"text","text":"﻿using UnityEngine;\nusing UnityEngine.UI;\n\nnamespace Gordian\n{\n\n    public class GordianEquipWarCard : BaseItem\n    {\n        /* -------- AUTO GENERATED COMPONENT FIELDS START -------- */\n\t\tprotected RectTransform m_CardTransform;\n\t\tprotected RectTransform m_CardBgTransform;\n\n\t\tprotected override void BindComponents(GameObject go)\n\t\t{\n\t\t\tvar autoBindTool = go.GetComponent<AutoBindTool>();\n\n\t\t\tm_CardTransform = autoBindTool.BindComponent<RectTransform>(0);\n\t\t\tm_CardBgTransform = autoBindTool.BindComponent<RectTransform>(1);\n\t\t}\n        /* -------- AUTO GENERATED COMPONENT FIELDS END -------- */\n\n        private GordianWarCardVo m_WarCardVo;\n\n        private GordianWarCard m_Card;\n\n        protected override void InitView()\n        {\n            base.InitView();\n        }\n\n        protected override void InitEvent()\n        {\n            m_Card = m_CardTransform.GetComponentInChildren<GordianWarCard>(true);\n            m_Card.OnClickCallback = OnClickCard;\n        }\n\n        public override void Remove()\n        {\n            base.Remove();\n        }\n\n        public void InitData(GordianWarCardVo warCarVo)\n        {\n            m_WarCardVo = warCarVo;\n\n            if (m_WarCardVo.BaseData != null)\n            {\n                m_Card.SetActive(true);\n\n                m_Card.InitData(m_WarCardVo);\n\n                m_CardBgTransform.SetActive(false);\n            }\n            else\n            {\n                m_Card.SetActive(false);\n                m_CardBgTransform.SetActive(true);\n            }\n        }\n\n        private void OnClickCard(GordianWarCard card)\n        {\n            var panel = GordianUIManager.Instance.OpenForm(UIFormId.GordianCardDetailPanel, (logic) =>\n            {\n                var panel = logic as GordianCardDetailPanel;\n                panel.InitData(card.Vo);\n            });\n        }\n    }\n}\n"}],"isError":false,"timestamp":1779098473200}}

{"type":"message","id":"f786315b","parentId":"0f3c4909","timestamp":"2026-05-18T11:25:16.034Z","message":{"role":"assistant","content":[{"type":"text","text":"上传了但文件大小是 0，`content_type` 是 `inode/x-empty`，说明文件内容没传上去。换用 Playwright 浏览器内的 fetch 来上传，带正确的 session cookie："},{"type":"toolCall","id":"toolu_vrtx_014inzHJMkG9R4wKGDgqaf5n","name":"write","arguments":{"path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\upload_bug_attachment6.mjs","content":"/**\n * 在浏览器上下文内用 XHR 上传附件到已有 bug 单\n */\nimport { chromium } from 'playwright';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\nconst WS_DIR = path.resolve(__dirname, '..');\nconst COOKIES_FILE = path.join(WS_DIR, 'tapd_cookies.json');\n\nconst BUG_ID = '1131253609001016534';\nconst WORKSPACE_ID = '31253609';\nconst ATTACHMENT_PATH = 'C:\\\\Users\\\\yyzypublic\\\\.openclaw\\\\media\\\\inbound\\\\3413db8c-85b9-44d3-a090-d07cf86b2cc4.jpg';\n\nconst cookies = JSON.parse(fs.readFileSync(COOKIES_FILE, 'utf8'));\nconst STEALTH = `Object.defineProperty(navigator,'webdriver',{get:()=>undefined});window.chrome={runtime:{}};`;\nconst filename = path.basename(ATTACHMENT_PATH);\nconst fileBuffer = fs.readFileSync(ATTACHMENT_PATH);\n\nconst browser = await chromium.launch({ headless: true, args: ['--no-sandbox'] });\nconst ctx = await browser.newContext({\n  userAgent: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',\n});\nawait ctx.addInitScript(STEALTH);\nawait ctx.addCookies(cookies);\nconst page = await ctx.newPage();\n\n// 先访问一下 TAPD 建立 session\nawait page.goto(`https://www.tapd.cn/${WORKSPACE_ID}/bugtrace/bugs/view?id=${BUG_ID}`, { waitUntil: 'networkidle', timeout: 30000 });\n\nconsole.log('页面加载完成，开始上传...');\n\n// 用 page.request 在浏览器 cookie context 内上传（带完整 session）\nconst uploadUrl = `https://www.tapd.cn/${WORKSPACE_ID}/attachments/add_attachment_drag/Bug/${BUG_ID}/security?filename=${encodeURIComponent(filename)}`;\n\nconst response = await page.request.post(uploadUrl, {\n  multipart: {\n    Filedata: {\n      name: filename,\n      mimeType: 'image/jpeg',\n      buffer: fileBuffer,\n    },\n  },\n  headers: {\n    'Referer': `https://www.tapd.cn/${WORKSPACE_ID}/bugtrace/bugs/view?id=${BUG_ID}`,\n    'Origin': 'https://www.tapd.cn',\n    'X-Requested-With': 'XMLHttpRequest',\n  },\n});\n\nconst responseText = await response.text();\nconsole.log('响应状态:', response.status());\nconsole.log('响应内容:', responseText.substring(0, 500));\n\nawait browser.close();\n"}}],"api":"openai-completions","provider":"openai-proxy","model":"giant-claude-sonnet-4-6","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779103501507,"responseId":"chatcmpl-74ffb791-8bce-4540-9f24-d60a4cc3ba88"}}

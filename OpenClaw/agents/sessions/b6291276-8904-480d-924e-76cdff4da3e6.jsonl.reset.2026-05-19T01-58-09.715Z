{"type":"message","id":"31195311","parentId":"339fa2b3","timestamp":"2026-05-18T11:26:01.690Z","message":{"role":"assistant","content":[{"type":"text","text":"还是 size=0，TAPD 那个 API 接收的 field name 可能不是 `Filedata`。从网络日志看到实际上传用的是 `add_attachment_drag`，但 field name 需要确认。试一下其他常见 field name："},{"type":"toolCall","id":"toolu_vrtx_015sGxYoh57tggTpSmHd3aR1","name":"write","arguments":{"path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\upload_bug_attachment7.mjs","content":"/**\n * 用 Playwright 模拟真实文件上传行为 - headed 模式在详情页直接操作\n */\nimport { chromium } from 'playwright';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\nconst WS_DIR = path.resolve(__dirname, '..');\nconst COOKIES_FILE = path.join(WS_DIR, 'tapd_cookies.json');\n\nconst BUG_ID = '1131253609001016534';\nconst WORKSPACE_ID = '31253609';\n// 用新版 FE 详情页\nconst DETAIL_URL = `https://www.tapd.cn/tapd_fe/${WORKSPACE_ID}/bug/detail/${BUG_ID}`;\nconst ATTACHMENT_PATH = 'C:\\\\Users\\\\yyzypublic\\\\.openclaw\\\\media\\\\inbound\\\\3413db8c-85b9-44d3-a090-d07cf86b2cc4.jpg';\n\nconst cookies = JSON.parse(fs.readFileSync(COOKIES_FILE, 'utf8'));\nconst STEALTH = `Object.defineProperty(navigator,'webdriver',{get:()=>undefined});window.chrome={runtime:{}};`;\n\nconst browser = await chromium.launch({ headless: false, args: ['--no-sandbox'] });\nconst ctx = await browser.newContext({\n  userAgent: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',\n  viewport: { width: 1440, height: 900 },\n});\nawait ctx.addInitScript(STEALTH);\nawait ctx.addCookies(cookies);\nconst page = await ctx.newPage();\n\n// 监听附件上传请求\npage.on('response', async res => {\n  if (res.url().includes('attach') && !res.url().includes('.css') && !res.url().includes('.js')) {\n    let body = '';\n    try { body = await res.text(); } catch {}\n    console.log(`[RESPONSE] ${res.status()} ${res.url().substring(0, 100)}`);\n    if (body && body.length < 500) console.log('  Body:', body);\n  }\n});\n\nconsole.log('打开 bug 详情页...');\nawait page.goto(DETAIL_URL, { waitUntil: 'networkidle', timeout: 30000 });\nawait page.waitForTimeout(2000);\n\n// 找附件上传的 input\nconst fileInputs = await page.locator('input[type=\"file\"]').all();\nconsole.log(`找到 ${fileInputs.length} 个 file input`);\n\nif (fileInputs.length > 0) {\n  // 直接 setInputFiles 触发上传\n  await fileInputs[0].setInputFiles(ATTACHMENT_PATH);\n  console.log('已选择文件，等待上传...');\n  await page.waitForTimeout(5000);\n} else {\n  // 详情页可能没有直接的 file input，找上传按钮\n  const uploadBtns = await page.locator('[class*=\"upload\"], [class*=\"attach\"], button:has-text(\"上传\"), a:has-text(\"上传\"), a:has-text(\"附件\")').all();\n  console.log(`找到 ${uploadBtns.length} 个上传相关按钮`);\n  \n  for (const btn of uploadBtns.slice(0, 3)) {\n    const text = await btn.textContent();\n    console.log('按钮:', text?.trim());\n  }\n  \n  if (uploadBtns.length > 0) {\n    await uploadBtns[0].click();\n    await page.waitForTimeout(1000);\n    \n    // 再找 file input\n    const inputs = await page.locator('input[type=\"file\"]').all();\n    console.log(`点击后找到 ${inputs.length} 个 file input`);\n    if (inputs.length > 0) {\n      await inputs[0].setInputFiles(ATTACHMENT_PATH);\n      await page.waitForTimeout(5000);\n    }\n  }\n}\n\n// 截图看结果\nawait page.screenshot({ path: path.join(WS_DIR, 'memory/attach_final.png') });\nconsole.log('完成');\n\nawait browser.close();\n"}}],"api":"openai-completions","provider":"openai-proxy","model":"giant-claude-sonnet-4-6","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779103539776,"responseId":"chatcmpl-d408cd64-72c8-4461-b897-da5226fcdce0"}}

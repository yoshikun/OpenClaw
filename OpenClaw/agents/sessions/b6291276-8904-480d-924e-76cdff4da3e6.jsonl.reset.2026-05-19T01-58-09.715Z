{"type":"message","id":"e57cbff3","parentId":"9b141f36","timestamp":"2026-05-18T11:26:59.234Z","message":{"role":"assistant","content":[{"type":"text","text":"新版 FE 页面加载慢，改用旧版 view 页面，并且降低等待条件："},{"type":"toolCall","id":"toolu_vrtx_01CHqsFuUjpH8DKF4mTqKnu7","name":"write","arguments":{"path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\upload_bug_attachment8.mjs","content":"/**\n * 在 bug 详情/编辑页直接操作附件 - 简化版\n */\nimport { chromium } from 'playwright';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\nconst WS_DIR = path.resolve(__dirname, '..');\nconst COOKIES_FILE = path.join(WS_DIR, 'tapd_cookies.json');\n\nconst BUG_ID = '1131253609001016534';\nconst WORKSPACE_ID = '31253609';\nconst VIEW_URL = `https://www.tapd.cn/${WORKSPACE_ID}/bugtrace/bugs/view?id=${BUG_ID}`;\nconst ATTACHMENT_PATH = 'C:\\\\Users\\\\yyzypublic\\\\.openclaw\\\\media\\\\inbound\\\\3413db8c-85b9-44d3-a090-d07cf86b2cc4.jpg';\n\nconst cookies = JSON.parse(fs.readFileSync(COOKIES_FILE, 'utf8'));\nconst STEALTH = `Object.defineProperty(navigator,'webdriver',{get:()=>undefined});window.chrome={runtime:{}};`;\n\n// 监听上传响应\nconst uploadResponses = [];\n\nconst browser = await chromium.launch({ headless: false, args: ['--no-sandbox'] });\nconst ctx = await browser.newContext({\n  userAgent: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',\n  viewport: { width: 1440, height: 900 },\n});\nawait ctx.addInitScript(STEALTH);\nawait ctx.addCookies(cookies);\nconst page = await ctx.newPage();\n\npage.on('response', async res => {\n  const url = res.url();\n  if (url.includes('add_attachment') || url.includes('attachments_list')) {\n    let body = '';\n    try { body = await res.text(); } catch {}\n    uploadResponses.push({ status: res.status(), url: url.substring(0, 120), body: body.substring(0, 300) });\n  }\n});\n\nconsole.log('打开 bug 详情页...');\nawait page.goto(VIEW_URL, { waitUntil: 'domcontentloaded', timeout: 30000 });\nawait page.waitForTimeout(3000);\n\n// 找附件区域的上传触发\nconsole.log('找上传触发按钮...');\nconst trigger = page.locator('#upload-attachement, a:has-text(\"本地上传\"), a:has-text(\"上传附件\")').first();\nconst triggerCount = await trigger.count();\nconsole.log(`上传触发按钮: ${triggerCount}`);\n\nif (triggerCount > 0) {\n  await trigger.click();\n  await page.waitForTimeout(800);\n}\n\n// 上传文件\nconst fileInputs = await page.locator('input[type=\"file\"]').all();\nconsole.log(`file input 数量: ${fileInputs.length}`);\n\nif (fileInputs.length > 0) {\n  await fileInputs[0].setInputFiles(ATTACHMENT_PATH);\n  console.log('文件已选择，等待上传...');\n  await page.waitForTimeout(6000);\n  \n  console.log('上传响应:', JSON.stringify(uploadResponses, null, 2));\n} else {\n  console.log('未找到 file input');\n  // 截图看页面结构\n  await page.screenshot({ path: path.join(WS_DIR, 'memory/attach_debug.png') });\n}\n\nawait browser.close();\n"}}],"api":"openai-completions","provider":"openai-proxy","model":"giant-claude-sonnet-4-6","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779103599648,"responseId":"chatcmpl-5a66790a-13fa-4d0b-9842-03d95de70ce1"}}

{"type":"message","id":"f76f80d4","parentId":"9468e2e9","timestamp":"2026-05-18T11:27:32.966Z","message":{"role":"assistant","content":[{"type":"text","text":"详情页没有文件上传控件，只在编辑页有。问题根源找到了：**编辑页的附件是临时上传（bugtemp），提交 bug_form 时需要正确的隐藏字段把临时附件 ID 关联到 bug**，但 form.submit() 方式绕过了这个逻辑。\n\n最简单可靠的方案——用编辑页，上传后**等待 JS 自动把附件 ID 写入隐藏字段，再提交**："},{"type":"toolCall","id":"toolu_vrtx_01WZiM6m3RX5aBaaLEmvnfdo","name":"write","arguments":{"path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\upload_bug_attachment9.mjs","content":"/**\n * 编辑页上传附件 - 等待附件 ID 写入隐藏字段再提交\n */\nimport { chromium } from 'playwright';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\nconst WS_DIR = path.resolve(__dirname, '..');\nconst COOKIES_FILE = path.join(WS_DIR, 'tapd_cookies.json');\n\nconst BUG_ID = '1131253609001016534';\nconst WORKSPACE_ID = '31253609';\nconst EDIT_URL = `https://www.tapd.cn/${WORKSPACE_ID}/bugtrace/bugs/edit?id=${BUG_ID}`;\nconst ATTACHMENT_PATH = 'C:\\\\Users\\\\yyzypublic\\\\.openclaw\\\\media\\\\inbound\\\\3413db8c-85b9-44d3-a090-d07cf86b2cc4.jpg';\n\nconst cookies = JSON.parse(fs.readFileSync(COOKIES_FILE, 'utf8'));\nconst STEALTH = `Object.defineProperty(navigator,'webdriver',{get:()=>undefined});window.chrome={runtime:{}};`;\n\nconst uploadResponses = [];\n\nconst browser = await chromium.launch({ headless: false, args: ['--no-sandbox'] });\nconst ctx = await browser.newContext({\n  userAgent: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',\n  viewport: { width: 1440, height: 900 },\n});\nawait ctx.addInitScript(STEALTH);\nawait ctx.addCookies(cookies);\nconst page = await ctx.newPage();\n\npage.on('response', async res => {\n  const url = res.url();\n  if (url.includes('add_attachment_drag')) {\n    let body = '';\n    try { body = await res.text(); } catch {}\n    uploadResponses.push({ status: res.status(), body });\n    console.log(`[上传响应] ${res.status()} ${body.substring(0, 200)}`);\n  }\n});\n\nconsole.log('打开编辑页...');\nawait page.goto(EDIT_URL, { waitUntil: 'networkidle', timeout: 30000 });\n\n// 点击上传触发\nconsole.log('点击上传触发...');\nawait page.locator('#upload-attachement').first().click();\nawait page.waitForTimeout(1000);\n\n// 上传文件\nconsole.log('选择文件...');\nawait page.locator('#file_input').first().setInputFiles(ATTACHMENT_PATH);\n\n// 等待上传完成（监听响应）\nconsole.log('等待上传完成...');\nawait page.waitForResponse(res => res.url().includes('add_attachment_drag'), { timeout: 15000 });\nawait page.waitForTimeout(2000);\n\n// 检查附件区域是否已显示文件名\nconst attachedFiles = await page.evaluate(() => {\n  // 找附件列表中的文件项\n  const items = document.querySelectorAll('.attachment-detail, .filename, [class*=\"attach-file\"]');\n  return Array.from(items).map(el => el.textContent?.trim()).filter(t => t && t.length < 100);\n});\nconsole.log('已上传附件:', attachedFiles);\n\n// 检查附件相关的隐藏字段\nconst hiddenInfo = await page.evaluate(() => {\n  const all = document.querySelectorAll('input[type=hidden]');\n  return Array.from(all)\n    .filter(i => i.name.includes('attach') || i.name.includes('file') || i.value.includes('attach'))\n    .map(i => ({ name: i.name, value: i.value?.substring(0, 100) }));\n});\nconsole.log('附件相关隐藏字段:', JSON.stringify(hiddenInfo));\n\n// 提交（用 a#_view 点击，跟创建页一样）\nconsole.log('提交...');\nawait page.locator('a#_view').click();\n\ntry {\n  await page.waitForNavigation({ waitUntil: 'networkidle', timeout: 15000 });\n} catch {\n  await page.waitForTimeout(3000);\n}\n\nconst finalUrl = page.url();\nconsole.log('完成 URL:', finalUrl);\n\nawait browser.close();\n"}}],"api":"openai-completions","provider":"openai-proxy","model":"giant-claude-sonnet-4-6","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779103632222,"responseId":"chatcmpl-9844c42c-915e-423d-9b46-a8f8b70a789a"}}

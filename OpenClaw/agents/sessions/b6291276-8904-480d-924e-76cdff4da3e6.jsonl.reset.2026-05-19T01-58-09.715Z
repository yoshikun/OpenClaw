{"type":"message","id":"ee0b33a1","parentId":"c892959d","timestamp":"2026-05-18T03:40:29.688Z","message":{"role":"assistant","content":[{"type":"text","text":"没有 `create_bug.mjs`，需要我现在写一个。根据 SKILL.md 的配置来生成："},{"type":"toolCall","id":"toolu_vrtx_01DRMiAT3bNnTcqoBb72Gdpz","name":"write","arguments":{"path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\create_bug.mjs","content":"/**\n * TAPD 创建缺陷（Bug）脚本\n * 工作区：31253609（月圆之夜）\n */\n\nimport { chromium } from 'playwright';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\nconst WS_DIR = path.resolve(__dirname, '..');\nconst COOKIES_FILE = path.join(WS_DIR, 'tapd_cookies.json');\nconst WORKSPACE_ID = '31253609';\nconst BUG_CREATE_URL = `https://www.tapd.cn/${WORKSPACE_ID}/bugtrace/bugs/add`;\n\nconst STEALTH_SCRIPT = `\n  Object.defineProperty(navigator, 'webdriver', { get: () => undefined });\n  Object.defineProperty(navigator, 'plugins', { get: () => [1, 2, 3, 4, 5] });\n  Object.defineProperty(navigator, 'languages', { get: () => ['zh-CN', 'zh', 'en'] });\n  Object.defineProperty(navigator, 'hardwareConcurrency', { get: () => 8 });\n  window.chrome = { runtime: {} };\n`;\n\n/**\n * 创建 Bug\n * @param {Object} opts\n * @param {string} opts.title - 标题（必填）\n * @param {string} [opts.handler='叶枝君'] - 处理人（姓名）\n * @param {string} [opts.cc='周以天;'] - 抄送（姓名;格式）\n * @param {string} [opts.priority='P2'] - 优先级\n * @param {string} [opts.version='【1V1】正式版本V2.0'] - 发现版本\n * @param {string} [opts.module='1V1'] - 模块\n * @param {string} [opts.branch='YZY_1V1 V1.0 Beta'] - 研发分支\n * @param {string} [opts.description=''] - 描述\n * @param {string[]} [opts.attachments=[]] - 附件路径列表\n * @returns {Promise<string>} Bug 详情页 URL\n */\nexport async function createBug(opts = {}) {\n  const {\n    title,\n    handler = '叶枝君',\n    cc = '周以天;',\n    priority = 'P2',\n    version = '【1V1】正式版本V2.0',\n    module: mod = '1V1',\n    branch = 'YZY_1V1 V1.0 Beta',\n    description = '',\n    attachments = [],\n  } = opts;\n\n  if (!title) throw new Error('title is required');\n\n  // 读取 cookies\n  if (!fs.existsSync(COOKIES_FILE)) {\n    throw new Error(`Cookies file not found: ${COOKIES_FILE}`);\n  }\n  const cookies = JSON.parse(fs.readFileSync(COOKIES_FILE, 'utf8'));\n\n  const browser = await chromium.launch({\n    headless: true,\n    args: [\n      '--no-sandbox',\n      '--disable-blink-features=AutomationControlled',\n      '--user-agent=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',\n    ],\n  });\n\n  const context = await browser.newContext({\n    userAgent: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',\n  });\n\n  await context.addInitScript(STEALTH_SCRIPT);\n  await context.addCookies(cookies);\n\n  const page = await context.newPage();\n\n  try {\n    console.log('Opening bug create page...');\n    await page.goto(BUG_CREATE_URL, { waitUntil: 'networkidle', timeout: 30000 });\n\n    // 检查是否被重定向到登录页\n    if (page.url().includes('login')) {\n      throw new Error('TAPD session expired, please re-login');\n    }\n\n    // 填写标题\n    await page.fill('#BugTitle', title);\n    console.log(`Title: ${title}`);\n\n    // 优先级\n    await page.selectOption('#BugPriority', priority);\n    console.log(`Priority: ${priority}`);\n\n    // 发现版本\n    try {\n      // 先尝试 select\n      await page.selectOption('#BugVersionReport', { label: version }, { timeout: 2000 });\n    } catch {\n      await page.fill('#BugVersionReport', version);\n    }\n    console.log(`Version: ${version}`);\n\n    // 模块\n    try {\n      await page.selectOption('#BugModule', { label: mod }, { timeout: 2000 });\n    } catch {\n      await page.fill('#BugModule', mod);\n    }\n    console.log(`Module: ${mod}`);\n\n    // 研发分支（自定义字段）\n    try {\n      await page.fill('#BugCustomFieldOne', branch);\n      console.log(`Branch: ${branch}`);\n    } catch (e) {\n      console.warn('Branch field not found, skipping:', e.message);\n    }\n\n    // 处理人（自动补全）\n    await page.fill('#BugCurrentOwnerValue', handler);\n    await page.waitForTimeout(1500);\n    await page.keyboard.press('Enter');\n    await page.waitForTimeout(500);\n    console.log(`Handler: ${handler}`);\n\n    // 抄送（直接填写 hidden 字段）\n    try {\n      // 先尝试点击 CC 输入区\n      const ccInput = page.locator('#BugCcValue').first();\n      if (await ccInput.count() > 0) {\n        await ccInput.fill(cc.replace(/;$/, ''));\n        await page.waitForTimeout(1500);\n        await page.keyboard.press('Enter');\n        await page.waitForTimeout(500);\n      }\n    } catch (e) {\n      console.warn('CC field autocomplete failed, trying hidden field:', e.message);\n      try {\n        await page.evaluate((ccVal) => {\n          const el = document.querySelector('#BugCc');\n          if (el) el.value = ccVal;\n        }, cc);\n      } catch (e2) {\n        console.warn('CC hidden field also failed:', e2.message);\n      }\n    }\n    console.log(`CC: ${cc}`);\n\n    // 描述\n    if (description) {\n      try {\n        // 尝试富文本编辑器\n        const descFrame = page.frameLocator('iframe[id*=\"BugDescription\"], iframe[title*=\"description\"]').first();\n        await descFrame.locator('body').fill(description);\n      } catch {\n        try {\n          await page.fill('#BugDescription', description);\n        } catch (e) {\n          console.warn('Description field not found:', e.message);\n        }\n      }\n    }\n\n    // 附件上传\n    if (attachments.length > 0) {\n      for (const filePath of attachments) {\n        if (fs.existsSync(filePath)) {\n          console.log(`Uploading: ${filePath}`);\n          await page.locator('#file_input').first().setInputFiles(filePath);\n          await page.waitForTimeout(3000);\n        } else {\n          console.warn(`Attachment not found: ${filePath}`);\n        }\n      }\n    }\n\n    // 提交\n    console.log('Submitting...');\n    await page.click('#_view');\n    await page.waitForNavigation({ waitUntil: 'networkidle', timeout: 15000 });\n\n    const finalUrl = page.url();\n    console.log(`Bug created: ${finalUrl}`);\n    return finalUrl;\n\n  } finally {\n    await browser.close();\n  }\n}\n\n// 直接运行时的入口\nif (process.argv[1] === fileURLToPath(import.meta.url)) {\n  const args = process.argv.slice(2);\n  const title = args[0] || '测试 Bug';\n  createBug({ title })\n    .then(url => {\n      console.log('SUCCESS:', url);\n      process.exit(0);\n    })\n    .catch(err => {\n      console.error('FAILED:', err.message);\n      process.exit(1);\n    });\n}\n"}}],"api":"openai-completions","provider":"openai-proxy","model":"giant-claude-sonnet-4-6","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779075595669,"responseId":"chatcmpl-619761b6-2c1f-4191-b6fd-434798c0edb2"}}

{"type":"message","id":"cd42a79e","parentId":"aaf348a9","timestamp":"2026-05-18T09:38:37.094Z","message":{"role":"assistant","content":[{"type":"text","text":"有 appId 和 appSecret，可以直接调飞书 API 发群消息："},{"type":"toolCall","id":"toolu_vrtx_015sXT6hMJgiH7LofvBVRpxq","name":"write","arguments":{"path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\feishu_send_group.mjs","content":"/**\n * 飞书群消息发送工具\n * 使用 OpenClaw 配置的 appId/appSecret 获取 tenant_access_token 后发送消息\n */\n\nconst APP_ID = 'cli_a9458ff380b99ccb';\nconst APP_SECRET = 'Qs3NVpgH7h4UP7cVPfZRHh72E3jEOGKv';\n\nasync function getTenantAccessToken() {\n  const res = await fetch('https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal', {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ app_id: APP_ID, app_secret: APP_SECRET }),\n  });\n  const data = await res.json();\n  if (data.code !== 0) throw new Error(`Get token failed: ${JSON.stringify(data)}`);\n  return data.tenant_access_token;\n}\n\n/**\n * 发送飞书群消息（富文本，支持 @ 提及）\n * @param {string} chatId - 群 chat_id，如 oc_xxx\n * @param {string} text - 消息文本（支持 <at user_id=\"xxx\">name</at> 格式）\n */\nexport async function sendGroupMessage(chatId, text) {\n  const token = await getTenantAccessToken();\n\n  const res = await fetch('https://open.feishu.cn/open-apis/im/v1/messages?receive_id_type=chat_id', {\n    method: 'POST',\n    headers: {\n      'Content-Type': 'application/json',\n      'Authorization': `Bearer ${token}`,\n    },\n    body: JSON.stringify({\n      receive_id: chatId,\n      msg_type: 'text',\n      content: JSON.stringify({ text }),\n    }),\n  });\n\n  const data = await res.json();\n  if (data.code !== 0) throw new Error(`Send message failed: ${JSON.stringify(data)}`);\n  return data.data?.message_id;\n}\n\n// 直接运行时的入口\nconst chatId = process.argv[2] || 'oc_59afc01122ec0cd04ca4d8c5103c7a77';\nconst text = process.argv[3] || '热更已完成，测试服已更新 ✅ <at user_id=\"ou_348eeddd81d4c03865f9f1684fce6966\">兵王(周以天)</at>';\n\nsendGroupMessage(chatId, text)\n  .then(msgId => {\n    console.log('发送成功！message_id:', msgId);\n  })\n  .catch(e => {\n    console.error('发送失败:', e.message);\n    process.exit(1);\n  });\n"}}],"api":"openai-completions","provider":"openai-proxy","model":"giant-claude-sonnet-4-6","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779097100561,"responseId":"chatcmpl-f8b4de04-b756-4ab2-bae9-3cba597d238d"}}

{"type":"message","id":"1be21a27","parentId":"847cd594","timestamp":"2026-05-18T10:01:22.956Z","message":{"role":"toolResult","toolCallId":"toolu_vrtx_01RdLymZxEqvsAof75nfza5W","toolName":"read","content":[{"type":"text","text":"﻿using System;\nusing System.Collections.Generic;\nusing System.Linq;\nusing System.Text;\nusing DG.Tweening;\nusing Dida.GameLogic.Common;\nusing Dida.GameLogic.Gordian;\nusing UnityEngine;\nusing UnityEngine.EventSystems;\nusing UnityEngine.UI;\n\nnamespace Gordian\n{\n    public class GordianWarCard : BaseItem, IPointerClickHandler\n    {\n        /* -------- AUTO GENERATED COMPONENT FIELDS START -------- */\n        protected RectTransform m_ContentTransform;\n        protected Image m_BgLightImage;\n        protected Image m_BgImage;\n        protected Image m_IconImage;\n        protected RectTransform m_CostTransform;\n        protected Text m_NumText;\n        protected Text m_NameText;\n        protected Text m_TypeText;\n        protected Text m_DescText;\n        protected Image m_QualityImage;\n        protected RectTransform m_CannotUpgradeTransform;\n        protected RectTransform m_EffectTransform;\n        protected RectTransform m_StarTransform;\n        protected Image m_StarImage;\n        protected RectTransform m_OwnerTransform;\n        protected Image m_OwnerImage;\n        protected RectTransform m_TipTransform;\n        protected RectTransform m_UnequipTransform;\n        protected RectTransform m_NoChooseTransform;\n\n        protected override void BindComponents(GameObject go)\n        {\n            var autoBindTool = go.GetComponent<AutoBindTool>();\n\n            m_ContentTransform = autoBindTool.BindComponent<RectTransform>(0);\n            m_BgLightImage = autoBindTool.BindComponent<Image>(1);\n            m_BgImage = autoBindTool.BindComponent<Image>(2);\n            m_IconImage = autoBindTool.BindComponent<Image>(3);\n            m_CostTransform = autoBindTool.BindComponent<RectTransform>(4);\n            m_NumText = autoBindTool.BindComponent<Text>(5);\n            m_NameText = autoBindTool.BindComponent<Text>(6);\n            m_TypeText = autoBindTool.BindComponent<Text>(7);\n            m_DescText = autoBindTool.BindComponent<Text>(8);\n            m_QualityImage = autoBindTool.BindComponent<Image>(9);\n            m_CannotUpgradeTransform = autoBindTool.BindComponent<RectTransform>(10);\n            m_EffectTransform = autoBindTool.BindComponent<RectTransform>(11);\n            m_StarTransform = autoBindTool.BindComponent<RectTransform>(12);\n            m_StarImage = autoBindTool.BindComponent<Image>(13);\n            m_OwnerTransform = autoBindTool.BindComponent<RectTransform>(14);\n            m_OwnerImage = autoBindTool.BindComponent<Image>(15);\n            m_TipTransform = autoBindTool.BindComponent<RectTransform>(16);\n            m_UnequipTransform = autoBindTool.BindComponent<RectTransform>(17);\n            m_NoChooseTransform = autoBindTool.BindComponent<RectTransform>(18);\n        }\n        /* -------- AUTO GENERATED COMPONENT FIELDS END -------- */\n\n        // 数据\n        protected GordianWarCardVo m_Vo;\n\n        // 点击回调\n        public Action<GordianWarCard> OnClickCallback;\n\n        // 品质图\n        private MultiImage m_QualityMultiImage;\n\n        // 拖动操作前记录原始位置等信息\n        private TransformInfo m_OriginInfo = new TransformInfo();\n\n        // 触摸缓动参数\n        private float m_TouchScale = 1f;\n        private float m_TouchMoveY = 250f;\n        private float m_TouchTime = 0.25f;\n\n        // 移除动画\n        private bool m_Removing;\n\n        // 拖动特效\n        public GameObject m_DragEffect;\n\n        // 加载过\n        public bool m_DragEffectLoaded;\n\n        // 显示拖动特效\n        public bool m_DragEffectVisible;\n\n        // 临时牌\n        private bool m_IsTemp;\n\n        // 卡牌位置\n        private int m_CardPos = (int)WarCardPos.None;\n\n        // 用于更新Fianl, 性能优化\n        private bool m_HasFinal;\n\n        public EffectsStencilMask m_Mask;\n\n        protected override void InitView()\n        {\n            base.InitView();\n\n            m_QualityMultiImage = m_QualityImage.GetComponent<MultiImage>();\n\n            m_Mask = gameObject.GetComponentInChildren<EffectsStencilMask>();\n        }\n\n        protected override void InitEvent()\n        {\n        }\n\n        public void OnPointerClick(PointerEventData eventData)\n        {\n            OnClickCallback?.Invoke(this);\n        }\n\n        public virtual void InitData(GordianWarCardVo vo)\n        {\n            m_Vo = vo;\n            if (m_Vo == null || m_Vo.BaseData == null)\n            {\n                return;\n            }\n\n            m_CardPos = m_Vo.CardPos;\n\n            m_BgLightImage.SetActive(false);\n            m_BgLightImage.color = GordianColor.LightBlue;\n\n            m_CannotUpgradeTransform.SetActive(false);\n            m_Mask.enabled = false;\n\n            // 默认隐藏Tips\n            m_TipTransform.SetActive(false);\n\n            // 更新卡牌解锁\n            GordianArchiveManager.Instance.UpdateGordianCard(m_Vo.BaseId);\n\n            UpdateInfo();\n        }\n\n        private void UpdateTips()\n        {\n            // 添加卡效果描述\n            var tips = new List<int>();\n            GetTipShowOrder(tips, m_Vo.BaseData);\n            tips = tips.Distinct().ToList();\n\n            m_TipTransform.RemoveAllChildren();\n\n            for (int j = 0; j < tips.Count; j++)\n            {\n                var tipBaseData = ConfigSystem.Instance.GetTipData(tips[j]);\n                if (tipBaseData != null)\n                {\n                    var path = AssetUtility.GetUIPrefab(\"GordianCardSmallTipItem\");\n                    GordianFactory.SpawnAsync(path, (go) =>\n                    {\n                        if (m_Vo == null)\n                        {\n                            go.Restore();\n                            return;\n                        }\n                        go.SetParent(m_TipTransform);\n\n                        var desc = tipBaseData.Desc;\n\n                        var owner = GordianEntityManager.Instance.GetEntity(m_Vo.EntityId);\n                        if (owner != null)\n                        {\n                            desc = BattleUtil.ReplaceFinalSum(desc, owner.EntityId);\n                        }\n\n                        var descText = go.GetComponentInChildren<Text>();\n                        descText.text = desc;\n\n                        GordianCommFunc.Instance.ForceRebuildLayoutImmediate(m_TipTransform);\n                    }, this);\n                }\n            }\n        }\n\n        public void ShowPos(int pos)\n        {\n            m_TypeText.text = pos.ToString();\n        }\n\n        public void SetCanNotUpgradeActive(bool value)\n        {\n            m_CannotUpgradeTransform.SetActive(value);\n        }\n\n        public virtual void SetLightActive(bool value)\n        {\n            m_BgLightImage.SetActive(value);\n        }\n\n        public virtual void SetLightColor(Color color)\n        {\n            m_BgLightImage.color = color;\n        }\n\n        private void SetQualityImage(MultiImage image, int level = 0)\n        {\n            if (image.image.Length > level)\n            {\n                image.SetImageIndex(level);\n            }\n            image.gameObject.SetActive(true);\n        }\n\n        public void OnPointerDown()\n        {\n            if (m_CardPos != (int)WarCardPos.Hand)\n            {\n                return;\n            }\n\n            transform.localRotation = Quaternion.identity;\n            transform.SetAsLastSibling();\n\n            // 播放缓动\n            transform.DOKill();\n            transform.DOLocalMoveY(transform.localPosition.y + m_TouchMoveY, m_TouchTime);\n            transform.DOScale(m_TouchScale, m_TouchTime);\n\n            ShowTips(true);\n        }\n\n        private void ShowTips(bool value)\n        {\n            UpdateTips();\n\n            m_TipTransform.SetActive(value);\n        }\n\n        private void GetTipShowOrder(List<int> tips, CardBaseData baseData)\n        {\n            var buffs = new List<int>(baseData.Buffs);\n            buffs.Sort((a, b) =>\n            {\n                var baseDataA = ConfigSystem.Instance.GetBuffData(a);\n                var baseDataB = ConfigSystem.Instance.GetBuffData(b);\n\n                return -baseDataA.ShowOrder.CompareTo(baseDataB.ShowOrder);\n            });\n\n            for (int j = 0; j < buffs.Count; j++)\n            {\n                var buff = buffs[j];\n                var buffBaseData = ConfigSystem.Instance.GetBuffData(buff);\n                if (buffBaseData != null)\n                {\n                    tips.AddRange(buffBaseData.Tips);\n                }\n            }\n        }\n\n        public void OnPointerUp()\n        {\n            if (m_CardPos != (int)WarCardPos.Hand)\n            {\n                return;\n            }\n\n            ShowTips(false);\n\n            ShowDragEffect(false);\n        }\n\n        public void RetrunToHand()\n        {\n            transform.DOKill();\n\n            transform.Reset(m_OriginInfo);\n        }\n\n        public void DragPosition(Vector3 endPosition)\n        {\n            if (m_CardPos != (int)WarCardPos.Hand)\n            {\n                return;\n            }\n\n            transform.DOKill();\n\n            transform.localScale = Vector3.one * m_TouchScale;\n\n            transform.position = endPosition;\n        }\n\n        // 拖动卡牌\n        public void OnDrag()\n        {\n            if (m_CardPos != (int)WarCardPos.Hand)\n            {\n                return;\n            }\n\n            ShowDragEffect(true);\n\n            ShowTips(false);\n        }\n\n        public void ShowRemoveEffect(bool move = false)\n        {\n            //移除卡动画\n            if (gameObject.activeSelf == false || m_Removing)\n            {\n                return;\n            }\n\n            transform.DOComplete();\n            m_Removing = true;\n\n            string path = AssetUtility.GetCommonPrefab(\"FX_UI_fire_card\");\n\n            Sequence sequence = DOTween.Sequence();\n            sequence.AppendCallback(() =>\n            {\n                //tipRoot.gameObject.SetActive(false);\n            });\n            if (move)\n            {\n                var end = transform.localPosition + new Vector3(0, 500, 0);\n                sequence.Append(transform.DOLocalMove(end, 0.3f).SetEase(Ease.OutCubic));\n                sequence.Insert(0, transform.DOLocalRotate(Vector3.zero, 0.2f).SetEase(Ease.OutCubic));\n            }\n\n            sequence.AppendCallback(() =>\n            {\n                GordianFactory.SpawnAsync(path, (go) =>\n                {\n                    go.SetParent(m_EffectTransform);\n                });\n            });\n            sequence.AppendInterval(0.3f);\n            sequence.AppendCallback(() =>\n            {\n                m_EffectTransform.RemoveAllChildren();\n\n                gameObject.SetActive(false);\n                m_Removing = false;\n            });\n        }\n\n        protected void UpdateInfo()\n        {\n            var baseData = m_Vo.BaseData;\n\n            if (baseData.Icon != \"\")\n            {\n                var path = AssetUtility.GetCardIcon(baseData.Icon);\n                m_IconImage.LoadSprite(path);\n            }\n\n            // 卡牌类型\n            var common = ConfigSystem.Instance.GetCommon();\n            var cardNameStr = LanguageEnum.CardTypeName.GetLanguage();\n            m_TypeText.text = cardNameStr.Split(',').ToList().GetValue(baseData.Type);\n\n            // 卡牌底颜色\n            ColorUtility.TryParseHtmlString(\"#\" + common.CardTypeColor.GetValue(baseData.Type), out var bgColor);\n            m_BgImage.color = bgColor;\n\n            // 隐藏消耗\n            var isEquipment = baseData.Type == (int)CardType.Equipment;\n            m_CostTransform.SetActive(!isEquipment);\n\n            // 更新消耗\n            m_NumText.text = baseData.Cost.ToString();\n\n            // 品质颜色\n            SetQualityImage(m_QualityMultiImage, m_Vo.BaseData.Rarity);\n\n            // 星星显示\n            m_StarTransform.SetActive(baseData.Star != -1);\n            m_StarImage.SetActive(baseData.Star > 0);\n\n            // 星星颜色\n            var starColor = ConfigSystem.Instance.GetCommon().StarColor;\n            var starColorIndex = baseData.Star - 1;\n\n⚠️ [... middle content omitted — showing head and tail ...]\n\n                                else if (combine[0] == 2)\n                                {\n                                    // 直接拼接\n                                }\n                            }\n                            else\n                            {\n                                sb.Append(\"\\n\");\n                            }\n                        }\n                        else\n                        {\n                            sb.Append(\"\\n\");\n                        }\n                    }\n                }\n            }\n            m_DescText.text = sb.ToString();\n        }\n\n        private void UpdateName()\n        {\n            m_NameText.text = m_Vo.BaseData.Name;\n\n            if (m_IsTemp)\n            {\n                m_NameText.text += \"*\";\n            }\n        }\n\n        public override void Remove()\n        {\n            base.Remove();\n\n            var listener = transform.GetComponent<GordianUIEventListener>();\n            if (listener != null)\n            {\n                listener.enabled = false;\n            }\n\n            m_TipTransform.RemoveAllChildren();\n            m_EffectTransform.RemoveAllChildren();\n\n            OnClickCallback = null;\n\n            m_Vo?.Release();\n            m_Vo = null;\n\n            m_IsTemp = false;\n            m_HasFinal = false;\n\n            m_DragEffectLoaded = false;\n            m_DragEffectVisible = false;\n\n            m_DragEffect = null;\n\n            TargetId = 0;\n        }\n\n        public void SetUsable(bool usable)\n        {\n            m_BgLightImage.SetActive(usable);\n        }\n\n        private void ShowDragEffect(bool value)\n        {\n            m_DragEffectVisible = value;\n\n            if (m_DragEffect != null)\n            {\n                m_DragEffect.SetActive(m_DragEffectVisible);\n            }\n            else\n            {\n                if (!m_DragEffectLoaded)\n                {\n                    m_DragEffectLoaded = true;\n\n                    string path = AssetUtility.GetCommonPrefab(\"ef_plane_01_Slave\");\n                    GordianFactory.SpawnAsync(path, (go) =>\n                    {\n                        go.SetParent(m_EffectTransform);\n                        go.transform.localScale = Vector3.one / 0.7f;\n\n                        GordianCommFunc.ResetSortingOrder(go);\n\n                        m_DragEffect = go;\n\n                        m_DragEffect.SetActive(m_DragEffectVisible);\n                    });\n                }\n            }\n        }\n\n        public void UpdateCost()\n        {\n            var cardEntity = GordianEntityManager.Instance.GetEntity(m_Vo.EntityId) as CardEntity;\n            if (cardEntity == null)\n            {\n                return;\n            }\n\n            // 不需要显示消耗\n            m_CostTransform.SetActive(m_Vo.BaseData.HideCost != 1);\n\n            // 改变值\n            var color = Color.white;\n            var addCost = cardEntity.GetAttrChange(CharAttr.ApCost) + cardEntity.GetAttrChange(CharAttr.ApCostAdd);\n            if (addCost > 0)\n            {\n                color = GordianColor.CardCostRed;\n            }\n            else if (addCost < 0)\n            {\n                // 如果本来就是0还是显示成白色\n                if (m_Vo.BaseData.Cost != 0)\n                {\n                    color = GordianColor.CardCostGreen;\n                }\n            }\n            m_NumText.color = color;\n\n            // 当前值\n            m_Vo.Cost = cardEntity.GetApCost();\n            m_NumText.text = m_Vo.Cost.ToString();\n        }\n\n        public bool IsTemp\n        {\n            get\n            {\n                return m_IsTemp;\n            }\n            set\n            {\n                m_IsTemp = value;\n                UpdateName();\n            }\n        }\n\n        public GordianWarCardVo Vo => m_Vo;\n        public TransformInfo OriginInfo => m_OriginInfo;\n        public bool HasFinal => m_HasFinal;\n        public RectTransform EffectTransform => m_EffectTransform;\n\n        // 手牌目标\n        public int TargetId { get; set; }\n    }\n}\n[... 3368 more characters truncated]"}],"isError":false,"timestamp":1779098482956}}

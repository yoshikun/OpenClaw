{"type":"message","id":"da8c27be","parentId":"d3e7d42c","timestamp":"2026-05-18T09:59:18.803Z","message":{"role":"toolResult","toolCallId":"toolu_vrtx_01X5WfeZufCV9K22vSb6v62D","toolName":"read","content":[{"type":"text","text":"﻿using System.Collections.Generic;\nusing System.Security.Cryptography;\nusing GameFramework.Event;\n\nnamespace Gordian\n{\n    public class GordianEquipmentWearPanel : BaseController\n    {\n        private GordianEquipmentWearModel m_Model;\n        private GordianEquipmentWearView m_View;\n\n        protected override void OnInit(object userData)\n        {\n            base.OnInit(userData);\n\n            m_Model = InitModel<GordianEquipmentWearModel>();\n            m_View = m_IsPC ? InitView<GordianEquipmentWearPCView>() : InitView<GordianEquipmentWearView>();\n        }\n\n        protected override void InitEvent()\n        {\n            EventSystem.Instance.Subscribe<UIEquipCardClickEvent>(OnUIEquipCardClickEvent, this);\n        }\n\n        private void OnUIEquipCardClickEvent(object sender, GameEventArgs e)\n        {\n            var data = e as UIEquipCardClickEvent;\n            var heroId = data.HeroId;\n            var equipId = data.EquipId;\n\n            var oldVo = RoleVo.Instance.GetEquip(equipId);\n\n            // 佩戴装备\n            if (m_Model.ShowType == (int)EquipWearShowType.Wear)\n            {\n                // 卸下当前装备\n                var equipList = RoleVo.Instance.GetEquipList(heroId);\n                var oldPos = equipList.Count;\n\n                if (oldVo != null)\n                {\n                    oldPos = oldVo.Pos;\n                    RoleVo.Instance.UnEquip(equipId);\n                }\n\n                // 佩戴新装备\n                RoleVo.Instance.Equip(m_Model.EquipId, heroId, oldPos);\n            }\n            else if (m_Model.ShowType == (int)EquipWearShowType.Buy)\n            {\n                var newCardVo = m_Model.CardVo;\n                var price = newCardVo.Price;\n\n                if (RoleVo.Instance.Gold >= price)\n                {\n                    RoleVo.Instance.ChangeGold(-price);\n\n                    GordianCommFunc.Instance.ShowMessage(\"购买成功\");\n\n                    // 移除当前装备\n                    RoleVo.Instance.UnEquip(equipId);\n\n                    var newEquipBaseId = newCardVo.BaseId;\n                    // 佩戴新装备\n                    RoleVo.Instance.AddEquip(newEquipBaseId, heroId);\n\n                    EventSystem.Instance.Fire(this, BuyEquipCardSuccessEvent.Create(newCardVo));\n                }\n                else\n                {\n                    GordianCommFunc.Instance.ShowMessage(\"金币不足\");\n                }\n            }\n\n            Close();\n        }\n\n        protected override void OnOpen(object userData)\n        {\n            base.OnOpen(userData);\n        }\n\n        public override void OnClose(bool isShutdown, object userData)\n        {\n            base.OnClose(isShutdown, userData);\n            EventSystem.Instance.Fire(this, OpenEquipWearPanelEvent.Create(0, true));\n        }\n\n        public void InitData(int equipBaseId, int equipId = 0, int showType = (int)EquipWearShowType.Wear, GordianCardVo cardVo = null)\n        {\n            m_Model.EquipBaseId = equipBaseId;\n            m_Model.EquipId = equipId;\n            m_Model.ShowType = showType;\n            m_Model.CardVo = cardVo;\n\n            var baseData = ConfigSystem.Instance.GetCardData(equipBaseId);\n            GordianFactory.CreateCard(baseData, (card) =>\n            {\n                m_View.AddEquipmentCard(card);\n                m_Model.AddEquipmentCard(card);\n            });\n\n            // 显示英雄装备列表\n            var heroIndex = 0;\n            var heroList = RoleVo.Instance.HeroList;\n            var count = heroList.Count;\n            for (int i = 0; i < count; i++)\n            {\n                var path = AssetUtility.GetUIPrefab(\"GordianEquipItem\");\n                GordianFactory.SpawnAsync(path, (go) =>\n                {\n                    var heroVo = heroList[heroIndex++];\n                    var equipList = RoleVo.Instance.GetEquipList(heroVo.BaseId);\n\n                    var vo = new GordianEquipItemVo(heroVo, equipList, heroIndex);\n\n                    var item = go.GetComponent<GordianEquipItem>();\n                    item.InitData(vo);\n                    item.transform.SetSiblingIndex(vo.Index);\n\n                    AddItem(item);\n                });\n            }\n        }\n\n        private void AddItem(GordianEquipItem item)\n        {\n            m_View.AddItem(item);\n            m_Model.AddItem(item);\n        }\n\n        public GordianEquipmentWearModel Model => m_Model;\n    }\n}\n"}],"isError":false,"timestamp":1779098358803}}

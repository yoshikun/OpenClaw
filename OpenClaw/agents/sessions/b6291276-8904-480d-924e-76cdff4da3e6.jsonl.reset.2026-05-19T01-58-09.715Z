{"type":"message","id":"4116cab7","parentId":"b20afb2e","timestamp":"2026-05-18T10:00:15.519Z","message":{"role":"toolResult","toolCallId":"toolu_vrtx_014zSE8g5doJYp4zwAxi6Dyr","toolName":"read","content":[{"type":"text","text":"﻿using Dida.GameLogic.Common;\nusing GameFramework.Event;\n\nnamespace Gordian\n{\n    public class GordianHeroPanel : BaseController\n    {\n        private GordianHeroModel m_Model;\n        private GordianHeroView m_View;\n\n        protected override void OnInit(object userData)\n        {\n            base.OnInit(userData);\n\n            m_Model = InitModel<GordianHeroModel>();\n            m_View = m_IsPC ? InitView<GordianHeroPCView>() : InitView<GordianHeroView>();\n\n            m_Model.HeroVoList = RoleVo.Instance.HeroList;\n        }\n\n        protected override void InitEvent()\n        {\n            EventSystem.Instance.Subscribe<UIEquipCardClickEvent>(OnUIEquipClickEvent, this);\n            EventSystem.Instance.Subscribe<UICardDetailEquipEvent>(OnUICardDetailEquipEvent, this);\n            EventSystem.Instance.Subscribe<UIRemoveEquipEvent>(OnUIRemoveEquipEvent, this);\n\n            EventSystem.Instance.Subscribe<UIHeroHeadItemEvent>(OnHeroHeadItemEvent, this);\n\n            EventSystem.Instance.Subscribe<HeroAddCardEvent>(OnAddHeroCardEvent, this);\n        }\n\n        public void InitData(bool showEquip)\n        {\n            m_Model.ShowEquip = showEquip;\n\n            m_View.InitData(m_Model.HeroVoList);\n        }\n\n        private void OnUIRemoveEquipEvent(object sender, GameEventArgs e)\n        {\n            var data = e as UIRemoveEquipEvent;\n            // 卸下当前装备\n            RoleVo.Instance.UnEquip(data.EquipId, true);\n\n            SetCurrentHero(m_Model.CurrentHeroVo);\n\n            GordianUIManager.Instance.CloseForm(UIFormId.GordianEquipmentBagPanel);\n        }\n\n        private void OnUIEquipClickEvent(object sender, GameEventArgs e)\n        {\n            var data = e as UIEquipCardClickEvent;\n\n            m_Model.CurrentEquipId = data.EquipId;\n\n            var callback = (OpenFormCallback)((logic) =>\n            {\n                var panel = logic as GordianEquipmentBagPanel;\n                panel.InitData((int)EquipBagShowType.Normal, m_Model.CurrentEquipId);\n            });\n            GordianUIManager.Instance.OpenForm(UIFormId.GordianEquipmentBagPanel, callback);\n        }\n\n        private void OnUICardDetailEquipEvent(object sender, GameEventArgs e)\n        {\n            var data = e as UICardDetailEquipEvent;\n\n            var heroVo = m_Model.CurrentHeroVo;\n            var newEquipVo = data.EquipVo;\n\n            var pos = RoleVo.Instance.GetEquipList(heroVo.BaseId).Count;\n            // 移除当前装备\n            var currentEquipVo = RoleVo.Instance.GetEquip(m_Model.CurrentEquipId);\n            if (currentEquipVo != null)\n            {\n                pos = currentEquipVo.Pos;\n\n                RoleVo.Instance.UnEquip(currentEquipVo.Id);\n            }\n\n            // 佩戴新装备\n            if (newEquipVo != null)\n            {\n                // 替换\n                if (newEquipVo.HeroBaseId != 0)\n                {\n                    if (currentEquipVo != null)\n                    {\n                        currentEquipVo.HeroBaseId = newEquipVo.HeroBaseId;\n                        currentEquipVo.Pos = newEquipVo.Pos;\n                    }\n                }\n\n                RoleVo.Instance.Equip(newEquipVo.Id, heroVo.BaseId, pos);\n            }\n\n            SetCurrentHero(heroVo);\n\n            GordianUIManager.Instance.CloseForm(UIFormId.GordianEquipmentBagPanel);\n        }\n\n        private void OnAddHeroCardEvent(object sender, GameEventArgs e)\n        {\n            var data = e as HeroAddCardEvent;\n            var heroVo = m_Model.GetHero(data.HeroBaseId);\n            if (heroVo != null)\n            {\n                SetCurrentHero(heroVo);\n            }\n        }\n\n        private void OnHeroHeadItemEvent(object sender, GameEventArgs e)\n        {\n            var data = e as UIHeroHeadItemEvent;\n            SetCurrentHero(data.HeroVo);\n        }\n\n        protected override void OnOpen(object userData)\n        {\n            base.OnOpen(userData);\n        }\n\n        public void SetCurrentHeroIndex(int index)\n        {\n            if (m_Model.HeroVoList.Count > index)\n            {\n                SetCurrentHero(m_Model.HeroVoList[index]);\n            }\n        }\n\n        public void SetCurrentHero(HeroVo vo)\n        {\n            m_Model.SetCurrentHero(vo);\n\n            m_View.SetCurrentHero(vo, m_Model.ShowEquip);\n\n            // 普通难度显示好感度\n            var chooseLevel = GordianUserInfo.Instance.GetGordianChooseTowerLevel();\n            m_View.ShowLove(chooseLevel <= 1);\n\n            // 播放音效\n            var voice = vo.BaseData.Voice.GetValue(vo.GetLoveType() - 1);\n            if (!string.IsNullOrEmpty(voice))\n            {\n                AudioCtrl.PlaySound(voice);\n            }\n\n            // 播放音效\n            var voice3 = vo.BaseData.Voice3;\n            if (!string.IsNullOrEmpty(voice3))\n            {\n                AudioCtrl.PlaySound(voice3);\n            }\n        }\n    }\n}\n"}],"isError":false,"timestamp":1779098415518}}

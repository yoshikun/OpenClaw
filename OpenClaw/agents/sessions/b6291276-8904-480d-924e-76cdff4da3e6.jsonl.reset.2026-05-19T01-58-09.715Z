{"type":"message","id":"8c8bd9b5","parentId":"d4683eac","timestamp":"2026-05-18T10:45:06.910Z","message":{"role":"toolResult","toolCallId":"toolu_vrtx_01Dw6gJtAJtb3XUTre1PE9j8","toolName":"read","content":[{"type":"text","text":"    headless: false,\n    args: [\n      '--no-sandbox',\n      '--disable-blink-features=AutomationControlled',\n      '--user-agent=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',\n    ],\n  });\n\n  const context = await browser.newContext({\n    userAgent: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',\n  });\n\n  await context.addInitScript(STEALTH_SCRIPT);\n  await context.addCookies(cookies);\n\n  const page = await context.newPage();\n\n  try {\n    console.log('Opening bug create page...');\n    await page.goto(BUG_CREATE_URL, { waitUntil: 'networkidle', timeout: 30000 });\n\n    // 检查是否被重定向到登录页\n    if (page.url().includes('login')) {\n      throw new Error('TAPD session expired, please re-login');\n    }\n\n    // 填写标题\n    await page.fill('#BugTitle', title);\n    console.log(`Title: ${title}`);\n\n    // 优先级\n    await page.selectOption('#BugPriority', priority);\n    console.log(`Priority: ${priority}`);\n\n    // 发现版本\n    try {\n      // 先尝试 select\n      await page.selectOption('#BugVersionReport', { label: version }, { timeout: 2000 });\n    } catch {\n      await page.fill('#BugVersionReport', version);\n    }\n    console.log(`Version: ${version}`);\n\n    // 模块\n    try {\n      await page.selectOption('#BugModule', { label: mod }, { timeout: 2000 });\n    } catch {\n      await page.fill('#BugModule', mod);\n    }\n    console.log(`Module: ${mod}`);\n\n    // 研发分支（自定义字段，select 类型）\n    try {\n      await page.selectOption('#BugCustomFieldOne', { label: branch }, { timeout: 3000 });\n      console.log(`Branch: ${branch}`);\n    } catch (e) {\n      try {\n        await page.fill('#BugCustomFieldOne', branch);\n        console.log(`Branch (fill): ${branch}`);\n      } catch (e2) {\n        console.warn('Branch field not found, skipping:', e2.message);\n      }\n    }\n\n    // 处理人（自动补全）\n    // 始终在处理人中追加兵王(周以天)，确保 bug 单能流转到 QA\n    const handlers = [handler, '周以天'].filter((v, i, arr) => arr.indexOf(v) === i); // 去重\n    for (const h of handlers) {\n      await page.fill('#BugCurrentOwnerValue', h);\n      await page.waitForTimeout(1500);\n      await page.keyboard.press('Enter');\n      await page.waitForTimeout(500);\n      console.log(`Handler added: ${h}`);\n    }\n    console.log(`Handlers: ${handlers.join(', ')}`);\n\n    // 抄送（直接填写 hidden 字段）\n    try {\n      // 先尝试点击 CC 输入区\n      const ccInput = page.locator('#BugCcValue').first();\n      if (await ccInput.count() > 0) {\n        await ccInput.fill(cc.replace(/;$/, ''));\n        await page.waitForTimeout(1500);\n        await page.keyboard.press('Enter');\n        await page.waitForTimeout(500);\n      }\n    } catch (e) {\n      console.warn('CC field autocomplete failed, trying hidden field:', e.message);\n      try {\n        await page.evaluate((ccVal) => {\n          const el = document.querySelector('#BugCc');\n          if (el) el.value = ccVal;\n        }, cc);\n      } catch (e2) {\n        console.warn('CC hidden field also failed:', e2.message);\n      }\n    }\n    console.log(`CC: ${cc}`);\n\n    // 描述\n    if (description) {\n      try {\n        // 尝试富文本编辑器\n        const descFrame = page.frameLocator('iframe[id*=\"BugDescription\"], iframe[title*=\"description\"]').first();\n        await descFrame.locator('body').fill(description);\n      } catch {\n        try {\n          await page.fill('#BugDescription', description);\n        } catch (e) {\n          console.warn('Description field not found:', e.message);\n        }\n      }\n    }\n\n    // 附件上传\n    if (attachments.length > 0) {\n      for (const filePath of attachments) {\n        if (fs.existsSync(filePath)) {\n          console.log(`Uploading: ${filePath}`);\n          await page.locator('#file_input').first().setInputFiles(filePath);\n          await page.waitForTimeout(3000);\n        } else {\n          console.warn(`Attachment not found: ${filePath}`);\n        }\n      }\n    }\n\n    // 提交\n    console.log('Submitting...');\n    // 先截图看一下当前状态\n    await page.screenshot({ path: path.join(WS_DIR, 'memory/tapd_before_submit.png') });\n    // 点击「创建」按钮（可见的 <a> 链接）\n    const submitBtn = page.locator('a#_view, a[onclick*=\"save_return\"], a:has-text(\"创建\")').first();\n    await submitBtn.click();\n    // 等待导航或成功提示\n    try {\n      await page.waitForNavigation({ waitUntil: 'networkidle', timeout: 20000 });\n    } catch {\n      // 可能是 AJAX 提交，不跳转，等待 URL 变化\n      await page.waitForTimeout(3000);\n\n[26 more lines in file. Use offset=201 to continue.]"}],"isError":false,"timestamp":1779101106910}}

- 时间戳未更新 → **视为失败**（流水线未执行），发失败通知\n- 时间戳已更新 + 无关键字匹配 + Unity 退出码 0 → **视为成功**，发成功通知（hotupdate-ok）`;\n\nif (content.includes(oldSection)) {\n  content = content.replace(oldSection, newSection);\n  fs.writeFileSync('C:\\\\Users\\\\yyzypublic\\\\.openclaw\\\\workspace\\\\TOOLS.md', content, 'utf8');\n  console.log('✅ TOOLS.md updated');\n} else {\n  console.log('❌ Could not find the old section to replace');\n}\n\"","timeout":5}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":1532,"output":842,"cacheRead":43392,"cacheWrite":0,"totalTokens":45766,"cost":{"input":0.00021448000000000002,"output":0.00023576,"cacheRead":0.001214976,"cacheWrite":0,"total":0.001665216}},"stopReason":"toolUse","timestamp":1780975248805,"responseId":"5f00c215-b943-4d4e-bf67-c0319ef27984"}}

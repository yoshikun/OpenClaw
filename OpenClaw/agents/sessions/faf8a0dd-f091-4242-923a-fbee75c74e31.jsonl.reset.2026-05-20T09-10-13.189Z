{"type":"message","id":"c4787f7e","parentId":"cfab7b74","timestamp":"2026-05-20T04:04:32.694Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"OK, `better-sqlite3` is installed. Now let me write a script that reads the Chrome cookie database directly, and tries to decrypt the cookies.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_00_IMsdgLf8wUbu0m5NSrhI0527","name":"write","arguments":{"content":"/**\n * 直接读取 Chrome 的 Cookie SQLite 数据库，解析加密的 cookie 值\n * Chrome 使用 AES-256-GCM 加密，密钥存储在 Local State\n */\nimport Database from 'better-sqlite3';\nimport fs from 'fs';\nimport path from 'path';\nimport crypto from 'crypto';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\nconst WS_DIR = path.resolve(__dirname, '..');\nconst COOKIES_FILE = path.join(WS_DIR, 'tapd_cookies.json');\n\nconst COOKIES_DB = 'C:\\\\Users\\\\yyzypublic\\\\AppData\\\\Local\\\\Google\\\\Chrome\\\\User Data\\\\Default\\\\Network\\\\Cookies';\nconst LOCAL_STATE = 'C:\\\\Users\\\\yyzypublic\\\\AppData\\\\Local\\\\Google\\\\Chrome\\\\User Data\\\\Local State';\n\nfunction getEncryptionKey() {\n  const state = JSON.parse(fs.readFileSync(LOCAL_STATE, 'utf8'));\n  const encryptedKey = Buffer.from(state.os_crypt.encrypted_key, 'base64');\n  \n  // Chrome 格式: 'DPAPI' prefix (5 bytes) + encrypted data\n  const prefix = encryptedKey.slice(0, 5).toString();\n  if (prefix !== 'DPAPI') {\n    throw new Error(`Unexpected key prefix: ${prefix}`);\n  }\n  \n  const encryptedData = encryptedKey.slice(5);\n  \n  // 使用 Windows DPAPI 解密\n  // 用 child_process 调用 PowerShell 来解密\n  return { encryptedData };\n}\n\nfunction decryptWithDPAPI(data) {\n  // 使用 PowerShell 调用 Windows DPAPI 来解密\n  const { execSync } = require('child_process');\n  \n  // 将数据转为 base64\n  const base64Data = data.toString('base64');\n  \n  // PowerShell 脚本：调用 System.Security.Cryptography.ProtectedData.Unprotect\n  const psScript = `\n    Add-Type -AssemblyName System.Security;\n    $data = [Convert]::FromBase64String('${base64Data}');\n    $key = [System.Security.Cryptography.ProtectedData]::Unprotect($data, $null, [System.Security.Cryptography.DataProtectionScope]::CurrentUser);\n    [Convert]::ToBase64String($key);\n  `;\n  \n  const result = execSync(`powershell -NoProfile -Command \"${psScript.Replace('\"', '\\\\\"')}\"`, {\n    encoding: 'utf8',\n    timeout: 10000,\n  });\n  \n  return Buffer.from(result.trim(), 'base64');\n}\n\nfunction decryptCookieValue(encryptedValue, key) {\n  // Chrome >= v80 uses AES-256-GCM\n  // Format: 'v10' + nonce (12 bytes) + ciphertext + tag (16 bytes)\n  // Or: 'v11' + nonce (12 bytes) + ciphertext + tag (16 bytes)\n  \n  if (!encryptedValue || encryptedValue.length === 0) return null;\n  \n  const data = Buffer.from(encryptedValue, 'base64');\n  \n  // Check prefix\n  const version = data.slice(0, 3).toString();\n  if (version !== 'v10' && version !== 'v11') {\n    console.warn(`  Unknown cookie version: ${version}`);\n    return null;\n  }\n  \n  const nonce = data.slice(3, 15); // 12 bytes\n  const ciphertext = data.slice(15, -16);\n  const tag = data.slice(-16);\n  \n  try {\n    const decipher = crypto.createDecipheriv('aes-256-gcm', key, nonce);\n    decipher.setAuthTag(tag);\n    const decrypted = Buffer.concat([decipher.update(ciphertext), decipher.final()]);\n    return decrypted.toString('utf8');\n  } catch (e) {\n    console.warn(`  Decryption failed: ${e.message}`);\n    return null;\n  }\n}\n\nasync function main() {\n  console.log('Reading Chrome cookie database...');\n  console.log('Database:', COOKIES_DB);\n  \n  // 读取加密密钥\n  const state = JSON.parse(fs.readFileSync(LOCAL_STATE, 'utf8'));\n  const encryptedKeyB64 = state.os_crypt.encrypted_key;\n  console.log('Encrypted key (base64):', encryptedKeyB64.substring(0, 30) + '...');\n  \n  // 用 PowerShell DPAPI 解密\n  console.log('Decrypting key via DPAPI...');\n  const prefix = Buffer.from(encryptedKeyB64, 'base64').slice(0, 5).toString();\n  const encryptedKeyData = Buffer.from(encryptedKeyB64, 'base64').slice(5);\n  \n  const { execSync } = require('child_process');\n  const psScript = `\nAdd-Type -AssemblyName System.Security;\ntry {\n  $data = [Convert]::FromBase64String('${encryptedKeyData.toString('base64')}');\n  $key = [System.Security.Cryptography.ProtectedData]::Unprotect($data, $null, [System.Security.Cryptography.DataProtectionScope]::CurrentUser);\n  [Convert]::ToBase64String($key);\n} catch {\n  Write-Error $_.Exception.Message;\n  exit 1;\n}\n`;\n  const psResult = execSync(`powershell -NoProfile -Command \"${psScript.replace(/\"/g, '\\\\\"')}\"`, {\n    encoding: 'utf8',\n    timeout: 10000,\n  });\n  \n  const aesKey = Buffer.from(psResult.trim(), 'base64');\n  console.log('AES Key (hex):', aesKey.toString('hex').substring(0, 20) + '...');\n  \n  // 读取 Cookie 数据库\n  const db = new Database(COOKIES_DB, { readonly: true });\n  \n  // 查询 tapd 相关 cookies\n  const rows = db.prepare(`\n    SELECT host_key, name, value, encrypted_value, path, expires_utc, is_secure, is_httponly\n    FROM cookies\n    WHERE host_key LIKE '%tapd%'\n    ORDER BY host_key, name\n  `).all();\n  \n  console.log(`\\nFound ${rows.length} TAPD cookie entries`);\n  \n  const decryptedCookies = [];\n  for (const row of rows) {\n    console.log(`\\n  ${row.name} (${row.host_key}):`);\n    console.log(`    plain value: \"${row.value.substring(0, 40)}\"`);\n    \n    // 尝试解密 encrypted_value\n    let decryptedValue = null;\n    if (row.encrypted_value && row.encrypted_value.length > 0) {\n      decryptedValue = decryptCookieValue(row.encrypted_value.toString('base64'), aesKey);\n    }\n    console.log(`    decrypted: \"${decryptedValue?.substring(0, 40) || 'FAILED'}\"`);\n    \n    // 使用解密后的值（如果解密失败则用明文字段）\n    const finalValue = decryptedValue || row.value;\n    \n    decryptedCookies.push({\n      name: row.name,\n      value: finalValue,\n      domain: row.host_key,\n      path: row.path,\n      expires: row.expires_utc ? new Date(row.expires_utc / 1000000 - 11644473600).getTime() / 1000 : -1,\n      httpOnly: row.is_httponly === 1,\n      secure: row.is_secure === 1,\n      sameSite: 'Lax',\n    });\n  }\n  \n  db.close();\n  \n  if (decryptedCookies.length > 0) {\n    // 保存\n    fs.writeFileSync(COOKIES_FILE, JSON.stringify(decryptedCookies, null, 2), 'utf8');\n    console.log(`\\n✅ Saved ${decryptedCookies.length} cookies to tapd_cookies.json`);\n    \n    // 检查关键 cookie\n    ['tapdsession', 't_u', 't_cloud_login', '_t_crop', '_t_uid'].forEach(name => {\n      const found = decryptedCookies.find(c => c.name === name);\n      console.log(`  ${name}: ${found ? '✅ ' + found.value.substring(0, 30) : '❌ NOT FOUND'}`);\n    });\n  }\n}\n\nmain().catch(err => {\n  console.error('FAILED:', err.message);\n  process.exit(1);\n});\n","path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\read_chrome_cookies.mjs"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":40,"output":1967,"cacheRead":54656,"cacheWrite":0,"totalTokens":56663,"cost":{"input":0.000005600000000000001,"output":0.0005507600000000001,"cacheRead":0.001530368,"cacheWrite":0,"total":0.0020867280000000004}},"stopReason":"toolUse","timestamp":1779249854391,"responseId":"ab3e7593-f03d-4f33-9c60-ca710c32aef3"}}

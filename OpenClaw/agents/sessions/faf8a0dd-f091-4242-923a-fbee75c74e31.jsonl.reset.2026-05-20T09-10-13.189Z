\"path\": \"/\",\n    \"expires\": 1779356895,\n    \"httpOnly\": true,\n    \"secure\": false,\n    \"sameSite\": \"Lax\"\n  },\n  {\n    \"name\": \"locale\",\n    \"value\": \"zh_CN\",\n    \"domain\": \".tapd.cn\",\n    \"path\": \"/\",\n    \"expires\": 1779333968,\n    \"httpOnly\": false,\n    \"secure\": false,\n    \"sameSite\": \"Lax\"\n  },\n  {\n    \"name\": \"sso-login-token\",\n    \"value\": \"1d59ee27b96e759933a12f814f692a83\",\n    \"domain\": \"www.tapd.cn\",\n    \"path\": \"/\",\n    \"expires\": 1779258755,\n    \"httpOnly\": false,\n    \"secure\": false,\n    \"sameSite\": \"Lax\"\n  },\n  {\n    \"name\": \"t_i_token\",\n    \"value\": \"MTQxNTI4NzM2NCwxNzc5Mzg3Nzgz.e8c076ef995266ce6cdc3af1c271ac46d3b4e3eb154d934b008d906fc58c7588\",\n    \"domain\": \".tapd.cn\",\n    \"path\": \"/\",\n    \"expires\": 1779301383,\n    \"httpOnly\": true,\n    \"secure\": false,\n    \"sameSite\": \"Lax\"\n  }\n]\n","path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\tapd_cookies_yezhijun.json"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":3386,"output":1666,"cacheRead":136704,"cacheWrite":0,"totalTokens":141756,"cost":{"input":0.00047404,"output":0.00046648,"cacheRead":0.003827712,"cacheWrite":0,"total":0.004768232}},"stopReason":"toolUse","timestamp":1779258196762,"responseId":"519618b0-a968-42bf-a1ce-30075ee0c65a"}}

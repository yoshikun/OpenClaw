{"type":"message","id":"f922f08a","parentId":"eab0bd12","timestamp":"2026-05-20T03:57:18.456Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"I see the Chrome user data directory. Let me write a Playwright script to launch Chrome with the Default profile and extract TAPD cookies. I'll then save them to the tapd_cookies.json file.\n\nLet me write a script to do this.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_00_Hx87CG1WImE0McPBRwOy4036","name":"write","arguments":{"path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\extract_tapd_cookies.mjs","content":"/**\n * 从 Chrome 现有配置文件中提取 TAPD cookies\n * 使用 Playwright 启动 Chrome，导航到 TAPD，获取 tapd.cn 相关 cookie\n */\nimport { chromium } from 'playwright';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\nconst WS_DIR = path.resolve(__dirname, '..');\n\nconst COOKIES_FILE = path.join(WS_DIR, 'tapd_cookies.json');\nconst USER_DATA_DIR = 'C:\\\\Users\\\\yyzypublic\\\\AppData\\\\Local\\\\Google\\\\Chrome\\\\User Data';\n\nasync function main() {\n  const context = await chromium.launchPersistentContext(USER_DATA_DIR, {\n    headless: false,\n    channel: 'chrome',\n    args: ['--no-sandbox'],\n  });\n\n  const page = await context.newPage();\n  \n  try {\n    console.log('Navigating to TAPD...');\n    await page.goto('https://www.tapd.cn/31253609/bugtrace/bugs/add', {\n      waitUntil: 'networkidle',\n      timeout: 30000,\n    });\n\n    console.log('Current URL:', page.url());\n\n    // 获取所有 cookie\n    const cookies = await context.cookies();\n    console.log(`Total cookies: ${cookies.length}`);\n\n    // 筛选 tapd 相关 cookie\n    const tapdCookies = cookies.filter(c => \n      c.domain.includes('tapd.cn') || c.domain.includes('tapd')\n    );\n    console.log(`TAPD cookies: ${tapdCookies.length}`);\n\n    // 检查关键 cookie\n    const sessionCookie = tapdCookies.find(c => c.name === 'tapdsession');\n    if (sessionCookie) {\n      console.log('tapdsession found:', sessionCookie.value.substring(0, 20) + '...');\n      console.log('Expires:', new Date(sessionCookie.expires * 1000).toLocaleString());\n    } else {\n      console.log('tapdsession NOT found - may need to login');\n      // 等 60 秒让人工扫码或登录\n      console.log('Waiting 60 seconds for login...');\n      await page.waitForTimeout(60000);\n    }\n\n    // 重新获取 cookie（如果上面等了登录）\n    const finalCookies = await context.cookies();\n    const finalTapdCookies = finalCookies.filter(c => \n      c.domain.includes('tapd.cn') || c.domain.includes('tapd')\n    );\n\n    // 保存 cookie\n    fs.writeFileSync(COOKIES_FILE, JSON.stringify(finalTapdCookies, null, 2), 'utf8');\n    console.log(`Saved ${finalTapdCookies.length} cookies to ${COOKIES_FILE}`);\n\n    // 打印 cookie 概览\n    finalTapdCookies.forEach(c => {\n      console.log(`  ${c.name} (${c.domain}): ${c.value.substring(0, 30)}...`);\n    });\n\n    // 确认登录成功\n    if (finalTapdCookies.find(c => c.name === 'tapdsession')) {\n      console.log('\\n✅ TAPD cookies saved successfully!');\n    } else {\n      console.log('\\n⚠️ No tapdsession cookie found - login may still be needed');\n    }\n\n  } finally {\n    await context.close();\n  }\n}\n\nmain().catch(err => {\n  console.error('FAILED:', err.message);\n  process.exit(1);\n});\n"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":334,"output":895,"cacheRead":29312,"cacheWrite":0,"totalTokens":30541,"cost":{"input":0.000046760000000000006,"output":0.0002506,"cacheRead":0.000820736,"cacheWrite":0,"total":0.001118096}},"stopReason":"toolUse","timestamp":1779249429937,"responseId":"4e8ec018-fdd4-4728-aad7-62bf1846c7a1"}}

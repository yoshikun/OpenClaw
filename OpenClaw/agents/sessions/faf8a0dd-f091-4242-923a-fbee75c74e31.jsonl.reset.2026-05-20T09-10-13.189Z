{"type":"message","id":"21a1f7ad","parentId":"8736fe0f","timestamp":"2026-05-20T03:58:23.605Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Let me check if Chrome processes are running and try a different approach. Let me use `chromium.launch` with `--user-data-dir` argument instead of `launchPersistentContext`, which might have issues on this system.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_00_HF9j831Q0B9AraF3HICR1604","name":"write","arguments":{"path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\extract_tapd_cookies2.mjs","content":"/**\n * 从 Chrome 现有配置文件中提取 TAPD cookies（v2 - 使用 launch + user-data-dir）\n */\nimport { chromium } from 'playwright';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\nconst WS_DIR = path.resolve(__dirname, '..');\n\nconst COOKIES_FILE = path.join(WS_DIR, 'tapd_cookies.json');\nconst USER_DATA_DIR = 'C:\\\\Users\\\\yyzypublic\\\\AppData\\\\Local\\\\Google\\\\Chrome\\\\User Data';\n\nasync function main() {\n  const browser = await chromium.launch({\n    headless: false,\n    channel: 'chrome',\n    args: [\n      `--user-data-dir=${USER_DATA_DIR}`,\n      '--no-sandbox',\n      '--disable-blink-features=AutomationControlled',\n    ],\n  });\n\n  const context = browser.contexts()[0] || await browser.newContext();\n  const page = await context.newPage();\n\n  try {\n    console.log('[1/3] Navigating to TAPD...');\n    await page.goto('https://www.tapd.cn/31253609/bugtrace/bugs/add', {\n      waitUntil: 'networkidle',\n      timeout: 30000,\n    });\n    console.log('Current URL:', page.url());\n\n    // 获取所有 cookie\n    const cookies = await context.cookies();\n    const tapdCookies = cookies.filter(c => c.domain.includes('tapd.cn'));\n    console.log(`[2/3] Found ${tapdCookies.length} TAPD cookies`);\n\n    const sessionCookie = tapdCookies.find(c => c.name === 'tapdsession');\n    if (sessionCookie) {\n      console.log('tapdsession:', sessionCookie.value.substring(0, 20) + '...');\n      console.log('Expires:', new Date(sessionCookie.expires * 1000).toLocaleString());\n\n      // 保存 cookie\n      fs.writeFileSync(COOKIES_FILE, JSON.stringify(tapdCookies, null, 2), 'utf8');\n      console.log(`[3/3] ✅ Saved ${tapdCookies.length} cookies to tapd_cookies.json`);\n\n      // 显示所有 cookie 名\n      tapdCookies.forEach(c => console.log(`  ${c.name}: ${c.value.substring(0, 30)}...`));\n    } else {\n      console.log('⚠️ No tapdsession cookie found. Waiting 60s for manual login...');\n      await page.waitForTimeout(60000);\n\n      const finalCookies = await context.cookies();\n      const finalTapd = finalCookies.filter(c => c.domain.includes('tapd.cn'));\n      fs.writeFileSync(COOKIES_FILE, JSON.stringify(finalTapd, null, 2), 'utf8');\n      console.log(`Saved ${finalTapd.length} cookies`);\n\n      if (finalTapd.find(c => c.name === 'tapdsession')) {\n        console.log('✅ Cookies saved after manual login!');\n      } else {\n        console.log('❌ Still no tapdsession');\n      }\n    }\n  } finally {\n    await browser.close();\n  }\n}\n\nmain().catch(err => {\n  console.error('FAILED:', err.message);\n  process.exit(1);\n});\n"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":129,"output":858,"cacheRead":31488,"cacheWrite":0,"totalTokens":32475,"cost":{"input":0.00001806,"output":0.00024024000000000002,"cacheRead":0.000881664,"cacheWrite":0,"total":0.001139964}},"stopReason":"toolUse","timestamp":1779249496237,"responseId":"f88ce1f5-91cb-4b0c-bf89-834ed661e5c8"}}

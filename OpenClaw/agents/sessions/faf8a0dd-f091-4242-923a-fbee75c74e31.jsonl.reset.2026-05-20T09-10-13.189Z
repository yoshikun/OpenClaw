{"type":"message","id":"1f99ae9f","parentId":"7dfd5fa2","timestamp":"2026-05-20T08:55:50.912Z","message":{"role":"toolResult","toolCallId":"call_00_LMqul2KxOSV9hmjT4Yh60145","toolName":"read","content":[{"type":"text","text":"/**\n * TAPD 创建需求（Story）脚本\n * 工作区：31253609（月圆之夜）\n * 账号：叶枝君\n * \n * 策略：不选择模板（模板选择会导致提交失败），先创建基础需求，\n * 创建成功后再从需求详情页补充处理人等信息。\n */\n\nimport { chromium } from 'playwright';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\nconst WS_DIR = path.resolve(__dirname, '..');\nconst COOKIES_FILE = path.join(WS_DIR, 'tapd_cookies_yezhijun.json');\nconst WORKSPACE_ID = '31253609';\nconst STORY_CREATE_URL = `https://www.tapd.cn/${WORKSPACE_ID}/prong/stories/add`;\n\nconst STEALTH_SCRIPT = `\n  Object.defineProperty(navigator, 'webdriver', { get: () => undefined });\n  Object.defineProperty(navigator, 'plugins', { get: () => [1, 2, 3, 4, 5] });\n  Object.defineProperty(navigator, 'languages', { get: () => ['zh-CN', 'zh', 'en'] });\n  Object.defineProperty(navigator, 'hardwareConcurrency', { get: () => 8 });\n  window.chrome = { runtime: {} };\n`;\n\nexport async function createStory(opts = {}) {\n  const {\n    title = '测试需求单 - 请忽略',\n    priority = 'P2',\n    module: mod = '1V1',\n    version = '【1V1】正式版本V2.0',\n    handler = '周以天',\n    description = '',\n  } = opts;\n\n  if (!title) throw new Error('title is required');\n  if (!fs.existsSync(COOKIES_FILE)) throw new Error(`Cookies file not found: ${COOKIES_FILE}`);\n\n  const cookies = JSON.parse(fs.readFileSync(COOKIES_FILE, 'utf8'));\n\n  const browser = await chromium.launch({\n    headless: false,\n    args: [\n      '--no-sandbox',\n      '--disable-blink-features=AutomationControlled',\n      '--user-agent=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',\n    ],\n  });\n\n  const context = await browser.newContext({\n    userAgent: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',\n  });\n\n  await context.addInitScript(STEALTH_SCRIPT);\n  await context.addCookies(cookies);\n\n  const page = await context.newPage();\n\n  try {\n    // Step 1: Create story without template\n    console.log('1/4 Opening story create page...');\n    await page.goto(STORY_CREATE_URL, { waitUntil: 'networkidle', timeout: 30000 });\n    if (page.url().includes('login')) throw new Error('TAPD session expired');\n    await page.waitForTimeout(2000);\n\n    console.log('2/4 Filling fields...');\n    await page.fill('#StoryName', title);\n    await page.selectOption('#StoryPriority', priority);\n    await page.selectOption('#StoryModule', { label: mod });\n    await page.selectOption('#StoryVersion', { label: version });\n\n    if (description) {\n      try {\n        const descFrame = page.frameLocator('iframe#StoryDescription_ifr').first();\n        await descFrame.locator('body').fill(description);\n      } catch (e) {\n        console.warn('Description field not found:', e.message);\n\n[53 more lines in file. Use offset=81 to continue.]"}],"isError":false,"timestamp":1779267350912}}

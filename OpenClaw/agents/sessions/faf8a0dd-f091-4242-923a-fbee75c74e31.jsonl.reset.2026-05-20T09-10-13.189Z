{"type":"message","id":"286b2573","parentId":"6e9ff194","timestamp":"2026-05-20T06:23:53.274Z","message":{"role":"toolResult","toolCallId":"call_00_b7H2goLOMS0VTLL2reQ59762","toolName":"read","content":[{"type":"text","text":"  }\n\n  const oldCookies = JSON.parse(fs.readFileSync(COOKIES_FILE, 'utf8'));\n  log(`Loaded ${oldCookies.length} cookies`);\n\n  const browser = await chromium.launch({\n    headless: true,\n    args: ['--no-sandbox', '--disable-blink-features=AutomationControlled'],\n  });\n  const ctx = await browser.newContext({\n    locale: 'zh-CN',\n    viewport: { width: 1920, height: 1080 },\n    userAgent: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36',\n  });\n  await ctx.addCookies(oldCookies);\n  const page = await ctx.newPage();\n  await page.addInitScript(STEALTH_INIT);\n\n  try {\n    log('Visiting workspace dashboard...');\n    const resp = await page.goto('https://www.tapd.cn/31253609/', {\n      waitUntil: 'domcontentloaded',\n      timeout: 30000,\n    });\n    await page.waitForTimeout(3000);\n\n    const url = page.url();\n    const title = await page.title();\n    const status = resp?.status();\n    log(`HTTP ${status} | url=${url} | title=${title}`);\n\n    if (url.includes('login') || title.includes('登录') || title.includes('WAF')) {\n      log('❌ Session EXPIRED - need re-login');\n      writeState({\n        ok: false,\n        error: 'session_expired',\n        at: new Date().toISOString(),\n        finalUrl: url,\n        title,\n      });\n      await browser.close();\n      process.exit(1);\n    }\n\n    // Bonus: also poke story-list to make sure deep nav still works\n    await page.goto('https://www.tapd.cn/tapd_fe/31253609/story/list', {\n      waitUntil: 'domcontentloaded',\n      timeout: 30000,\n    }).catch(() => {});\n    await page.waitForTimeout(2000);\n\n[35 more lines in file. Use offset=100 to continue.]"}],"isError":false,"timestamp":1779258233274}}
{"type":"message","id":"d2ee8dfb","parentId":"286b2573","timestamp":"2026-05-20T06:24:05.821Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The indentation is 2 spaces (not tabs). Let me just rewrite the whole file since it's getting too hard to match exact whitespace with the edit tool.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_00_8HI87AKQm8cIkpZXzE2y2772","name":"write","arguments":{"content":"// TAPD Keepalive Script (支持双账号)\n// 用法: node scripts/tapd_keepalive.mjs [zhouyitian|yezhijun]\n//   默认 zhouyitian（周以天）\n//   指定 yezhijun 则保活叶枝君的 cookie\n//\n// Exit codes:\n//   0 = success (cookies refreshed)\n//   1 = cookie invalid / login expired (need re-login)\n//   2 = script error (network, etc.)\n\nimport { chromium } from 'playwright';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __filename = fileURLToPath(import.meta.url);\nconst __dirname = path.dirname(__filename);\nconst WORKSPACE_DIR = path.resolve(__dirname, '..');\n\n// 账号参数\nconst ACCOUNT = process.argv[2] || 'zhouyitian';\nconst LABELS = { zhouyitian: '周以天', yezhijun: '叶枝君' };\nconst label = LABELS[ACCOUNT] || ACCOUNT;\n\nconst COOKIES_FILE = ACCOUNT === 'yezhijun'\n  ? path.join(WORKSPACE_DIR, 'tapd_cookies_yezhijun.json')\n  : path.join(WORKSPACE_DIR, 'tapd_cookies_zhouyitian.json');\nconst STORAGE_FILE = path.join(WORKSPACE_DIR, `tapd_storage_${ACCOUNT}.json`);\nconst STATE_FILE = path.join(WORKSPACE_DIR, 'memory', `tapd-keepalive-state-${ACCOUNT}.json`);\n\nconst STEALTH_INIT = () => {\n  delete navigator.webdriver;\n  Object.defineProperty(navigator, 'webdriver', { get: () => false });\n  Object.defineProperty(navigator, 'plugins', { get: () => [1, 2, 3, 4, 5] });\n  Object.defineProperty(navigator, 'languages', { get: () => ['zh-CN', 'zh'] });\n  Object.defineProperty(navigator, 'hardwareConcurrency', { get: () => 8 });\n  window.chrome = { runtime: {}, loadTimes: function () {}, csi: function () {}, app: {} };\n};\n\nfunction log(msg) {\n  console.log(`[${new Date().toISOString()}] ${msg}`);\n}\n\nfunction writeState(state) {\n  try {\n    fs.mkdirSync(path.dirname(STATE_FILE), { recursive: true });\n    fs.writeFileSync(STATE_FILE, JSON.stringify(state, null, 2));\n  } catch (e) {\n    console.error('Failed to write state:', e.message);\n  }\n}\n\nasync function main() {\n  if (!fs.existsSync(COOKIES_FILE)) {\n    log(`[${label}] ERROR: cookies file not found: ${COOKIES_FILE}`);\n    writeState({ ok: false, error: 'cookies_missing', at: new Date().toISOString(), account: ACCOUNT });\n    process.exit(1);\n  }\n\n  const oldCookies = JSON.parse(fs.readFileSync(COOKIES_FILE, 'utf8'));\n  log(`[${label}] Loaded ${oldCookies.length} cookies`);\n\n  const browser = await chromium.launch({\n    headless: true,\n    args: ['--no-sandbox', '--disable-blink-features=AutomationControlled'],\n  });\n  const ctx = await browser.newContext({\n    locale: 'zh-CN',\n    viewport: { width: 1920, height: 1080 },\n    userAgent: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36',\n  });\n  await ctx.addCookies(oldCookies);\n  const page = await ctx.newPage();\n  await page.addInitScript(STEALTH_INIT);\n\n  try {\n    log(`[${label}] Visiting workspace dashboard...`);\n    const resp = await page.goto('https://www.tapd.cn/31253609/', {\n      waitUntil: 'domcontentloaded',\n      timeout: 30000,\n    });\n    await page.waitForTimeout(3000);\n\n    const url = page.url();\n    const title = await page.title();\n    const status = resp?.status();\n    log(`[${label}] HTTP ${status} | url=${url} | title=${title}`);\n\n    if (url.includes('login') || title.includes('登录') || title.includes('WAF')) {\n      log(`[${label}] Session EXPIRED - need re-login`);\n      writeState({\n        ok: false,\n        error: 'session_expired',\n        at: new Date().toISOString(),\n        finalUrl: url,\n        title,\n        account: ACCOUNT,\n      });\n      await browser.close();\n      process.exit(1);\n    }\n\n    // Bonus: also poke the main page to make sure session stays active\n    await page.goto('https://www.tapd.cn/tapd_fe/31253609/story/list', {\n      waitUntil: 'domcontentloaded',\n      timeout: 30000,\n    }).catch(() => {});\n    await page.waitForTimeout(2000);\n\n    // Save refreshed cookies\n    const newCookies = await ctx.cookies();\n    const newStorage = await ctx.storageState();\n\n    // 同时更新主文件（如果是周以天）和备份文件\n    fs.writeFileSync(COOKIES_FILE, JSON.stringify(newCookies, null, 2));\n    if (ACCOUNT === 'zhouyitian') {\n      // 主 tapd_cookies.json 也保持为周以天（提单用）\n      fs.writeFileSync(path.join(WORKSPACE_DIR, 'tapd_cookies.json'), JSON.stringify(newCookies, null, 2));\n    }\n    fs.writeFileSync(STORAGE_FILE, JSON.stringify(newStorage, null, 2));\n\n    const tapdsession = newCookies.find((c) => c.name === 'tapdsession');\n    const exp = tapdsession?.expires > 0\n      ? new Date(tapdsession.expires * 1000).toISOString()\n      : 'session';\n\n    log(`[${label}] Refreshed ${newCookies.length} cookies | tapdsession exp: ${exp}`);\n    writeState({\n      ok: true,\n      at: new Date().toISOString(),\n      cookieCount: newCookies.length,\n      tapdsessionExpires: exp,\n      title,\n      account: ACCOUNT,\n    });\n\n    await browser.close();\n    process.exit(0);\n  } catch (e) {\n    log(`[${label}] ERROR: ${e.message}`);\n    writeState({ ok: false, error: e.message, at: new Date().toISOString(), account: ACCOUNT });\n    try { await browser.close(); } catch {}\n    process.exit(2);\n  }\n}\n\nmain();\n","path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\tapd_keepalive.mjs"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":554,"output":1630,"cacheRead":145152,"cacheWrite":0,"totalTokens":147336,"cost":{"input":0.00007756000000000001,"output":0.00045640000000000003,"cacheRead":0.004064256,"cacheWrite":0,"total":0.004598216}},"stopReason":"toolUse","timestamp":1779258233277,"responseId":"c5f2baa3-e55a-4333-a331-01fe499b4cb1"}}

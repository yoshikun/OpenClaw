{"type":"message","id":"ec811408","parentId":"223da5d6","timestamp":"2026-05-20T03:59:40.628Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Chrome started with remote debugging on port 9222. Now I can write a Playwright script to connect to it via `connectOverCDP` and extract TAPD cookies.","thinkingSignature":"reasoning_content"},{"type":"text","text":"Chrome 已用远程调试模式启动，现在连接它提取 cookie："},{"type":"toolCall","id":"call_00_Qdm7VT2mCuIsGTYxt6sR1070","name":"write","arguments":{"content":"/**\n * 通过 Chrome DevTools Protocol 连接并提取 TAPD cookies\n * Chrome 需以 --remote-debugging-port=9222 启动\n */\nimport { chromium } from 'playwright';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\nconst WS_DIR = path.resolve(__dirname, '..');\nconst COOKIES_FILE = path.join(WS_DIR, 'tapd_cookies.json');\n\nasync function main() {\n  // 通过 CDP 连接到已打开的 Chrome\n  const browser = await chromium.connectOverCDP('http://127.0.0.1:9222');\n  console.log('Connected to Chrome via CDP');\n\n  // 使用默认 context\n  const defaultContext = browser.contexts()[0];\n  const page = defaultContext.pages()[0] || await defaultContext.newPage();\n\n  try {\n    console.log('Navigating to TAPD...');\n    await page.goto('https://www.tapd.cn/31253609/bugtrace/bugs/add', {\n      waitUntil: 'networkidle',\n      timeout: 30000,\n    });\n    console.log('Current URL:', page.url());\n\n    // 获取 cookies\n    const cookies = await defaultContext.cookies();\n    const tapdCookies = cookies.filter(c => \n      c.domain.includes('tapd.cn') || c.name === 'tapdsession' || c.name === 't_u' || c.name === 't_cloud_login'\n    );\n    console.log(`Found ${tapdCookies.length} TAPD-related cookies`);\n\n    // 筛选关键 cookie\n    const sessionCookie = cookies.find(c => c.name === 'tapdsession');\n    if (sessionCookie) {\n      console.log('✅ tapdsession found!');\n      console.log('   Value:', sessionCookie.value.substring(0, 30) + '...');\n      console.log('   Expires:', new Date(sessionCookie.expires * 1000).toLocaleString());\n      console.log('   Domain:', sessionCookie.domain);\n\n      // 获取完整 TAPD cookie 列表\n      const allTapdCookies = cookies.filter(c => c.domain.includes('tapd.cn'));\n      \n      // 保存\n      fs.writeFileSync(COOKIES_FILE, JSON.stringify(allTapdCookies, null, 2), 'utf8');\n      console.log(`\\n✅ Saved ${allTapdCookies.length} cookies to tapd_cookies.json`);\n      \n      allTapdCookies.forEach(c => {\n        console.log(`   ${c.name}: ${c.value.substring(0, 40)}`);\n      });\n    } else {\n      console.log('❌ No tapdsession cookie found');\n      // 列出所有 cookies 的域名\n      const domains = [...new Set(cookies.map(c => c.domain))];\n      console.log('Available domains:', domains.join(', '));\n    }\n  } finally {\n    await browser.close();\n  }\n}\n\nmain().catch(err => {\n  console.error('FAILED:', err.message);\n  process.exit(1);\n});\n","path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\extract_tapd_cookies_cdp.mjs"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":68,"output":808,"cacheRead":38144,"cacheWrite":0,"totalTokens":39020,"cost":{"input":0.00000952,"output":0.00022624,"cacheRead":0.001068032,"cacheWrite":0,"total":0.001303792}},"stopReason":"toolUse","timestamp":1779249573257,"responseId":"35b54569-7c1c-42e3-8b2d-dc8d239f6e3f"}}

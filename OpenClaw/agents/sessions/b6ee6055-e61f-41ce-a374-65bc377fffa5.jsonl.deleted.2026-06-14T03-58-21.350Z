{"type":"message","id":"2a0d2375","parentId":"8db6a57e","timestamp":"2026-05-15T03:53:39.501Z","message":{"role":"toolResult","toolCallId":"call_00_XWDRjxqc40OvMX9tLZ843503","toolName":"read","content":[{"type":"text","text":"\n        /// <summary>\n        /// 无参入口，供 bat：<c>-executeMethod YYZY.BuildPipeline.BuildPipeline.RunHotUpdatePipeline</c>。\n        /// 执行名为 <see cref=\"HotUpdatePipelineName\"/> 的流水线中的<strong>全部有效步骤</strong>（与编辑器里整条线执行一致，非仅勾选步骤）。\n        /// </summary>\n        public static void RunHotUpdatePipeline()\n        {\n            if (!IsCommandLineBatchMode())\n            {\n                Execute(HotUpdatePipelineName);\n                return;\n            }\n\n            Debug.Log($\"BuildPipeline.RunHotUpdatePipeline (batch, all steps): '{HotUpdatePipelineName}'\");\n            BeginBatchCli(HotUpdatePipelineName, selectedOnly: false);\n        }\n\n        private static bool IsCommandLineBatchMode()\n        {\n            return Array.IndexOf(Environment.GetCommandLineArgs(), \"-batchmode\") >= 0;\n        }\n\n        private static void BeginBatchCli(string pipeline, bool selectedOnly)\n        {\n            if (string.IsNullOrEmpty(pipeline))\n            {\n                Debug.LogError(\"BuildPipeline CLI: pipeline name is empty.\");\n                EditorApplication.Exit(1);\n                return;\n            }\n\n            EditorPrefs.SetBool(BatchExitAfterDonePrefKey, true);\n            var mode = selectedOnly ? \"Selected\" : \"Full\";\n            Debug.Log($\"BuildPipeline CLI (batch) mode={mode} pipeline='{pipeline}'\");\n\n            var pipe = Config.GetPipeLine(pipeline);\n            if (pipe == null)\n            {\n                Debug.LogError(\"pipeline \" + pipeline + \" not found!\");\n                ClearBatchExitRequest();\n                EditorApplication.Exit(1);\n                return;\n            }\n\n            try\n            {\n                Config.ExecuteStack.Clear();\n                ExecutePipeline(pipe, selectedOnly);\n            }\n            catch (Exception e)\n            {\n                Debug.LogException(e);\n                ClearBatchExitRequest();\n                EditorApplication.Exit(1);\n                return;\n            }\n\n            TryBatchExitNowIfDone();\n        }\n\n        private static void ClearBatchExitRequest()\n        {\n            EditorPrefs.SetBool(BatchExitAfterDonePrefKey, false);\n        }\n\n        private static void TryBatchExitNowIfDone()\n        {\n            if (!EditorPrefs.GetBool(BatchExitAfterDonePrefKey, false))\n                return;\n            if (!IsDone())\n                return;\n\n            ClearBatchExitRequest();\n            var code = LastRunSucceeded ? 0 : 1;\n            if (code != 0)\n                Debug.LogError(\"Build pipeline finished with errors or was canceled.\");\n            EditorApplication.Exit(code);\n        }\n\n        public static void ExecuteSelected(string pipeline)\n        {\n            var pipe = Config.GetPipeLine(pipeline);\n            if (pipe != null)\n            {\n                Config.ExecuteStack.Clear();\n                ExecutePipeline(pipe, true);\n            }\n            else\n            {\n                Debug.Log(\"pipeline \" + pipeline + \" not found!\");\n            }\n        }\n\n        public static void SaveConfig()\n        {\n            if (config != null)\n            {\n                var path = ConfigFilePath;\n                using (var w = serializer.CreateWriter(File.OpenWrite(path)))\n                {\n\n[117 more lines in file. Use offset=200 to continue.]"}],"isError":false,"timestamp":1778817219501}}

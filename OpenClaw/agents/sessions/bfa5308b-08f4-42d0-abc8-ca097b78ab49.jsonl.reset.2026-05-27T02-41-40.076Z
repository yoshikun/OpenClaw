{"type":"message","id":"aad243fd","parentId":"36da2bd4","timestamp":"2026-05-26T07:35:23.218Z","message":{"role":"toolResult","toolCallId":"call_00_XKV57s2xPVL1hZGeycHL1295","toolName":"exec","content":[{"type":"text","text":"@echo off\r\nchcp 65001 >nul\r\n\r\nREM ========================================\r\nREM  配置检测工具 (Go + C#)\r\nREM  同时检测 lobbysvr 和 roomsvr 配置\r\nREM  用法：将配置目录拖放到此 bat 文件上\r\nREM ========================================\r\n\r\nsetlocal enabledelayedexpansion\r\nset \"SCRIPT_DIR=%~dp0\"\r\nset \"CONFIG_PATH=%~1\"\r\n\r\nREM 如果没有传入参数，尝试自动查找配置目录\r\nif \"%CONFIG_PATH%\"==\"\" (\r\n    REM 尝试路径1: 固定路径\r\n    set \"DEFAULT_PATH1=D:\\project\\nightoffullmoon\\client\\cardv\\Assets\\ArtPackage\\Solo\\Config\\Server\"\r\n    if exist \"!DEFAULT_PATH1!\" (\r\n        set \"CONFIG_PATH=!DEFAULT_PATH1!\"\r\n        REM echo [Check] 找到配置目录: !CONFIG_PATH!\r\n    ) else (\r\n        REM 尝试路径2: 相对路径\r\n        set \"DEFAULT_REL_PATH=..\\..\\server\\bin\\config\\excel\"\r\n        set \"TEMP_PATH=!SCRIPT_DIR!!DEFAULT_REL_PATH!\"\r\n        REM echo [Check] 尝试查找默认配置路径: !TEMP_PATH!\r\n        pushd \"!TEMP_PATH!\" 2>nul\r\n        if not errorlevel 1 (\r\n            set \"CONFIG_PATH=!CD!\"\r\n            popd\r\n            REM echo [Check] 找到配置目录: !CONFIG_PATH!\r\n        ) else (\r\n            echo [Check] WARNING: Default path does not exist: !TEMP_PATH!\r\n        )\r\n    )\r\n)\r\n\r\nREM 转换相对路径为绝对路径（如果用户传入的是相对路径）\r\nif not \"!CONFIG_PATH!\"==\"\" (\r\n    REM 检查是否是绝对路径（以盘符开头）\r\n    if errorlevel 1 (\r\n        REM 不是绝对路径，需要转换\r\n        pushd \"!CONFIG_PATH!\" 2>nul\r\n        if not errorlevel 1 (\r\n            set \"CONFIG_PATH=!CD!\"\r\n            popd\r\n        )\r\n    )\r\n)\r\n\r\nREM 检查配置目录是否存在\r\nif not exist \"%CONFIG_PATH%\" (\r\n    echo.\r\n    echo ========================================\r\n    echo   配置检测工具\r\n    echo ========================================\r\n    echo.\r\n    echo ❌ 未找到配置目录\r\n    echo.\r\n    echo 用法：\r\n    echo   1. 将配置目录拖放到此 bat 文件上\r\n    echo   2. 使用命令行：check_all.bat \"配置目录路径\"\r\n    echo.\r\n    echo 可用脚本：\r\n    echo   check_all.bat          - 同时检测 Go 和 C# 配置\r\n    echo   csharp\\check_csharp.bat - 仅检测 C# ^(roomsvr^) 配置\r\n    echo   go\\check_go.bat         - 仅检测 Go ^(lobbysvr^) 配置\r\n    echo.\r\n    pause\r\n    exit /b 1\r\n)\r\n\r\nREM echo ========================================\r\nREM echo   配置检测工具\r\nREM echo ========================================\r\nREM echo   配置目录: !CONFIG_PATH!\r\nREM echo ========================================\r\nREM echo.\r\necho ========================================\r\necho   配置检测 - C# ^(roomsvr^)\r\necho ========================================\r\necho.\r\n\"!SCRIPT_DIR!csharp\\config_checker_csharp.exe\" -config \"!CONFIG_PATH!\" -v\r\nset CSHARP_RESULT=!errorlevel!\r\n\r\necho.\r\necho ========================================\r\necho   配置检测 - Go ^(lobbysvr^)\r\necho ========================================\r\necho.\r\nif exist \"%SCRIPT_DIR%go\\config_checker.exe\" (\r\n    REM 自动修复 manzo 环境 (如果不存在)\r\n    if not exist \"%USERPROFILE%\\.manzo\" (\r\n        echo [初始化] 创建 .manzo 目录...\r\n        mkdir \"%USERPROFILE%\\.manzo\"\r\n    )\r\n    if not exist \"%USERPROFILE%\\.manzo\\manzo.bin\" (\r\n        if exist \"%SCRIPT_DIR%go\\manzo.bin\" (\r\n            echo [初始化] 复制 manzo.bin 授权文件...\r\n            copy \"%SCRIPT_DIR%go\\manzo.bin\" \"%USERPROFILE%\\.manzo\\\" >nul\r\n        ) else (\r\n            echo ⚠️ 警告: 缺少 manzo.bin，Go 工具可能无法运行\r\n        )\r\n    )\r\n\r\n    \"!SCRIPT_DIR!go\\config_checker.exe\" -config \"!CONFIG_PATH!\" -v\r\n    set GO_RESULT=!errorlevel!\r\n) else (\r\n    echo ⚠️ Go 版本未部署，跳过\r\n    set GO_RESULT=0\r\n)\r\n\r\necho.\r\necho ========================================\r\necho   检测结果汇总\r\necho ========================================\r\nif !CSHARP_RESULT! equ 0 (echo   C# ^(roomsvr^): ✅ 通过) else (echo   C# ^(roomsvr^): ❌ 失败)\r\nif !GO_RESULT! equ 0 (echo   Go ^(lobbysvr^): ✅ 通过) else (echo   Go ^(lobbysvr^): ❌ 失败)\r\necho.\r\npause\r\n=== \r\n@echo off\r\nchcp 65001 >nul\r\n\r\nREM ========================================\r\nREM  初始化 Manzo 运行环境\r\nREM  功能：创建 .manzo 目录并复制授权文件\r\nREM ========================================\r\n\r\nsetlocal\r\nset SCRIPT_DIR=%~dp0\r\n\r\necho 正在检查 Manzo 环境...\r\n\r\nREM 1. 创建 .manzo 目录\r\nif not exist \"%USERPROFILE%\\.manzo\" (\r\n    echo [创建目录] %USERPROFILE%\\.manzo\r\n    mkdir \"%USERPROFILE%\\.manzo\"\r\n) else (\r\n    echo [已存在] %USERPROFILE%\\.manzo\r\n)\r\n\r\nREM 2. 复制 manzo.bin\r\nif exist \"%SCRIPT_DIR%go\\manzo.bin\" (\r\n    echo [复制文件] go\\manzo.bin -> %USERPROFILE%\\.manzo\\\r\n    copy \"%SCRIPT_DIR%go\\manzo.bin\" \"%USERPROFILE%\\.manzo\\\" >nul\r\n    if not errorlevel 1 (\r\n        echo ✅ 环境初始化成功！\r\n    ) else (\r\n        echo ❌ 文件复制失败\r\n    )\r\n) else (\r\n    echo ❌ 错误：go目录下找不到 manzo.bin\r\n)\r\n\r\npause"}],"details":{"status":"completed","exitCode":0,"durationMs":370,"aggregated":"@echo off\r\nchcp 65001 >nul\r\n\r\nREM ========================================\r\nREM  配置检测工具 (Go + C#)\r\nREM  同时检测 lobbysvr 和 roomsvr 配置\r\nREM  用法：将配置目录拖放到此 bat 文件上\r\nREM ========================================\r\n\r\nsetlocal enabledelayedexpansion\r\nset \"SCRIPT_DIR=%~dp0\"\r\nset \"CONFIG_PATH=%~1\"\r\n\r\nREM 如果没有传入参数，尝试自动查找配置目录\r\nif \"%CONFIG_PATH%\"==\"\" (\r\n    REM 尝试路径1: 固定路径\r\n    set \"DEFAULT_PATH1=D:\\project\\nightoffullmoon\\client\\cardv\\Assets\\ArtPackage\\Solo\\Config\\Server\"\r\n    if exist \"!DEFAULT_PATH1!\" (\r\n        set \"CONFIG_PATH=!DEFAULT_PATH1!\"\r\n        REM echo [Check] 找到配置目录: !CONFIG_PATH!\r\n    ) else (\r\n        REM 尝试路径2: 相对路径\r\n        set \"DEFAULT_REL_PATH=..\\..\\server\\bin\\config\\excel\"\r\n        set \"TEMP_PATH=!SCRIPT_DIR!!DEFAULT_REL_PATH!\"\r\n        REM echo [Check] 尝试查找默认配置路径: !TEMP_PATH!\r\n        pushd \"!TEMP_PATH!\" 2>nul\r\n        if not errorlevel 1 (\r\n            set \"CONFIG_PATH=!CD!\"\r\n            popd\r\n            REM echo [Check] 找到配置目录: !CONFIG_PATH!\r\n        ) else (\r\n            echo [Check] WARNING: Default path does not exist: !TEMP_PATH!\r\n        )\r\n    )\r\n)\r\n\r\nREM 转换相对路径为绝对路径（如果用户传入的是相对路径）\r\nif not \"!CONFIG_PATH!\"==\"\" (\r\n    REM 检查是否是绝对路径（以盘符开头）\r\n    if errorlevel 1 (\r\n        REM 不是绝对路径，需要转换\r\n        pushd \"!CONFIG_PATH!\" 2>nul\r\n        if not errorlevel 1 (\r\n            set \"CONFIG_PATH=!CD!\"\r\n            popd\r\n        )\r\n    )\r\n)\r\n\r\nREM 检查配置目录是否存在\r\nif not exist \"%CONFIG_PATH%\" (\r\n    echo.\r\n    echo ========================================\r\n    echo   配置检测工具\r\n    echo ========================================\r\n    echo.\r\n    echo ❌ 未找到配置目录\r\n    echo.\r\n    echo 用法：\r\n    echo   1. 将配置目录拖放到此 bat 文件上\r\n    echo   2. 使用命令行：check_all.bat \"配置目录路径\"\r\n    echo.\r\n    echo 可用脚本：\r\n    echo   check_all.bat          - 同时检测 Go 和 C# 配置\r\n    echo   csharp\\check_csharp.bat - 仅检测 C# ^(roomsvr^) 配置\r\n    echo   go\\check_go.bat         - 仅检测 Go ^(lobbysvr^) 配置\r\n    echo.\r\n    pause\r\n    exit /b 1\r\n)\r\n\r\nREM echo ========================================\r\nREM echo   配置检测工具\r\nREM echo ========================================\r\nREM echo   配置目录: !CONFIG_PATH!\r\nREM echo ========================================\r\nREM echo.\r\necho ========================================\r\necho   配置检测 - C# ^(roomsvr^)\r\necho ========================================\r\necho.\r\n\"!SCRIPT_DIR!csharp\\config_checker_csharp.exe\" -config \"!CONFIG_PATH!\" -v\r\nset CSHARP_RESULT=!errorlevel!\r\n\r\necho.\r\necho ========================================\r\necho   配置检测 - Go ^(lobbysvr^)\r\necho ========================================\r\necho.\r\nif exist \"%SCRIPT_DIR%go\\config_checker.exe\" (\r\n    REM 自动修复 manzo 环境 (如果不存在)\r\n    if not exist \"%USERPROFILE%\\.manzo\" (\r\n        echo [初始化] 创建 .manzo 目录...\r\n        mkdir \"%USERPROFILE%\\.manzo\"\r\n    )\r\n    if not exist \"%USERPROFILE%\\.manzo\\manzo.bin\" (\r\n        if exist \"%SCRIPT_DIR%go\\manzo.bin\" (\r\n            echo [初始化] 复制 manzo.bin 授权文件...\r\n            copy \"%SCRIPT_DIR%go\\manzo.bin\" \"%USERPROFILE%\\.manzo\\\" >nul\r\n        ) else (\r\n            echo ⚠️ 警告: 缺少 manzo.bin，Go 工具可能无法运行\r\n        )\r\n    )\r\n\r\n    \"!SCRIPT_DIR!go\\config_checker.exe\" -config \"!CONFIG_PATH!\" -v\r\n    set GO_RESULT=!errorlevel!\r\n) else (\r\n    echo ⚠️ Go 版本未部署，跳过\r\n    set GO_RESULT=0\r\n)\r\n\r\necho.\r\necho ========================================\r\necho   检测结果汇总\r\necho ========================================\r\nif !CSHARP_RESULT! equ 0 (echo   C# ^(roomsvr^): ✅ 通过) else (echo   C# ^(roomsvr^): ❌ 失败)\r\nif !GO_RESULT! equ 0 (echo   Go ^(lobbysvr^): ✅ 通过) else (echo   Go ^(lobbysvr^): ❌ 失败)\r\necho.\r\npause\r\n=== \r\n@echo off\r\nchcp 65001 >nul\r\n\r\nREM ========================================\r\nREM  初始化 Manzo 运行环境\r\nREM  功能：创建 .manzo 目录并复制授权文件\r\nREM ========================================\r\n\r\nsetlocal\r\nset SCRIPT_DIR=%~dp0\r\n\r\necho 正在检查 Manzo 环境...\r\n\r\nREM 1. 创建 .manzo 目录\r\nif not exist \"%USERPROFILE%\\.manzo\" (\r\n    echo [创建目录] %USERPROFILE%\\.manzo\r\n    mkdir \"%USERPROFILE%\\.manzo\"\r\n) else (\r\n    echo [已存在] %USERPROFILE%\\.manzo\r\n)\r\n\r\nREM 2. 复制 manzo.bin\r\nif exist \"%SCRIPT_DIR%go\\manzo.bin\" (\r\n    echo [复制文件] go\\manzo.bin -> %USERPROFILE%\\.manzo\\\r\n    copy \"%SCRIPT_DIR%go\\manzo.bin\" \"%USERPROFILE%\\.manzo\\\" >nul\r\n    if not errorlevel 1 (\r\n        echo ✅ 环境初始化成功！\r\n    ) else (\r\n        echo ❌ 文件复制失败\r\n    )\r\n) else (\r\n    echo ❌ 错误：go目录下找不到 manzo.bin\r\n)\r\n\r\npause","cwd":"C:\\Users\\yyzypublic\\.openclaw\\workspace"},"isError":false,"timestamp":1779780923218}}

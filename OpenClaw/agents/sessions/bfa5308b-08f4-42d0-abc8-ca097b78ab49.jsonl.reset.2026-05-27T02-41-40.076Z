{"type":"message","id":"f33844f6","parentId":"7dbe0c5e","timestamp":"2026-05-26T07:36:44.139Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Good, created. Now let me write the main script for adding fields to config tables.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_00_Q95uD4aV7AYNukPV79b27141","name":"write","arguments":{"path":"C:\\Users\\yyzypublic\\.openclaw\\plugin-skills\\solo-config-field\\scripts\\add_field.mjs","content":"#!/usr/bin/env node\n/**\n * solo-config-field skill — add fields to Luban Excel config tables\n *\n * Usage:\n *   node add_field.mjs <tableName> <fieldName> <fieldType> [--group c|s|e] [--desc \"注释\"] [--default \"默认值\"] [--after existingField]\n *\n * Examples:\n *   node add_field.mjs Card testField int\n *   node add_field.mjs Common testField float --group c --desc \"测试字段\" --default 0.5\n *   node add_field.mjs Card testField \"(list#sep=,),int\" --after id\n */\n\nimport * as XLSX from 'xlsx';\nimport { readFileSync, writeFileSync, existsSync } from 'fs';\nimport { join, dirname } from 'path';\n\n// ── Config ────────────────────────────────────────────────────\n// SoloConfig 子模块根目录\nconst SOLO_CONFIG = 'E:\\\\Solo\\\\nightoffullmoon\\\\client\\\\config\\\\SoloConfig';\nconst DATAS_DIR  = join(SOLO_CONFIG, 'Datas');\nconst TABLES_DEF = join(DATAS_DIR, '__tables__.xlsx');\nconst BEANS_DEF  = join(DATAS_DIR, '__beans__.xlsx');\nconst ENUMS_DEF  = join(DATAS_DIR, '__enums__.xlsx');\n\n// ── Help ──────────────────────────────────────────────────────\nfunction printHelp() {\n  console.log(`\nUsage: node add_field.mjs <tableName> <fieldName> <fieldType> [options]\n\nOptions:\n  --group  c|s|e         分组标识（默认 c,s）\n  --desc   \"注释\"          字段中文注释\n  --default \"默认值\"       已有行的默认填充值（默认空）\n  --after  existingField  在哪列后面插入（默认追加到末尾）\n\nExamples:\n  node add_field.mjs Card newField int --group c,s --desc \"新字段\"\n  node add_field.mjs Common newField float --group c --default 0\n  node add_field.mjs Buff newField \"(list#sep=,),int\"\n\nTables Defined:\n` + listTables());\n}\n\nfunction listTables() {\n  if (!existsSync(TABLES_DEF)) return '  [__tables__.xlsx not found]';\n  const wb = XLSX.readFile(TABLES_DEF);\n  const ws = wb.Sheets[wb.SheetNames[0]];\n  const rows = XLSX.utils.sheet_to_json(ws, { header: 1 });\n  const tableRows = rows.filter(r => r[1] && r[1].startsWith('Tb'));\n  return tableRows.map(r => `  ${r[1]?.padEnd(20)} → ${r[4] || ''}  (${r[5] ? 'group:' + r[5] : ''})`).join('\\n');\n}\n\n// ── Find table definition from __tables__.xlsx ────────────────\nfunction findTableDef(tableName) {\n  if (!existsSync(TABLES_DEF)) {\n    console.error('❌ __tables__.xlsx not found at:', TABLES_DEF);\n    process.exit(2);\n  }\n  const wb = XLSX.readFile(TABLES_DEF);\n  const ws = wb.Sheets[wb.SheetNames[0]];\n  const rows = XLSX.utils.sheet_to_json(ws, { header: 1 });\n\n  // Column: 0=##var, 1=full_name, 2=value_type, 3=input, 4=index, 5=mode, 6=group, 7=comment\n  const def = rows.find(r => {\n    const name = String(r[0] || '').trim();\n    return name.replace(/^Tb/i, '').toLowerCase() === tableName.toLowerCase()\n        || name.toLowerCase() === tableName.toLowerCase();\n  });\n  if (!def) {\n    // Try matching by full_name\n    const def2 = rows.find(r => {\n      const fullName = String(r[1] || '');\n      return fullName.replace(/Config$/i, '').toLowerCase() === tableName.toLowerCase()\n          || fullName.toLowerCase() === tableName.toLowerCase();\n    });\n    return def2;\n  }\n  return def;\n}\n\n// ── Get data xlsx filename from table definition ──────────────\nfunction getDataXlsxFileName(tableDef) {\n  return String(tableDef[4] || '').trim();\n}\n\n// ── Parse Luban header rows from an xlsx sheet ────────────────\nfunction parseHeaders(rows, formatType) {\n  // For list format: row0=##var row1=##type row2=##group row3=comment\n  // For kv format: row0=##column#var row1=##type row2=##group row3=comment\n\n  if (formatType === 'kv') {\n    // Key-value table (like Common.xlsx)\n    // Search for the header rows\n    let varRow = -1, typeRow = -1, groupRow = -1;\n    for (let i = 0; i < Math.min(10, rows.length); i++) {\n      const cell = String(rows[i]?.[0] || '');\n      if (cell === '##column#var' || cell === '##var') varRow = varRow === -1 ? i : varRow;\n      if (cell === '##type') typeRow = typeRow === -1 ? i : typeRow;\n      if (cell === '##group') groupRow = groupRow === -1 ? i : groupRow;\n    }\n    return { varRow, typeRow, groupRow, format: 'kv' };\n  }\n\n  // List format (like Card.xlsx)\n  // Search for header rows: after skip the first empty rows\n  let varRow = -1, typeRow = -1, groupRow = -1, commentRow = -1;\n  for (let i = 0; i < Math.min(10, rows.length); i++) {\n    const cell = String(rows[i]?.[0] || '');\n    // If first cell is a data value (number), we've passed headers\n    if (cell === '##var') varRow = i;\n    else if (cell === '##type') typeRow = i;\n    else if (cell === '##group') groupRow = i;\n    else if (cell.startsWith('##') && varRow >= 0 && typeRow >= 0 && commentRow === -1) commentRow = i;\n  }\n  return { varRow, typeRow, groupRow, commentRow, format: 'list' };\n}\n\n// ── Add field to list-format table ────────────────────────────\nfunction addToListTable(ws, rows, fieldName, fieldType, group, desc, defaultVal, after) {\n  const { varRow, typeRow, groupRow, commentRow } = parseHeaders(rows, 'list');\n\n  if (varRow === -1 || typeRow === -1) {\n    console.error('❌ Cannot find header rows (##var / ##type)');\n    process.exit(1);\n  }\n\n  // Find the column index to insert\n  const headerRow = rows[varRow];\n  let insertCol = headerRow.length; // append by default\n\n  if (after) {\n    const afterIdx = headerRow.findIndex((c, i) => String(c || '').trim() === after);\n    if (afterIdx >= 0) {\n      insertCol = afterIdx + 1;\n    } else {\n      console.warn(`⚠️ Field \"${after}\" not found, appending to end.`);\n    }\n  }\n\n  // Build column letter for xlsx\n  const getColName = (idx) => {\n    let col = '';\n    while (idx >= 0) {\n      col = String.fromCharCode(65 + (idx % 26)) + col;\n      idx = Math.floor(idx / 26) - 1;\n    }\n    return col;\n  };\n\n  // Insert into each header row\n  if (varRow >= 0) {\n    const cell = XLSX.utils.encode_cell({ r: varRow, c: insertCol });\n    ws[cell] = { t: 's', v: fieldName };\n  }\n  if (typeRow >= 0) {\n    const cell = XLSX.utils.encode_cell({ r: typeRow, c: insertCol });\n    ws[cell] = { t: 's', v: fieldType };\n  }\n  if (groupRow >= 0) {\n    const cell = XLSX.utils.encode_cell({ r: groupRow, c: insertCol });\n    ws[cell] = { t: 's', v: group || 'c,s' };\n  }\n  if (commentRow >= 0) {\n    const cell = XLSX.utils.encode_cell({ r: commentRow, c: insertCol });\n    if (desc) ws[cell] = { t: 's', v: desc };\n  }\n\n  // Fill default values for all data rows\n  if (defaultVal !== undefined && defaultVal !== null) {\n    for (let i = Math.max(varRow, typeRow, groupRow, commentRow) + 1; i < rows.length; i++) {\n      // Skip empty rows and rows that start with ##\n      if (!rows[i] || !rows[i][0] || String(rows[i][0]).startsWith('##')) continue;\n      const cell = XLSX.utils.encode_cell({ r: i, c: insertCol });\n      // Try to determine numeric vs string\n      if (fieldType === 'int' || fieldType === 'float' || fieldType === 'long') {\n        const num = Number(defaultVal);\n        if (!isNaN(num)) {\n          ws[cell] = { t: 'n', v: num };\n        } else {\n          ws[cell] = { t: 's', v: String(defaultVal) };\n        }\n      } else {\n        ws[cell] = { t: 's', v: String(defaultVal) };\n      }\n    }\n  }\n\n  console.log(`✅ Added field \"${fieldName}\" (${fieldType}) at column ${getColName(insertCol)}`);\n  return true;\n}\n\n// ── Add field to key-value table (like Common.xlsx) ──────────\nfunction addToKvTable(ws, rows, fieldName, fieldType, group, desc, defaultVal, after) {\n  // For KV tables: each row is a key-value entry in column A (name), C (desc), D (value)\n  // But we're actually adding a row, not a column\n\n  const { varRow, typeRow, groupRow } = parseHeaders(rows, 'kv');\n\n  if (varRow === -1) {\n    console.error('❌ Cannot find header row (##var / ##column#var)');\n    process.exit(1);\n  }\n\n  // For KV tables, adding a field means adding a new row\n  // Find the next empty row\n  let newRowIdx = rows.length;\n  for (let i = Math.max(varRow, typeRow, groupRow) + 1; i < rows.length; i++) {\n    if (!rows[i]) { newRowIdx = i; break; }\n    if (i + 1 > newRowIdx) newRowIdx = i + 1;\n  }\n\n  // Fill row: [fieldName, fieldType, group, desc, defaultVal]\n  const values = [fieldName, fieldType, group || '', desc || '', defaultVal !== undefined ? String(defaultVal) : ''];\n  values.forEach((val, ci) => {\n    if (val !== undefined && val !== null && val !== '') {\n      const cell = XLSX.utils.encode_cell({ r: newRowIdx, c: ci });\n      const num = Number(val);\n      if (!isNaN(num) && fieldType !== 'string') {\n        ws[cell] = { t: 'n', v: num };\n      } else {\n        ws[cell] = { t: 's', v: String(val) };\n      }\n    }\n  });\n\n  console.log(`✅ Added KV field \"${fieldName}\" (${fieldType}) at row ${newRowIdx + 1}`);\n  return true;\n}\n\n// ── Main ──────────────────────────────────────────────────────\nfunction main() {\n  const args = process.argv.slice(2);\n\n  if (args.length === 0 || args[0] === '--help' || args[0] === '-h') {\n    printHelp();\n    process.exit(0);\n  }\n\n  const tableName = args[0];\n  const fieldName = args[1];\n  const fieldType = args[2];\n\n  if (!tableName || !fieldName || !fieldType) {\n    console.error('❌ Missing required args: <tableName> <fieldName> <fieldType>');\n    printHelp();\n    process.exit(1);\n  }\n\n  // Parse options\n  let group = 'c,s';\n  let desc = '';\n  let defaultVal = undefined;\n  let after = undefined;\n\n  for (let i = 3; i < args.length; i++) {\n    if (args[i] === '--group' && i + 1 < args.length) group = args[++i];\n    else if (args[i] === '--desc' && i + 1 < args.length) desc = args[++i];\n    else if (args[i] === '--default' && i + 1 < args.length) defaultVal = args[++i];\n    else if (args[i] === '--after' && i + 1 < args.length) after = args[++i];\n  }\n\n  // 1. Find table definition\n  const tableDef = findTableDef(tableName);\n  if (!tableDef) {\n    console.error(`❌ Table \"${tableName}\" not found in __tables__.xlsx`);\n    console.log('Available tables:');\n    console.log(listTables());\n    process.exit(1);\n  }\n\n  const dataFileName = getDataXlsxFileName(tableDef);\n  if (!dataFileName) {\n    console.error('❌ No data file specified for this table');\n    process.exit(1);\n  }\n\n  const dataFile = join(DATAS_DIR, dataFileName);\n  if (!existsSync(dataFile)) {\n    console.error(`❌ Data file not found: ${dataFile}`);\n    process.exit(1);\n  }\n\n  // 2. Read data xlsx\n  console.log(`📂 Table: ${tableDef[0]} (${tableDef[1]})`);\n  console.log(`📄 File: ${dataFileName}`);\n  console.log(`🔧 Adding: ${fieldName} : ${fieldType}`);\n\n  const wb = XLSX.readFile(dataFile);\n  const ws = wb.Sheets[wb.SheetNames[0]];\n  const rows = XLSX.utils.sheet_to_json(ws, { header: 1 });\n\n  // 3. Determine if KV or List format\n  const firstRow0 = String(rows[0]?.[0] || '');\n  const isKeyValue = firstRow0 === '##column#var' || (\n    // Common.xlsx uses ##column#var, but let's check: if rows are key-value pairs\n    rows.length > 3 && String(rows[3]?.[0] || '').length > 0 && !String(rows[3]?.[0])?.startsWith(',')\n    && String(rows[3]?.[1] || '') !== '' // Second column is type\n  );\n\n  // A better heuristic: check if the data file matches Common.xlsx pattern\n  // Common.xlsx has the format: name | type | group | desc | value (no id column)\n  // Card.xlsx has: ##var row with field names\n\n  const isKvTable = firstRow0 === '##column#var';\n\n  if (isKvTable) {\n    addToKvTable(ws, rows, fieldName, fieldType, group, desc, defaultVal, after);\n  } else {\n    addToListTable(ws, rows, fieldName, fieldType, group, desc, defaultVal, after);\n  }\n\n  // 4. Save\n  XLSX.writeFile(wb, dataFile);\n  console.log(`💾 Saved: ${dataFile}`);\n  console.log('');\n  console.log('⚠️  Next steps:');\n  console.log('   1. Verify the xlsx file in Excel if needed');\n  console.log('   2. Run Luban to regenerate code (via Unity BuildPipeline or Luban CLI)');\n  console.log('   3. Update server/client code to use the new field');\n  console.log('   4. Commit SoloConfig submodule changes');\n}\n\nmain();\n"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":92,"output":3767,"cacheRead":112768,"cacheWrite":0,"totalTokens":116627,"cost":{"input":0.00001288,"output":0.00105476,"cacheRead":0.0031575039999999998,"cacheWrite":0,"total":0.004225144}},"stopReason":"toolUse","timestamp":1779780966111,"responseId":"bd69698b-805a-49d1-b3cc-a3fa6e880f7e"}}

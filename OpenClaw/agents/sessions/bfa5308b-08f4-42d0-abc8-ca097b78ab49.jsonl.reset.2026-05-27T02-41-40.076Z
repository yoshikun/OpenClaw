sx \n                            → EventSlot.xlsx       \n                            → RechargeRebate.xlsx  \n                            → CollectionPoint.xlsx \n                            → AnimationChange.xlsx \n                            → RankedSettingsMatch.xlsx \n                            → CollectionLevel.xlsx \n                            → Title.xlsx           \n                            → CardGold.xlsx        \n                            → Level.xlsx"}],"details":{"status":"completed","exitCode":0,"durationMs":326,"aggregated":"Usage: node add_field.mjs <tableName> <fieldName> <fieldType> [options]\n\nOptions:\n  --group  c|s|e         分组标识（默认 c,s）\n  --desc   \"注释\"          字段中文注释\n  --default \"默认值\"       已有行的默认填充值（默认空）\n  --after  existingField  在哪列后面插入（默认追加到末尾）\n\nExamples:\n  node add_field.mjs Card newField int --group c,s --desc \"新字段\"\n  node add_field.mjs Common newField float --group c --default 0\n  node add_field.mjs Buff newField \"(list#sep=,),int\"\n\nTables Defined:\n                            → Common.xlsx          \n                            → Card.xlsx            \n                            → Buff.xlsx            \n                            → Target.xlsx          \n                            → ErrorCode.xlsx       \n                            → Animation.xlsx       \n                            → AnimationSet.xlsx    \n                            → Keyword.xlsx         \n                            → TestCard.xlsx        \n                            → CardAttribute.xlsx   \n                            → CardClan.xlsx        \n                            → CardDeck.xlsx        \n                            → Skin.xlsx            \n                            → Hero.xlsx            \n                            → CardGlobal.xlsx      \n                            → Guide.xlsx           \n                            → GuideSettings.xlsx   \n                            → Language.xlsx        \n                          
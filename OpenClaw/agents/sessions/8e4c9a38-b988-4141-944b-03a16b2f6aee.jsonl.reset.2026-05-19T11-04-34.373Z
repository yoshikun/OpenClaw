Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36' });\n  await ctx.addCookies(cookies);\n  const page = await ctx.newPage();\n  await page.addInitScript(STEALTH_INIT);\n  \n  // Capture console errors\n  page.on('pageerror', err => console.log('PAGE ERROR:', err.message));\n  page.on('console', msg => {\n    if (msg.type() === 'error') console.log('CONSOLE ERROR:', msg.text());\n  });\n  \n  const url = `https://www.tapd.cn/${WORKSPACE_ID}/bugtrace/bugs/add`;\n  await page.goto(url, { waitUntil: 'domcontentloaded', timeout: 30000 }).catch(() => {});\n  await page.waitForTimeout(5000);\n  \n  const pageTitle = await page.title();\n  if (pageTitle.includes('WAF')) { console.log('WAF!'); process.exit(1); }\n  \n  // Fill ALL required fields\n  await page.fill('#BugTitle', '卡组私密无法选中');\n  await page.selectOption('#BugVersionReport', '【1V1】正式版本V2.0');\n  await page.selectOption('#BugModule', '1V1');\n  await page.selectOption('#BugPriority', 'P2');\n  await page.selectOption('#BugCustomFieldOne', 'YYZY_1V1_V1.0');\n  console.log('Basic fields filled');\n  \n  // Set handler - use autocomplete\n  await page.click('#BugCurrentOwnerValue');\n  await page.waitForTimeout(300);\n  await page.fill('#BugCurrentOwnerValue', '谭佳钦');\n  await page.waitForTimeout(2000);\n  \n  const sugg = page.locator('.tt-suggestion').first();\n  if (await sugg.isVisible()) {\n    await sugg.click();\n    await page.waitForTimeout(1000);\n    // Override with numeric ID\n    await page.evaluate(() => {\n      document.getElementById('BugCurrentOwner').value = '553342158';\n    });\n  }\n  \n  const hv = await page.evaluate(() => ({\n    value: document.getElementById('BugCurrentOwner')?.value,\n    display: document.getElementById('BugCurrentOwnerValue')?.value,\n  }));\n  console.log('Handler:', JSON.stringify(hv));\n  \n  // Check form for validation errors\n  const errorCheck = await page.evaluate(() => {\n    // Look for any visible error messages\n    const errors = [];\n    document.querySelectorAll('*').forEach(el => {\n      if (el.offsetParent !== null) {\n        const text = el.textContent?.trim();\n        if (text && (text.includes('必填') || text.includes('不能为空') || text.includes('错误') || text.includes('请选择'))) {\n          if (text.length < 100) errors.push({ tag: el.tagName, id: el.id, text });\n        }\n      }\n    });\n    return errors;\n  });\n  console.log('Validation errors:', JSON.stringify(errorCheck));\n  \n  // Also check all required fields\n  const requiredFields = await page.evaluate(() => {\n    const required = document.querySelectorAll('[required]');\n    return Array.from(required).map(el => ({\n      id: el.id,\n      name: el.name,\n      type: el.type || el.tagName,\n      value: el.value.substring(0, 50),\n      tag: el.tagName,\n    }));\n  });\n  console.log('Required fields:', JSON.stringify(requiredFields, null, 2));\n  \n  // Try submitting\n  console.log('Submitting...');\n  await page.click('#_view');\n  await page.waitForTimeout(5000);\n  \n  const resultUrl = page.url();\n  console.log('Result:', resultUrl);\n  \n  if (!resultUrl.includes('bugs/add')) {\n    console.log('SUCCESS! Bug URL:', resultUrl);\n  } else {\n    console.log('Still on form - checking post-submit state...');\n    const afterSubmit = await page.evaluate(() => {\n      const errors = document.querySelectorAll('[class*=error],[class*=alert],.error,.alert');\n      const texts = [];\n      errors.forEach(e => {\n        if (e.textContent.trim()) texts.push(e.textContent.trim().substring(0, 200));\n      });\n      if (!texts.length) {\n        // Check for invisible validation messages\n        document.querySelectorAll('form *').forEach(el => {\n          const text = el.textContent?.trim();\n          if (text && (text.includes('必填') || text.includes('不能为空') || text.includes('请选'))) {\n            if (text.length < 50) texts.push(el.id + ': ' + text);\n          }\n        });\n      }\n      return texts;\n    });\n    console.log('Error texts:', JSON.stringify(afterSubmit));\n    await page.screenshot({ path: path.join(__dirname, 'tapd_error.png') });\n  }\n  \n  await browser.close();\n}\n\nmain().catch(e => { console.error('Fatal:', e.message); process.exit(1); });\n","path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\tapd_create_bug6.mjs"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":490,"output":1613,"cacheRead":99840,"cacheWrite":0,"totalTokens":101943,"cost":{"input":0.0000686,"output":0.00045164,"cacheRead":0.00279552,"cacheWrite":0,"total":0.00331576}},"stopReason":"toolUse","timestamp":1778849766714,"responseId":"24a6ddea-e16f-43d3-8f43-da0cebb1f68c"}}

u64CD\\u4F5C\\u65E5\\u5FD7:');\n  console.log('');\n  console.log(header);\n  console.log(sep);\n  console.log(rows);\n  console.log('');\n}\n\n// CLI entry\nif (process.argv[1] === fileURLToPath(import.meta.url)) {\n  const subcmd = process.argv[2];\n  if (subcmd === 'read') {\n    const n = parseInt(process.argv[3], 10) || 10;\n    readLogs(n);\n    process.exit(0);\n  }\n  const type = subcmd;\n  const sender = process.argv[3];\n  const detail = process.argv[4] || '';\n  const result = process.argv[5] || '';\n  if (!type || !sender) {\n    console.error('\\u7528\\u6CD5:');\n    console.error('  node scripts/log_operation.mjs <\\u64CD\\u4F5C\\u7C7B\\u578B> <\\u53D1\\u9001\\u4EBA> <\\u8BE6\\u60C5> [\\u7ED3\\u679C]  \\u8BB0\\u5F55\\u65E5\\u5FD7');\n    console.error('  node scripts/log_operation.mjs read [\\u6761\\u6570]                      \\u67E5\\u770B\\u65E5\\u5FD7');\n    process.exit(1);\n  }\n  logOperation({ type, sender, detail, result });\n  console.log('\\u2705 \\u5DF2\\u8BB0\\u5F55');\n}"}]}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":1867,"output":1087,"cacheRead":21632,"cacheWrite":0,"totalTokens":24586,"cost":{"input":0.00026138,"output":0.00030436000000000005,"cacheRead":0.000605696,"cacheWrite":0,"total":0.001171436}},"stopReason":"toolUse","timestamp":1779329450752,"responseId":"46e74227-b990-4769-b155-e9c43a5cc114"}}

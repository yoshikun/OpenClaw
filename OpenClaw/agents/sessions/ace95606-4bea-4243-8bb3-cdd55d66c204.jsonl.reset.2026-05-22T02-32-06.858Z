{"type":"message","id":"3c489cd4","parentId":"121b6059","timestamp":"2026-05-21T03:49:00.024Z","message":{"role":"toolResult","toolCallId":"call_00_hfZvQbdPGpO3pLqWNRM85806","toolName":"read","content":[{"type":"text","text":"/**\n * 操作日志记录模块\n * 同事每次操作后调用，记录到 memory/operation-log.json\n * 自动发送飞书卡片到开发群。\n *\n * 用法: node scripts/log_operation.mjs <操作类型> <发送人> <详情> [结果]\n */\n\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\nconst WS_DIR = path.resolve(__dirname, '..');\nconst LOG_FILE = path.join(WS_DIR, 'memory', 'operation-log.json');\n\nexport function logOperation({ type, sender, detail, result = '', senderId = '' }) {\n  const now = new Date();\n  const entry = {\n    timestamp: now.toISOString(),\n    time_cn: now.toLocaleString('zh-CN', { timeZone: 'Asia/Shanghai' }),\n    type, sender, senderId, detail, result,\n  };\n  let logs = [];\n  try { if (fs.existsSync(LOG_FILE)) logs = JSON.parse(fs.readFileSync(LOG_FILE, 'utf8')); } catch(e) {}\n  logs.push(entry);\n  if (logs.length > 500) logs = logs.slice(-500);\n  fs.writeFileSync(LOG_FILE, JSON.stringify(logs, null, 2), 'utf8');\n  return entry;\n}\n\nfunction readLogs(count = 10) {\n  let logs = [];\n  try {\n    if (fs.existsSync(LOG_FILE)) logs = JSON.parse(fs.readFileSync(LOG_FILE, 'utf8'));\n  } catch(e) {}\n  const recent = logs.slice(-count).reverse();\n  if (recent.length === 0) { console.log('暂无日志'); return; }\n  const header = '| # | 时间 | 类型 | 发送人 | 详情 | 结果 |';\n  const sep = '|---|------|------|--------|------|------|';\n  const rows = recent.map((e, i) => {\n    const n = recent.length - i;\n    const t = e.type && e.type.length > 8 ? e.type.slice(0, 6) + '..' : (e.type || '');\n    const d = e.detail && e.detail.length > 10 ? e.detail.slice(0, 9) + '..' : (e.detail || '');\n    const r = e.result || '';\n    const icon = r === '成功' ? '\\u2705' : r === '失败' ? '\\u274C' : '-';\n    return '| ' + n + ' | ' + (e.time_cn || '-') + ' | ' + icon + ' ' + t + ' | ' + (e.sender || '-') + ' | ' + d + ' | ' + (r || '-') + ' |';\n  }).join('\\n');\n  console.log('');\n  console.log('\\uD83D\\uDCCB \\u6700\\u8FD1 ' + recent.length + ' \\u6761\\u64CD\\u4F5C\\u65E5\\u5FD7:');\n  console.log('');\n  console.log(header);\n  console.log(sep);\n  console.log(rows);\n  console.log('');\n}\n\n// CLI entry\nif (process.argv[1] === fileURLToPath(import.meta.url)) {\n  const subcmd = process.argv[2];\n  if (subcmd === 'read') {\n    const n = parseInt(process.argv[3], 10) || 10;\n    readLogs(n);\n    process.exit(0);\n  }\n  const type = subcmd;\n  const sender = process.argv[3];\n  const detail = process.argv[4] || '';\n  const result = process.argv[5] || '';\n  if (!type || !sender) {\n    console.error('\\u7528\\u6CD5:');\n    console.error('  node scripts/log_operation.mjs <\\u64CD\\u4F5C\\u7C7B\\u578B> <\\u53D1\\u9001\\u4EBA> <\\u8BE6\\u60C5> [\\u7ED3\\u679C]  \\u8BB0\\u5F55\\u65E5\\u5FD7');\n    console.error('  node scripts/log_operation.mjs read [\\u6761\\u6570]                      \\u67E5\\u770B\\u65E5\\u5FD7');\n    process.exit(1);\n  }\n  logOperation({ type, sender, detail, result });\n  console.log('\\u2705 \\u5DF2\\u8BB0\\u5F55');\n}\n"}],"isError":false,"timestamp":1779335340024}}

  else { const t = await r.text(); console.error(`❌ 失败:`, t.substring(0, 200)); }\n}","newText":"async function addMember(projectId, userName, level) {\n  const user = await findUsers(userName);\n  const body = new URLSearchParams({ user_id: String(user.id), access_level: String(LEVEL_MAP[level]) }).toString();\n  const r = await writeWithRetry(`${GITLAB}/api/v4/projects/${projectId}/members`, 'POST', body);\n  const result = await r.json();\n  if (r.ok) console.log(`✅ 已添加 ${user.name} (@${user.username}) 为 ${LEVEL_NAMES[result.access_level]}`);\n  else console.error(`❌ 失败:`, result.message || JSON.stringify(result));\n}\n\nasync function updateMember(projectId, userName, level) {\n  const user = await findUsers(userName);\n  const body = new URLSearchParams({ access_level: String(LEVEL_MAP[level]) }).toString();\n  const r = await writeWithRetry(`${GITLAB}/api/v4/projects/${projectId}/members/${user.id}`, 'PUT', body);\n  const result = await r.json();\n  if (r.ok) console.log(`✅ 已更新 ${user.name} (@${user.username}) 为 ${LEVEL_NAMES[result.access_level]}`);\n  else console.error(`❌ 失败:`, result.message || JSON.stringify(result));\n}\n\nasync function removeMember(projectId, userName) {\n  const user = await findUsers(userName);\n  const r = await writeWithRetry(`${GITLAB}/api/v4/projects/${projectId}/members/${user.id}`, 'DELETE');\n  if (r.ok || r.status === 204) console.log(`✅ 已移除 ${user.name} (@${user.username})`);\n  else { const t = await r.text(); console.error(`❌ 失败:`, t.substring(0, 200)); }\n}"}]}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":129,"output":1037,"cacheRead":75008,"cacheWrite":0,"totalTokens":76174,"cost":{"input":0.00001806,"output":0.00029036000000000003,"cacheRead":0.002100224,"cacheWrite":0,"total":0.0024086439999999997}},"stopReason":"toolUse","timestamp":1779336355203,"responseId":"86bde9e1-dda7-4497-a812-4b3b899aa804"}}

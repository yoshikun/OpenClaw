og('\\n=== 表单 ===');\ninfo.forms.forEach(f => console.log(`  id=${f.id} action=${f.action} method=${f.method}`));\n\n// Try clicking ldap or oauth links\nconst ldapLinks = info.links.filter(l => \n  l.href && (l.href.includes('ldap') || l.href.includes('saml') || l.href.includes('oauth') || l.href.includes('auth') || l.href.includes('cas'))\n);\nif (ldapLinks.length > 0) {\n  console.log('\\n=== 外部认证链接 ===');\n  ldapLinks.forEach(l => console.log(`  ${l.text} -> ${l.href}`));\n}\n\n// Check if there's a standard login form\nconst formHtml = await page.evaluate(() => {\n  const f = document.querySelector('form');\n  return f ? f.innerHTML.substring(0, 2000) : 'no form found';\n});\nconsole.log('\\n=== 表单 HTML (前2000字) ===');\nconsole.log(formHtml);\n\nawait browser.close();\n","path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\_gitlab_debug_login.mjs"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":31,"output":725,"cacheRead":46080,"cacheWrite":0,"totalTokens":46836,"cost":{"input":0.00000434,"output":0.000203,"cacheRead":0.00129024,"cacheWrite":0,"total":0.00149758}},"stopReason":"toolUse","timestamp":1779335835955,"responseId":"cc108338-3cc2-43b7-940a-4d3299b7a2b5"}}

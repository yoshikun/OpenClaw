{"type":"message","id":"52990e6f","parentId":"5a5e86ff","timestamp":"2026-05-19T02:39:18.932Z","message":{"role":"assistant","content":[{"type":"text","text":"点提交没触发 POST，说明提交不是通过 preset API，而是修改主页面的 hidden input，最终随需求提交一起发出。这意味着**预设子工作项的修改是存到模板配置里的，需要管理后台来操作**。\n\n换策略——直接调用 TAPD 的 `save_preset_items` API（从 JS 源码里找到了 workitem_template 相关接口）："},{"type":"toolCall","id":"toolu_vrtx_01KGSKYSuC4mohSqQrwMXFfn","name":"write","arguments":{"path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\tapd_save_preset.mjs","content":"// 通过 TAPD API 保存 CCG 玩法模板的预设子工作项\n// 在现有13项基础上增加：客户端(叶枝君) + 服务端(胡新雷)\nimport { readFileSync } from 'fs';\nimport https from 'https';\n\nconst cookies = JSON.parse(readFileSync('tapd_cookies.json', 'utf8'));\nconst cookieStr = cookies.map(c => `${c.name}=${c.value}`).join('; ');\n\nfunction request(options, body) {\n  return new Promise((resolve, reject) => {\n    const req = https.request(options, res => {\n      let data = '';\n      res.on('data', c => data += c);\n      res.on('end', () => resolve({ status: res.statusCode, body: data }));\n      res.on('error', reject);\n    });\n    req.on('error', reject);\n    if (body) req.write(body);\n    req.end();\n  });\n}\n\nfunction get(path) {\n  return request({ host: 'www.tapd.cn', path, method: 'GET', headers: { Cookie: cookieStr, 'User-Agent': 'Mozilla/5.0' } });\n}\n\nfunction post(path, data) {\n  const body = typeof data === 'string' ? data : new URLSearchParams(data).toString();\n  return request({\n    host: 'www.tapd.cn', path, method: 'POST',\n    headers: {\n      Cookie: cookieStr,\n      'User-Agent': 'Mozilla/5.0',\n      'Content-Type': 'application/x-www-form-urlencoded',\n      'Content-Length': Buffer.byteLength(body),\n      'X-Requested-With': 'XMLHttpRequest',\n      'Referer': 'https://www.tapd.cn/31253609/prong/stories/add?workitem_type_id=1131253609001000049'\n    }\n  }, body);\n}\n\n// 当前的13个预设子工作项\nconst currentItems = [\n  { id: \"1131253609001003973\", name: \"原画\",    typeId: \"1131253609001000039\", templateId: \"1131253609001000039\", owner: \"靳应桥;阳矾;\" },\n  { id: \"1131253609001003974\", name: \"UI\",      typeId: \"1131253609001000028\", templateId: \"1131253609001000039\", owner: \"张龙慎;\" },\n  { id: \"1131253609001003975\", name: \"UI验收\",  typeId: \"1131253609001000031\", templateId: \"1131253609001000039\", owner: \"张龙慎;\" },\n  { id: \"1131253609001003976\", name: \"动作\",    typeId: \"1131253609001000047\", templateId: \"1131253609001000039\", owner: \"王晓松;\" },\n  { id: \"1131253609001003977\", name: \"特效\",    typeId: \"1131253609001000038\", templateId: \"1131253609001000039\", owner: \"肖和;\" },\n  { id: \"1131253609001003978\", name: \"特效验收\",typeId: \"1131253609001000031\", templateId: \"1131253609001000039\", owner: \"肖和;\" },\n  { id: \"1131253609001003979\", name: \"策划\",    typeId: \"1131253609001000041\", templateId: \"1131253609001000010\", owner: \"吴美霞;傅一然;温佳音;\" },\n  { id: \"1131253609001003980\", name: \"Lua\",     typeId: \"1131253609001000033\", templateId: \"1131253609001000010\", owner: \"\" },\n  { id: \"1131253609001003981\", name: \"Lua验收\", typeId: \"1131253609001000034\", templateId: \"1131253609001000010\", owner: \"\" },\n  { id: \"1131253609001003982\", name: \"服务端\",  typeId: \"1131253609001000043\", templateId: \"1131253609001000010\", owner: \"胡新雷;\" },  // 更新负责人\n  { id: \"1131253609001003983\", name: \"音效\",    typeId: \"1131253609001000032\", templateId: \"1131253609001000040\", owner: \"\" },\n  { id: \"1131253609001003984\", name: \"动效\",    typeId: \"1131253609001000038\", templateId: \"1131253609001000039\", owner: \"\" },\n  { id: \"1131253609001003985\", name: \"QA\",      typeId: \"1131253609001000031\", templateId: \"1131253609001000039\", owner: \"周以天;\" },\n];\n\n// 新增：客户端（叶枝君负责）\n// 客户端对应 ClientStory 类型，需要找到对应的 typeId\n// 从之前的1V1模板数据：客户端=[12]，typeId=1131253609001000046，templateId待确认\n// CCG 的 workitemtype_childs_map 包含 1131253609001000046\n\nconst newItems = [\n  ...currentItems,\n  { id: \"new_client\", name: \"客户端\", typeId: \"1131253609001000046\", templateId: \"1131253609001000039\", owner: \"叶枝君;\" },\n];\n\n// 先获取 token/csrf\nconst indexResp = await get('/31253609/prong/stories/add?workitem_type_id=1131253609001000049');\nconst tokenMatch = indexResp.body.match(/csrf_token['\":\\s]+['\"]([^'\"]+)['\"]/);\nconst token = tokenMatch?.[1];\nconsole.log('CSRF token:', token);\n\n// 构建请求体\nconst params = new URLSearchParams();\nparams.append('workspace_id', '31253609');\nparams.append('template_id', '1131253609001000047');  // 1V1模板是这个，CCG的模板ID需要确认\n\n// 找 CCG 模板真正的模板ID\nconst presetResp = await get('/api/entity/workitem_template/get_preset_items?workspace_id=31253609&template_id=1131253609001000047');\nconst presetData = JSON.parse(presetResp.body);\nconsole.log('Preset API response:', JSON.stringify(presetData).substring(0, 500));\n"}}],"api":"openai-completions","provider":"openai-proxy","model":"giant-claude-sonnet-4-6","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779158329780,"responseId":"chatcmpl-b6d0f638-c625-451e-9123-4e483ab52269"}}

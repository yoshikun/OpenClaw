=\"workitem-prefixname j-workitem-title--prefix-span\" title=\"\"></span>\n                <span class=\"workitem-middle j-workitem-title--middle-span\">-</span>\n              </span>\n            \n                    <input class=\"workitem-template-name j-row-cell--name\" required=\"required\" name=\"原画\" title=\"\" position=\"left\" type=\"text\" data-placeholder=\"预设子工作项\" placeholder=\"预设子工作项\" value=\"原画\">\n                    \n              <span class=\"j-workitem-title--suffix\" style=\"display: none;\">\n              -\n              <span class=\"workitem-suffixname j-workitem-title--suffix-span\" title=\"\"></span>\n              </span>\n            \n                </div></div>\n                  \n                    <div class=\"row-cell field-operate\">\n                <div class=\"row-operat-right\">\n                    <i class=\"font font-public font-public-add-subchild j-insert-row\" style=\"display: none;\"></i>\n                    <i class=\"font font-close j-remove-row\"></i>\n                </div>\n            </div>\n                  \n            </div>\n            <div idx=\"1\" level=\"0\" class=\"tree-row\" style=\"display: flex;\">\n              \n                    <div class=\"row-cell field-relate_workitem_type_id\"><div class=\"row-workitem-baseinfo\" style=\"padding-left:0px;\">\n                    <span class=\"font font-fold j-toggle-row\" title=\"\" style=\"opacity: 0; cursor: default;\"></span>\n                    \n                    <div class=\"dropdown workitem-type-select j-workitem-type-select j-row-cell--relate_workitem_type_id disabled\" data-dropdown=\"\" title=\"\">\n                        <a href=\"#\" class=\"dropdown-toggle j-workitem-icon-container\" data-type-id=\"1131253609001000028\">\n                            <span class=\"workitem-icon workitem-icon__mini\" style=\"background-color:#b8e986\">A</span>\n                        </a>\n                        \n\n\n[464 more lines in file. Us
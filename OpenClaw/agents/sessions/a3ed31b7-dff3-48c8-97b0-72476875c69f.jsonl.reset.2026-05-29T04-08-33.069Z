{"type":"message","id":"a685529d","parentId":"3c118ae4","timestamp":"2026-05-28T03:13:02.275Z","message":{"role":"toolResult","toolCallId":"call_00_NdXcruEF8vBgOrIuH3b85941","toolName":"read","content":[{"type":"text","text":"/**\n * TAPD 创建缺陷（Bug）脚本\n * 工作区：31253609（月圆之夜）\n */\n\nimport { chromium } from 'playwright';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\nconst WS_DIR = path.resolve(__dirname, '..');\nconst COOKIES_FILE = path.join(WS_DIR, 'tapd_cookies.json');\nconst WORKSPACE_ID = '31253609';\nconst BUG_CREATE_URL = `https://www.tapd.cn/${WORKSPACE_ID}/bugtrace/bugs/add`;\n\nconst STEALTH_SCRIPT = `\n  Object.defineProperty(navigator, 'webdriver', { get: () => undefined });\n  Object.defineProperty(navigator, 'plugins', { get: () => [1, 2, 3, 4, 5] });\n  Object.defineProperty(navigator, 'languages', { get: () => ['zh-CN', 'zh', 'en'] });\n  Object.defineProperty(navigator, 'hardwareConcurrency', { get: () => 8 });\n  window.chrome = { runtime: {} };\n`;\n\n/**\n * 创建 Bug\n * @param {Object} opts\n * @param {string} opts.title - 标题（必填）\n * @param {string} [opts.handler='叶枝君'] - 处理人（姓名）\n * @param {string} [opts.cc='周以天;'] - 抄送（姓名;格式）\n * @param {string} [opts.priority='P2'] - 优先级\n * @param {string} [opts.version='【1V1】正式版本V2.0'] - 发现版本\n * @param {string} [opts.module='1V1'] - 模块\n * @param {string} [opts.branch='YZY_1V1 V1.0 Beta'] - 研发分支\n * @param {string} [opts.description=''] - 描述\n * @param {string[]} [opts.attachments=[]] - 附件路径列表\n * @returns {Promise<string>} Bug 详情页 URL\n */\nexport async function createBug(opts = {}) {\n  const {\n    title,\n    handler = '叶枝君',\n    cc = '周以天;',\n    priority = 'P2',\n    version = '【1V1】正式版本V2.0',\n    module: mod = '1V1',\n    branch = 'YZY_1V1 V1.0 Beta',\n    description = '',\n    attachments = [],\n  } = opts;\n\n  if (!title) throw new Error('title is required');\n\n  // 读取 cookies\n  if (!fs.existsSync(COOKIES_FILE)) {\n    throw new Error(`Cookies file not found: ${COOKIES_FILE}`);\n  }\n  const cookies = JSON.parse(fs.readFileSync(COOKIES_FILE, 'utf8'));\n\n  const browser = await chromium.launch({\n\n[175 more lines in file. Use offset=61 to continue.]"}],"isError":false,"timestamp":1779937982275}}

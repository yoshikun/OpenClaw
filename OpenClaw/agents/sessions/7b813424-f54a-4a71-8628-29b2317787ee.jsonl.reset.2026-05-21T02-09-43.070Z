{"type":"message","id":"168fa22c","parentId":"cb9206c5","timestamp":"2026-05-20T13:27:28.271Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"I tried to use the edit tool incorrectly. Let me just rewrite the file with the fix - change `plain_text` to `lark_md` for the header row content.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_00_3Xbk7vMkmy7IxFL4dAAp4096","name":"write","arguments":{"path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\feishu_send_log_card.mjs","content":"/**\n * 发送操作日志飞书卡片（Interactive Card 格式，带表格）\n */\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\nconst WS = path.resolve(__dirname, '..');\nconst LOG_FILE = path.join(WS, 'memory', 'operation-log.json');\n\nconst APP_ID = 'cli_a9458ff380b99ccb';\nconst APP_SECRET = 'Qs3NVpgH7h4UP7cVPfZRHh72E3jEOGKv';\n\nasync function getToken() {\n  const r = await fetch('https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal', {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify({ app_id: APP_ID, app_secret: APP_SECRET }),\n  });\n  const d = await r.json();\n  if (d.code !== 0) throw new Error(`Token failed: ${JSON.stringify(d)}`);\n  return d.tenant_access_token;\n}\n\nfunction makeCard(logs) {\n  const recent = logs.slice(-5).reverse();\n  const headerRow = {\n    tag: 'column_set',\n    flex_mode: 'none',\n    background_style: 'grey',\n    columns: [\n      { tag: 'column', width: 'weighted', weight: 2, vertical_align: 'center',\n        elements: [{ tag: 'lark_md', content: '**人**' }] },\n      { tag: 'column', width: 'weighted', weight: 2, vertical_align: 'center',\n        elements: [{ tag: 'lark_md', content: '**事情**' }] },\n      { tag: 'column', width: 'weighted', weight: 3, vertical_align: 'center',\n        elements: [{ tag: 'lark_md', content: '**详情**' }] },\n      { tag: 'column', width: 'weighted', weight: 1, vertical_align: 'center',\n        elements: [{ tag: 'lark_md', content: '**结果**' }] },\n    ]\n  };\n\n  const dataRows = recent.map(l => ({\n    tag: 'column_set',\n    flex_mode: 'none',\n    background_style: 'default',\n    columns: [\n      { tag: 'column', width: 'weighted', weight: 2, vertical_align: 'center',\n        elements: [{ tag: 'lark_md', content: l.sender }] },\n      { tag: 'column', width: 'weighted', weight: 2, vertical_align: 'center',\n        elements: [{ tag: 'lark_md', content: l.type }] },\n      { tag: 'column', width: 'weighted', weight: 3, vertical_align: 'center',\n        elements: [{ tag: 'lark_md', content: l.detail || '-' }] },\n      { tag: 'column', width: 'weighted', weight: 1, vertical_align: 'center',\n        elements: [{ tag: 'lark_md', content: l.result || '-' }] },\n    ]\n  }));\n\n  return {\n    config: { wide_screen_mode: true },\n    header: {\n      title: { tag: 'plain_text', content: `最近 ${recent.length} 条操作日志` },\n      template: 'blue',\n    },\n    elements: [headerRow, ...dataRows],\n  };\n}\n\nconst targetId = process.argv[2] || 'oc_59afc01122ec0cd04ca4d8c5103c7a77';\nconst targetType = process.argv[3] === 'user' ? 'open_id' : 'chat_id';\n\nconst logs = JSON.parse(fs.readFileSync(LOG_FILE, 'utf8'));\nconst card = makeCard(logs);\n\nconst token = await getToken();\nconst r = await fetch(`https://open.feishu.cn/open-apis/im/v1/messages?receive_id_type=${targetType}`, {\n  method: 'POST',\n  headers: {\n    'Content-Type': 'application/json',\n    'Authorization': `Bearer ${token}`,\n  },\n  body: JSON.stringify({\n    receive_id: targetId,\n    msg_type: 'interactive',\n    content: JSON.stringify(card),\n  }),\n});\n\nconst d = await r.json();\nif (d.code === 0) {\n  console.log('卡片已发送 ✓');\n} else {\n  console.error('发送失败:', JSON.stringify(d, null, 2));\n}\n"}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":417,"output
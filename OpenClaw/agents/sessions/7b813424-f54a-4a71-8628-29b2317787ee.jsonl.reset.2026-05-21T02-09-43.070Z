            waited += 500;\n-243             const curUrl = page.url();\n-244             if (curUrl !== beforeUrl) break;\n-245           }\n-246           const subStoryUrl = page.url();\n-247           if (subStoryUrl !== beforeUrl) {\n-248             console.log(`    ✅ Sub-item created: ${subStoryUrl}`);\n+255           if (result.status === 200) {\n+256             const subId = result.extractedId || result.storyUrlInPage || 'unknown';\n+257             console.log(`    ✅ Sub-item '${item.name}' created (id=${subId}, finalUrl=${result.finalUrl})`);\n 249           } else {\n-250             const errText = await page.locator('.error-msg, .alert-danger, [class*=\"invalid\"]').first().textContent().catch(() => '');\n-251             console.warn(`    ⚠️ Sub-item URL unchanged. Error hint: ${errText.trim().substring(0, 100)}`);\n+259             console.warn(`    ⚠️ Sub-item '${item.name}' status=${result.status}`);\n 252           }\n+261 \n 253           await page.waitForTimeout(500);\n 254         } catch(e) {\n 255           console.error(`    ❌ Failed to create sub-item ${item.name}:`, e.message);\n 256         }\n     ...","firstChangedLine":196},"isError":false,"timestamp":1779270408241}}

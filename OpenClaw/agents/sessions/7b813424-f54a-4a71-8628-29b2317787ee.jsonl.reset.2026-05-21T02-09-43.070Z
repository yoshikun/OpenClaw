{"type":"message","id":"07bab3fd","parentId":"8f2576db","timestamp":"2026-05-20T10:20:34.460Z","message":{"role":"assistant","content":[{"type":"text","text":"但其实我想先搞清楚——正确提交时 POST body 里的 `workitem_type` 字段名是什么。让我先看看页面里的隐藏字段，再去提交："},{"type":"toolCall","id":"toolu_vrtx_01TfUck51WRuaNTrDX111GNt","name":"write","arguments":{"path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\inspect_substory_form2.mjs","content":"import { chromium } from 'playwright';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\nconst WS_DIR = path.resolve(__dirname, '..');\nconst cookies = JSON.parse(fs.readFileSync(path.join(WS_DIR, 'tapd_cookies_yezhijun.json'), 'utf8'));\n\nconst STORY_ID = '1131253609001037992'; // 当前测试单\nconst browser = await chromium.launch({ headless: false, args: ['--no-sandbox'] });\nconst context = await browser.newContext();\nawait context.addCookies(cookies);\nconst page = await context.newPage();\n\n// 监听提交请求，看真实 POST body\npage.on('request', req => {\n  if (req.method() === 'POST' && req.url().includes('stories/add')) {\n    console.log('POST URL:', req.url());\n    console.log('POST body:', req.postData());\n  }\n});\n\nconst subUrl = `https://www.tapd.cn/31253609/prong/stories/add?parent_id=${STORY_ID}&workitem_type=CLIENT`;\nawait page.goto(subUrl, { waitUntil: 'networkidle', timeout: 30000 });\nawait page.waitForTimeout(2000);\n\n// 列出所有隐藏 input 字段\nconst hiddenFields = await page.evaluate(() => {\n  const inputs = document.querySelectorAll('input[type=\"hidden\"], select, input:not([type=\"hidden\"])');\n  const result = [];\n  inputs.forEach(el => {\n    result.push({ tag: el.tagName, type: el.type, name: el.name, id: el.id, value: el.value?.substring(0, 50) });\n  });\n  return result;\n});\nconsole.log('All form fields:');\nhiddenFields.forEach(f => console.log(`  ${f.tag}[${f.type}] name=\"${f.name}\" id=\"${f.id}\" value=\"${f.value}\"`));\n\n// 填字段并手动触发提交，捕获 POST body\nawait page.fill('#StoryName', '[客户端] 检查POST body');\nawait page.selectOption('#StoryVersion', { label: '【1V1】正式版本V2.0' }).catch(() => {});\nconst ownerInput = page.locator('#StoryOwnerValue').first();\nawait ownerInput.click();\nawait ownerInput.type('王亮亮', { delay: 100 });\nawait page.waitForTimeout(2000);\nawait page.keyboard.press('Enter');\nawait page.waitForTimeout(500);\n\n// 用 Playwright 直接提交表单拦截 body\nconst formBody = await page.evaluate(() => {\n  const form = document.getElementById('FormStory');\n  const fd = new FormData(form);\n  const obj = {};\n  for (const [k, v] of fd.entries()) {\n    if (!k.includes('description') && !k.includes('content')) obj[k] = v;\n  }\n  return obj;\n});\nconsole.log('\\nForm body (key fields):');\n// 找 workitem_type 相关\nObject.entries(formBody).forEach(([k, v]) => {\n  if (k.includes('workitem') || k.includes('type') || k.includes('parent') || k.includes('Template') || k.includes('token')) {\n    console.log(`  ${k} = ${v}`);\n  }\n});\n\nawait browser.close();\n"}}],"api":"openai-completions","provider":"openai-proxy","model":"giant-claude-sonnet-4-6","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779272413552,"responseId":"chatcmpl-20f16762-1720-43d6-8ca1-1080af907f67"}}

visLen('事情'));\n  const detailPad = Math.max(...recent.map(l => visLen(l.detail)), visLen('详情'));\n\n  console.log(`最近 ${recent.length} 条日志：`);\n  const sep = ' │ ';\n  console.log('  ' + padVis('人', namePad) + sep + padVis('事情', typePad) + sep + padVis('详情', detailPad) + sep + '结果');\n  console.log('  ' + '─'.repeat(namePad) + '─' + '┼' + '─'.repeat(typePad) + '─' + '┼' + '─'.repeat(detailPad) + '─' + '┼' + '──');\n  recent.forEach(l => {\n    console.log('  ' + padVis(l.sender, namePad) + sep + padVis(l.type, typePad) + sep + padVis(l.detail, detailPad) + sep + l.result);\n  });"}]}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":195,"output":876,"cacheRead":242176,"cacheWrite":0,"totalTokens":243247,"cost":{"input":0.000027300000000000003,"output":0.00024528,"cacheRead":0.0067809279999999994,"cacheWrite":0,"total":0.007053507999999999}},"stopReason":"toolUse","timestamp":1779283250128,"responseId":"d4466a7b-91d7-4245-9c9d-78c45e38ae59"}}

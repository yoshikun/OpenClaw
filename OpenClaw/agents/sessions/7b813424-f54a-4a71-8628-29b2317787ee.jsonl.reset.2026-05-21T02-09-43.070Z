{"type":"message","id":"fa1d5f83","parentId":"7bf991fc","timestamp":"2026-05-20T10:27:22.555Z","message":{"role":"assistant","content":[{"type":"text","text":"POST body 格式不对，用 GET 方式试试，模仿之前捕获到的 XHR："},{"type":"toolCall","id":"toolu_vrtx_014ChZgztkWcAbNeyNzKWRj9","name":"write","arguments":{"path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\get_substory_types2.mjs","content":"import { chromium } from 'playwright';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\nconst WS_DIR = path.resolve(__dirname, '..');\nconst cookies = JSON.parse(fs.readFileSync(path.join(WS_DIR, 'tapd_cookies_yezhijun.json'), 'utf8'));\n\nconst subIds = ['1131253609001037716', '1131253609001037717', '1131253609001037718'];\nconst WORKSPACE_ID = '31253609';\n\nconst browser = await chromium.launch({ headless: true, args: ['--no-sandbox'] });\nconst context = await browser.newContext();\nawait context.addCookies(cookies);\nconst page = await context.newPage();\n\n// 先导航到 TAPD 建立 session\nawait page.goto('https://www.tapd.cn', { waitUntil: 'networkidle', timeout: 15000 });\nawait page.waitForTimeout(1000);\n\nfor (const id of subIds) {\n  const result = await page.evaluate(async ({ sid, wsId }) => {\n    const resp = await fetch('/api/aggregation/workitem_aggregation/common_get_info', {\n      method: 'POST',\n      headers: {\n        'Content-Type': 'application/json',\n        'X-Requested-With': 'XMLHttpRequest',\n      },\n      body: JSON.stringify({ workspace_id: wsId, story_id: sid })\n    });\n    const text = await resp.text();\n    return text;\n  }, { sid: id, wsId: WORKSPACE_ID });\n  \n  try {\n    const data = JSON.parse(result);\n    const story = data?.data?.get_info_ret?.data?.Story;\n    if (story) {\n      console.log(`\\nStory ${id}:`);\n      console.log(`  name: ${story.name}`);\n      console.log(`  workitem_type_id: ${story.workitem_type_id}`);\n      console.log(`  owner: ${story.owner}`);\n    } else {\n      // 尝试另一个接口\n      const resp2 = await page.evaluate(async ({ sid, wsId }) => {\n        const r = await fetch(`/api/aggregation/workitem_aggregation/get_info?workspace_id=${wsId}&story_id=${sid}`, {\n          headers: { 'X-Requested-With': 'XMLHttpRequest' }\n        });\n        return r.text();\n      }, { sid: id, wsId: WORKSPACE_ID });\n      const data2 = JSON.parse(resp2);\n      const story2 = data2?.data?.get_workitem_basic_info_ret?.data;\n      console.log(`\\nStory ${id} (via get_info):`);\n      if (story2) {\n        console.log(`  name: ${story2.name}`);\n        console.log(`  workitem_type_id: ${story2.workitem_type_id}`);\n      } else {\n        console.log('  raw:', resp2.substring(0, 200));\n      }\n    }\n  } catch(e) {\n    console.log(`Parse error for ${id}:`, result.substring(0, 200));\n  }\n}\n\nawait browser.close();\n"}}],"api":"openai-completions","provider":"openai-proxy","model":"giant-claude-sonnet-4-6","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779272826396,"responseId":"chatcmpl-800f3c1e-2d78-4d9b-9eba-8b611b3ef237"}}

{"type":"message","id":"65fbf49d","parentId":"47c475e3","timestamp":"2026-05-20T09:23:47.587Z","message":{"role":"assistant","content":[{"type":"text","text":"找到了！workitem type 对应关系：\n- **客户端** → `CLIENT`\n- **策划** → `MASTER`  \n- **QA验收** → `QA`\n\n现在完整方案清晰了：\n1. 创建主需求时清空 TemplateId\n2. 创建成功后，用 `parent_id=<STORY_ID>&workitem_type=CLIENT/MASTER/QA` 分别创建3个子需求\n\n现在更新 `create_story.mjs`，加入创建子需求的逻辑："},{"type":"toolCall","id":"toolu_vrtx_01JkP55YzjPYtmpgwvj1DCRN","name":"read","arguments":{"path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\create_story.mjs"}}],"api":"openai-completions","provider":"openai-proxy","model":"giant-claude-sonnet-4-6","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779269021590,"responseId":"chatcmpl-558fd77b-5c38-4c68-b06b-390c53d6e0ce"}}
{"type":"message","id":"7f45f02a","parentId":"65fbf49d","timestamp":"2026-05-20T09:23:47.603Z","message":{"role":"toolResult","toolCallId":"toolu_vrtx_01JkP55YzjPYtmpgwvj1DCRN","toolName":"read","content":[{"type":"text","text":"/**\n * TAPD 创建需求（Story）脚本\n * 工作区：31253609（月圆之夜）\n * 账号：叶枝君\n * \n * 策略：不选择模板（模板选择会导致提交失败），先创建基础需求，\n * 创建成功后再从需求详情页补充处理人等信息。\n */\n\nimport { chromium } from 'playwright';\nimport fs from 'fs';\nimport path from 'path';\nimport { fileURLToPath } from 'url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\nconst WS_DIR = path.resolve(__dirname, '..');\nconst COOKIES_FILE = path.join(WS_DIR, 'tapd_cookies_yezhijun.json');\nconst WORKSPACE_ID = '31253609';\nconst STORY_CREATE_URL = `https://www.tapd.cn/${WORKSPACE_ID}/prong/stories/add`;\n\nconst STEALTH_SCRIPT = `\n  Object.defineProperty(navigator, 'webdriver', { get: () => undefined });\n  Object.defineProperty(navigator, 'plugins', { get: () => [1, 2, 3, 4, 5] });\n  Object.defineProperty(navigator, 'languages', { get: () => ['zh-CN', 'zh', 'en'] });\n  Object.defineProperty(navigator, 'hardwareConcurrency', { get: () => 8 });\n  window.chrome = { runtime: {} };\n`;\n\n// 1V1 模板子工作项配置\n// 全部 17 个子工作项的索引（0-based，对应页面 checkbox 顺序）\n// client: 客户端[12], 策划[14], QA[16]\n// server: 服务端[13], 策划[14], QA[16]\n// design: 策划[14], QA[16]\n// ui: UI[7], UI验收[8], 策划[14], QA[16]\n// motion: 2D动作[2], 策划[14], QA[16]\n// audio: 音频[11], 策划[14], QA[16]\nconst TEMPLATE_SUB_ITEMS = {\n  client: [12, 14, 16],\n  server: [13, 14, 16],\n  design: [14, 16],\n  ui: [7, 8, 14, 16],\n  motion: [2, 14, 16],\n  audio: [11, 14, 16],\n};\n\nexport async function createStory(opts = {}) {\n  const {\n    title = '测试需求单 - 请忽略',\n    priority = 'P2',\n    module: mod = '1V1',\n    version = '【1V1】正式版本V2.0',\n    handler = '周以天',\n    description = '',\n    template = 'client',\n  } = opts;\n\n  if (!title) throw new Error('title is required');\n  if (!fs.existsSync(COOKIES_FILE)) throw new Error(`Cookies file not found: ${COOKIES_FILE}`);\n\n  const cookies = JSON.parse(fs.readFileSync(COOKIES_FILE, 'utf8'));\n\n  const browser = await chromium.launch({\n    headless: false,\n    args: [\n      '--no-sandbox',\n      '--disable-blink-features=AutomationControlled',\n      '--user-agent=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',\n    ],\n  });\n\n  const context = await browser.newContext({\n    userAgent: 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',\n  });\n\n  await context.addInitScript(STEALTH_SCRIPT);\n  await context.addCookies(cookies);\n\n  const page = await context.newPage();\n\n  try {\n    // Step 1: Create story without template\n    console.log('1/4 Opening story create page...');\n    await page.goto(STORY_CREATE_URL, { waitUntil: 'networkidle', timeout: 30000 });\n    if (page.url().includes('login')) throw new Error('TAPD session expired');\n    await page.waitForTimeout(2000);\n\n    console.log('2/4 Filling fields...');\n    \n    // 清空模板选择，避免自动生成 17 个预设子工作项\n    // 直接通过 JS 把 TemplateId 展示属性打开并设为空，然后取消模板选中\n    try {\n      await page.evaluate(() => {\n        const sel = document.getElementById('TemplateId');\n        if (sel) {\n          // 移除 required 属性，直接设为空值\n          sel.removeAttribute('required');\n          sel.value = '';\n          // 添加一个空选项并选中\n          const emptyOpt = document.createElement('option');\n          emptyOpt.value = '';\n          emptyOpt.text = '无模板';\n          sel.insertBefore(emptyOpt, sel.firstChild);\n          sel.selectedIndex = 0;\n          // 触发 change 事件\n          sel.dispatchEvent(new Event('change', { bubbles: true }));\n        }\n      });\n      console.log('  Template cleared (no preset sub-items)');\n      await page.waitForTimeout(1000);\n    } catch(e) {\n      console.warn('  Could not clear template:', e.message);\n    }\n    \n    await page.fill('#StoryName', title);\n    await page.selectOption('#StoryPriority', priority);\n    await page.selectOption('#StoryModule', { label: mod });\n    await page.selectOption('#StoryVersion', { label: version });\n\n    if (description) {\n      try {\n        const descFrame = page.frameLocator('iframe#StoryDescription_ifr').first();\n        await descFrame.locator('body').fill(description);\n      } catch (e) {\n        console.warn('Description field not found:', e.message);\n      }\n    }\n\n    console.log('3/4 Submitting...');\n    const [response] = await Promise.all([\n      page.waitForNavigation({ timeout: 30000 }),\n      page.locator('#btn_save_view').click(),\n    ]);\n\n    const storyUrl = page.url();\n    console.log('4/4 Created, URL:', storyUrl);\n\n    // Extract story ID\n    const storyIdMatch = storyUrl.match(/stories\\/(\\d+)/) || storyUrl.match(/story\\/(\\d+)/) || storyUrl.match(/story\\/detail\\/(\\d+)/);\n    let storyId, detailUrl;\n    \n    if (storyIdMatch) {\n      storyId = storyIdMatch[1];\n      detailUrl = `https://www.tapd.cn/${WORKSPACE_ID}/prong/stories/view/${storyId}`;\n    } else {\n      // URL might be tapd_fe format\n      const feMatch = storyUrl.match(/story\\/detail\\/(\\d+)/);\n      if (feMatch) {\n        storyId = feMatch[1];\n        detailUrl = storyUrl;\n      } else {\n        storyId = 'unknown';\n        detailUrl = storyUrl;\n      }\n    }\n\n    console.log(`\\n✅ Story created: ${detailUrl}`);\n    return { url: detailUrl, storyId };\n\n  } finally {\n    await browser.close();\n  }\n}\n\n// CLI entry\nif (process.argv[1] === fileURLToPath(import.meta.url)) {\n  const title = process.argv[2] || '测试需求单 - 请忽略';\n  createStory({ title })\n    .then(result => {\n      console.log('SUCCESS:', JSON.stringify(result));\n      process.exit(0);\n    })\n    .catch(err => {\n      console.error('FAILED:', err.message);\n      process.exit(1);\n    });\n}\n"}],"isError":false,"timestamp":1779269027603}}
{"type":"message","id":"e8132efe","parentId":"7f45f02a","timestamp":"2026-05-20T09:24:10.499Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"toolu_vrtx_014QGwj4zVT7htGFwY3Dnyfe","name":"edit","arguments":{"path":"C:\\Users\\yyzypublic\\.openclaw\\workspace\\scripts\\create_story.mjs","edits":[{"oldText":"    console.log(`\\n✅ Story created: ${detailUrl}`);\n    return { url: detailUrl, storyId };\n\n  } finally {\n    await browser.close();\n  }\n}","newText":"    console.log(`\\n✅ Story created: ${detailUrl}`);\n\n    // Step 5: 创建子工作项（根据模板配置）\n    const subItemConfig = {\n      client: [\n        { type: 'CLIENT', name: '客户端' },\n        { type: 'MASTER', name: '策划' },\n        { type: 'QA', name: 'QA验收' },\n      ],\n      server: [\n        { type: 'SERVERS', name: '服务器' },\n        { type: 'MASTER', name: '策划' },\n        { type: 'QA', name: 'QA验收' },\n      ],\n      design: [\n        { type: 'MASTER', name: '策划' },\n        { type: 'QA', name: 'QA验收' },\n      ],\n      ui: [\n        { type: 'UI', name: 'UI' },\n        { type: 'ARTQA', name: 'UI验收' },\n        { type: 'MASTER', name: '策划' },\n        { type: 'QA', name: 'QA验收' },\n      ],\n      motion: [\n        { type: 'ACTION', name: '2D动作' },\n        { type: 'MASTER', name: '策划' },\n        { type: 'QA', name: 'QA验收' },\n      ],\n      audio: [\n        { type: 'AUDIO', name: '音频' },\n        { type: 'MASTER', name: '策划' },\n        { type: 'QA', name: 'QA验收' },\n      ],\n    };\n\n    const subItems = subItemConfig[template] || subItemConfig.client;\n    console.log(`\\n5/${4 + subItems.length} Creating ${subItems.length} sub-items for template '${template}'...`);\n\n    if (storyId && storyId !== 'unknown') {\n      for (let i = 0; i < subItems.length; i++) {\n        const item = subItems[i];\n        console.log(`  ${i + 1}/${subItems.length} Creating sub-item: ${item.name} (${item.type})`);\n        try {\n          const subUrl = `https://www.tapd.cn/${WORKSPACE_ID}/prong/stories/add?parent_id=${storyId}&workitem_type=${item.type}`;\n          await page.goto(subUrl, { waitUntil: 'networkidle', timeout: 30000 });\n          await page.waitForTimeout(1500);\n\n          // 清空模板（子需求也不需要预设）\n          await page.evaluate(() => {\n            const sel = document.getElementById('TemplateId');\n            if (sel) {\n              sel.removeAttribute('required');\n              const emptyOpt = document.createElement('option');\n              emptyOpt.value = '';\n              emptyOpt.text = '无模板';\n              sel.insertBefore(emptyOpt, sel.firstChild);\n              sel.selectedIndex = 0;\n              sel.dispatchEvent(new Event('change', { bubbles: true }));\n            }\n          }).catch(() => {});\n          await page.waitForTimeout(800);\n\n          // 填写标题（继承主需求标题）\n          const subTitle = `[${item.name}] ${title}`;\n          await page.fill('#StoryName', subTitle);\n\n          // 提交\n          const [nav] = await Promise.all([\n            page.waitForNavigation({ timeout: 30000 }),\n            page.locator('#btn_save_view').click(),\n          ]);\n          const subStoryUrl = page.url();\n          console.log(`    ✅ Sub-item created: ${subStoryUrl}`);\n          await page.waitForTimeout(500);\n        } catch(e) {\n          console.error(`    ❌ Failed to create sub-item ${item.name}:`, e.message);\n        }\n      }\n    } else {\n      console.warn('  Cannot create sub-items: storyId unknown');\n    }\n\n    return { url: detailUrl, storyId };\n\n  } finally {\n    await browser.close();\n  }\n}"}]}}],"api":"openai-completions","provider":"openai-proxy","model":"giant-claude-sonnet-4-6","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1779269027604,"responseId":"chatcmpl-270e7025-60fc-427e-b8cd-6647e9c1966d"}}

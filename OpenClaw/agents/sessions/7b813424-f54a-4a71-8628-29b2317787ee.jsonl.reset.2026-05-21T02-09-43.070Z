> 255 ? 2 : 1), 0); }\n  function pad(s, w) { return s + ' '.repeat(Math.max(0, w - visLen(s))); }\n\n  const logs = JSON.parse(fs.readFileSync(LOG_FILE, 'utf8'));\n  const recent = logs.slice(-5).reverse();\n\n  const nw = Math.max(visLen('人'), ...recent.map(l => visLen(l.sender)));\n  const tw = Math.max(visLen('事情'), ...recent.map(l => visLen(l.type)));\n  const rw = Math.max(visLen('结果'), ...recent.map(l => visLen(l.result)));\n\n  console.log(`最近 ${recent.length} 条日志：`);\n  console.log(`┌${'─'.repeat(nw + 2)}┬${'─'.repeat(tw + 2)}┬${'─'.repeat(rw + 2)}┐`);\n  console.log(`│ ${pad('人', nw)}  │ ${pad('事情', tw)}  │ ${pad('结果', rw)}  │`);\n  console.log(`├${'─'.repeat(nw + 2)}┼${'─'.repeat(tw + 2)}┼${'─'.repeat(rw + 2)}┤`);\n  recent.forEach((l, i) => {\n    console.log(`│ ${pad(l.sender, nw)}  │ ${pad(l.type, tw)}  │ ${pad(l.result, rw)}  │`);\n    if (i < recent.length - 1) console.log(`├${'─'.repeat(nw + 2)}┼${'─'.repeat(tw + 2)}┼${'─'.repeat(rw + 2)}┤`);\n  });\n  console.log(`└${'─'.repeat(nw + 2)}┴${'─'.repeat(tw + 2)}┴${'─'.repeat(rw + 2)}┘`);"}]}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":4583,"output":1085,"cacheRead":243584,"cacheWrite":0,"totalTokens":249252,"cost":{"input":0.0006416200000000001,"output":0.0003038,"cacheRead":0.006820352,"cacheWrite":0,"total":0.007765772}},"stopReason":"toolUse","timestamp":1779283421949,"responseId":"58591712-6094-498d-9d0a-4e4c7951fcf6"}}

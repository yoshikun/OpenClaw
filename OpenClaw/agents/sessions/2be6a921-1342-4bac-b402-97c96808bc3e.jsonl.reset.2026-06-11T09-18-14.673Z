oogle Play or F-Droid as an alternative\"","timeout":20}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":276,"output":537,"cacheRead":267264,"cacheWrite":0,"totalTokens":268077,"cost":{"input":0.00003864,"output":0.00015036000000000002,"cacheRead":0.007483392,"cacheWrite":0,"total":0.007672392}},"stopReason":"toolUse","timestamp":1781098411769,"responseId":"6cb8afe0-d1c4-4931-94cd-e3c9b2db98d6"}}

{"type":"message","id":"89d980f5","parentId":"1773a2a8","timestamp":"2026-05-27T05:13:10.772Z","message":{"role":"toolResult","toolCallId":"call_00_2fdST9hNQwwo0DKEE5hs5156","toolName":"read","content":[{"type":"text","text":"                    SaveConfig();\n                    SetExecuteState(ExecuteState.Suspend);\n                    Debug.Log(\"-----Jump out the build step-----\");\n                    return;\n                }\n\n                var lastIndex = Config.ExecuteStack.Count - 1;\n                var step = Config.ExecuteStack[lastIndex];\n                Config.ExecuteStack.RemoveAt(lastIndex);\n                if (step != null)\n                {\n                    using (new LogStamp(\"Excute Pipline:\" + step.Name))\n                    {\n                        if (!ExecuteStep(step))\n                        {\n                            SetExecuteState(ExecuteState.Canceled);\n                            TryBatchExitNowIfDone();\n                            return;\n                        }\n                    }\n                }\n            }\n            SetExecuteState(ExecuteState.Succeeded);\n            TryBatchExitNowIfDone();\n        }\n\n        internal static bool ExecuteStep(BuildPipelineStep step)\n        {\n            try\n            {\n                IsBuilding = true;\n                if (step.IsBuildActionValid)\n                {\n                    step.BuildAction?.Invoke();\n                }\n            }\n            catch (Exception e)\n            {\n                throw;\n            }\n            finally\n            {\n                IsBuilding = false;\n            }\n\n            return true;\n        }\n\n        internal static void ExecuteSelected(BuildPipelineLine line)\n        {\n            Config.ExecuteStack.Clear();\n            ExecutePipeline(line, true);\n        }\n\n        internal static void Execute(BuildPipelineLine line)\n        {\n            Config.ExecuteStack.Clear();\n            ExecutePipeline(line, false);\n        }\n\n\n[37 more lines in file. Use offset=280 to continue.]"}],"isError":false,"timestamp":1779858790772}}

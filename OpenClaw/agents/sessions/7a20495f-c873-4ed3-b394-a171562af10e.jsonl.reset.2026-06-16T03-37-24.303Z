" + $proc.StartTime) }","timeout":10}}],"api":"openai-completions","provider":"deepseek","model":"deepseek-v4-flash","usage":{"input":179,"output":583,"cacheRead":172160,"cacheWrite":0,"totalTokens":172922,"cost":{"input":0.00002506,"output":0.00016324000000000002,"cacheRead":0.00482048,"cacheWrite":0,"total":0.00500878}},"stopReason":"toolUse","timestamp":1781505126710,"responseId":"e7c5a9c3-3bd5-4067-8b1f-a7475086a108"}}

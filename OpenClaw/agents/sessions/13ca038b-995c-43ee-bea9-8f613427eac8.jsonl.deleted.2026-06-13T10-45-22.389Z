e)}===============\");\n            if ((ExecuteState)EditorPrefs.GetInt(ExecuteVariable) == ExecuteState.Suspend)\n            {\n                Debug.Log(\"=====Resume the build step=====\");\n                ExecuteContinued();\n            }\n\n            if (Array.IndexOf(Environment.GetCommandLineArgs(), \"-batchmode\") < 0)\n                EditorPrefs.SetBool(BatchExitAfterDonePrefKey, false);\n        }\n\n[256 more lines in file. Use offset=61 to continue.]"}],"isError":false,"timestamp":1778755693096}}
